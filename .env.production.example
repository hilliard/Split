# Database Configuration - Neon Production
DATABASE_URL=postgresql://user:password@endpoint.c.neon.tech/dbname?sslmode=require&channel_binding=require

# Authentication - Use a strong secret in production!
SESSION_SECRET=generate-a-strong-secret-with-crypto.randomBytes-for-production

# Email (Resend) - Use production API key and verified domain
RESEND_API_KEY=re_your_production_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Public URL for production
PUBLIC_URL=https://yourdomain.com

# Environment
NODE_ENV=production
