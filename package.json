{
  "name": "split",
  "type": "module",
  "version": "0.1.0",
  "description": "Split - A shared expense tracker app",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "astro": "astro",
    "db:push": "drizzle-kit push",
    "db:local:generate": "dotenv -e .env.local -- npm run db:generate",
    "db:local:push": "dotenv -e .env.local -- npm run db:push",
    "db:neon:generate": "dotenv -e .env.production -- npm run db:generate",
    "db:neon:push": "dotenv -e .env.production -- npm run db:push",
    "health:db": "node scripts/db-healthcheck.js",
    "health:db:local": "dotenv -e .env.local -- npm run health:db",
    "health:db:neon": "dotenv -e .env.production -- npm run health:db",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:restart": "docker-compose restart",
    "docker:logs": "docker-compose logs -f postgres",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "e2e": "playwright test",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:local:schema": "node scripts/verify-local-schema.js"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.11",
    "@neondatabase/serverless": "^1.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "alpinejs": "^3.15.11",
    "astro": "^6.1.3",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.0",
    "drizzle-orm": "0.45.2",
    "htmx.org": "^2.0.8",
    "pg": "^8.10.0",
    "postgres": "^3.4.8",
    "resend": "^6.1.3",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/node": "^10.0.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-prettier": "^5.5.5",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  }
}