---
import { getSession } from '@/utils/session';
import { isSystemAdmin } from '@/db/authorization';

interface Props {
  title?: string;
  currentPage?: string;
}

const { title = 'Split', currentPage } = Astro.props;

import { db } from '@/db';
import { customers } from '@/db/schema';
import { eq } from 'drizzle-orm';

// Get user session and check if admin
const sessionId = Astro.cookies.get('sessionId')?.value;
const session = sessionId ? await getSession(sessionId) : null;
const isAdmin = session ? await isSystemAdmin(session.userId) : false;

let username = '';
if (session) {
  try {
    const [customer] = await db
      .select({ username: customers.username, email: customers.email })
      .from(customers)
      .where(eq(customers.humanId, session.userId))
      .limit(1);
    
    if (customer) {
      username = customer.username || customer.email;
    }
  } catch (error) {
    console.error('Failed to load username for header:', error);
  }
}
---

<header
  class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
>
  <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo/Home Link -->
      <a
        href={session ? "/dashboard" : "/"}
        class="text-lg sm:text-2xl font-bold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors flex-shrink-0"
      >
        ⚡ Split
      </a>

      <!-- Desktop Navigation -->
      {session && (
        <nav class="hidden md:flex items-center gap-1 flex-1 mx-6">
          <a
            href="/dashboard"
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPage === 'dashboard'
                ? 'bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-200'
                : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700'
            }`}
          >
            Dashboard
          </a>
          <a
            href="/events/create"
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPage === 'events'
                ? 'bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-200'
                : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700'
            }`}
          >
            Events
          </a>
          <a
            href="/standalone-activities"
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPage === 'activities'
                ? 'bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-200'
                : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700'
            }`}
          >
            Activities
          </a>
          <a
            href="/expenses/create"
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPage === 'expenses'
                ? 'bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-200'
                : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700'
            }`}
          >
            Add Expense
          </a>
          <a
            href="/groups/create"
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPage === 'groups'
                ? 'bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-200'
                : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700'
            }`}
          >
            Groups
          </a>
          {isAdmin && (
            <a
              href="/admin/users"
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                currentPage === 'admin'
                  ? 'bg-orange-100 dark:bg-orange-900 text-orange-700 dark:text-orange-200'
                  : 'text-orange-600 dark:text-orange-400 hover:text-orange-700 dark:hover:text-orange-300 hover:bg-orange-100 dark:hover:bg-orange-900'
              }`}
            >
              🔐 Manage Users
            </a>
          )}
        </nav>
      )}

      <!-- Right Side: Theme Toggle + Mobile Menu + Auth Actions -->
      <div class="flex items-center gap-2 ml-auto">
        <!-- Theme Toggle -->
        <button
          id="themeToggle"
          onclick="window.toggleTheme && window.toggleTheme()"
          class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors text-lg flex-shrink-0"
          aria-label="Toggle dark mode"
        >
          <span id="themeIcon">☀️</span>
        </button>

        {session ? (
          <>
            <!-- Welcome Message -->
            <span class="hidden sm:inline-block text-sm font-medium text-slate-600 dark:text-slate-300 mr-2">
              Welcome, {username}!
            </span>

            <!-- Mobile Menu Button -->
            <button
              id="mobileMenuBtn"
              class="md:hidden p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors flex-shrink-0"
              aria-label="Toggle menu"
            >
              <span class="text-2xl">☰</span>
            </button>

            <!-- Logout Button -->
            <form method="POST" action="/api/auth/logout" style="display: inline;">
              <button
                type="submit"
                class="px-3 sm:px-4 py-2 text-xs sm:text-sm bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-semibold flex-shrink-0 whitespace-nowrap border-0 cursor-pointer"
              >
                Logout
              </button>
            </form>
          </>
        ) : (
          <div class="hidden sm:flex gap-2 items-center ml-2">
            <a
              href="/auth/login"
              class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors px-3 py-2"
            >
              Login
            </a>
            <a
              href="/auth/register"
              class="text-sm font-medium px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors"
            >
              Sign Up
            </a>
          </div>
        )}
      </div>
    </div>

    <!-- Mobile Navigation Menu (Only if authenticated) -->
    {session && (
      <nav id="mobileMenu" class="hidden md:hidden pb-4 space-y-2 animate-in fade-in duration-200">
        <a
          href="/dashboard"
          class="block px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
        >
          Dashboard
        </a>
        <a
          href="/events/create"
          class="block px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
        >
          Events
        </a>
        <a
          href="/standalone-activities"
          class="block px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
        >
          Activities
        </a>
        <a
          href="/expenses/create"
          class="block px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
        >
          Add Expense
        </a>
        <a
          href="/groups/create"
          class="block px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
        >
          Groups
        </a>
        {isAdmin && (
          <a
            href="/admin/users"
            class="block px-4 py-2 rounded-lg text-sm font-medium text-orange-600 dark:text-orange-400 hover:text-orange-700 dark:hover:text-orange-300 hover:bg-orange-100 dark:hover:bg-orange-900 transition-colors"
          >
            🔐 Manage Users
          </a>
        )}
      </nav>
    )}
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Close menu when clicking on a link
    const links = mobileMenu.querySelectorAll('a');
    links.forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-in {
    animation: fadeIn 0.2s ease-in-out;
  }
</style>
