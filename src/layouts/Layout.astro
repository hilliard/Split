---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const { title, description = 'Split - Expense Tracking Made Simple', currentPage } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5, user-scalable=yes"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#4f46e5" />
    <title>{title} | Split</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body
    class="bg-white dark:bg-slate-950 text-slate-900 dark:text-white transition-colors duration-200 min-h-screen flex flex-col"
  >
    <Header currentPage={currentPage} />
    <slot />

    <script is:inline>
      // Dark mode initialization - run ASAP before rendering to prevent flash
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = savedTheme || (prefersDark ? 'dark' : 'light');

      // Set HTML class
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }

      // Also set inline styles for guaranteed visibility
      if (theme === 'dark') {
        document.documentElement.style.colorScheme = 'dark';
        document.body.style.backgroundColor = 'rgb(6, 6, 10)';
        document.body.style.color = 'rgb(248, 250, 252)';

        // Inject dark mode CSS for elements
        const darkStyle = document.createElement('style');
        darkStyle.id = 'dynamicDarkStyles';
        darkStyle.textContent = `
          html.dark header,
          html.dark header.bg-white {
            background-color: rgb(15, 23, 42) !important;
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark header {
            color: rgb(129, 140, 248) !important;
          }
          html.dark header * {
            color: rgb(129, 140, 248) !important;
          }
          html.dark header a,
          html.dark header h1,
          html.dark header button {
            color: rgb(129, 140, 248) !important;
          }
          html.dark main {
            background-color: rgb(6, 6, 10) !important;
          }
          html.dark [class*="bg-white"],
          html.dark [class*="bg-slate-50"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="bg-slate-800"] {
            background-color: rgb(30, 41, 59) !important;
          }
          html.dark [class*="bg-slate-900"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="text-slate-900"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-slate-600"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-slate-400"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-white"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="border-slate-200"] {
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark [class*="border-slate-700"] {
            border-color: rgb(51, 65, 85) !important;
          }
        `;
        document.head.appendChild(darkStyle);
      } else {
        document.documentElement.style.colorScheme = 'light';
        document.body.style.backgroundColor = 'rgb(255, 255, 255)';
        document.body.style.color = 'rgb(15, 23, 42)';
      }

      // Initialize form handlers
      document.addEventListener('DOMContentLoaded', () => {
        // Setup register form
        const registerForm = document.getElementById('registerForm');
        if (registerForm) {
          registerForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const username = document.getElementById('registerUsername')?.value || '';
            const email = document.getElementById('registerEmail')?.value || '';
            const password = document.getElementById('registerPassword')?.value || '';
            const confirmPassword = document.getElementById('registerConfirmPassword')?.value || '';
            const errorDiv = document.getElementById('registerError');
            const submitBtn = registerForm.querySelector('button[type="submit"]');

            if (errorDiv) {
              errorDiv.innerHTML = '';
              errorDiv.classList.add('hidden');
            }
            if (submitBtn) submitBtn.disabled = true;

            try {
              const response = await fetch('/api/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  username,
                  email,
                  password,
                  confirmPassword,
                }),
              });

              const data = await response.json();

              if (!response.ok) {
                const errorMsg = Array.isArray(data.error)
                  ? data.error[0]?.message || 'Registration failed'
                  : data.error || 'Registration failed';
                if (errorDiv) {
                  errorDiv.innerHTML = errorMsg;
                  errorDiv.classList.remove('hidden');
                }
              } else {
                window.location.href = '/dashboard';
              }
            } catch (error) {
              console.error('Register error:', error);
              if (errorDiv) {
                errorDiv.innerHTML = 'An error occurred. Please try again.';
                errorDiv.classList.remove('hidden');
              }
            } finally {
              if (submitBtn) submitBtn.disabled = false;
            }
          });
        }

        // Setup login form
        const loginForm = document.getElementById('loginForm');
        if (loginForm) {
          loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('loginEmail')?.value || '';
            const password = document.getElementById('loginPassword')?.value || '';
            const errorDiv = document.getElementById('loginError');
            const submitBtn = loginForm.querySelector('button[type="submit"]');

            if (errorDiv) {
              errorDiv.innerHTML = '';
              errorDiv.classList.add('hidden');
            }
            if (submitBtn) submitBtn.disabled = true;

            try {
              const response = await fetch('/api/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password }),
              });

              const data = await response.json();

              if (!response.ok) {
                if (errorDiv) {
                  errorDiv.innerHTML = data.error || 'Login failed';
                  errorDiv.classList.remove('hidden');
                }
              } else {
                window.location.href = '/dashboard';
              }
            } catch (error) {
              console.error('Login error:', error);
              if (errorDiv) {
                errorDiv.innerHTML = 'An error occurred. Please try again.';
                errorDiv.classList.remove('hidden');
              }
            } finally {
              if (submitBtn) submitBtn.disabled = false;
            }
          });
        }
      });

      // Global Custom Confirmation Modal
      window.customConfirm = function(message, title = "Confirm Action") {
        return new Promise((resolve) => {
          const modal = document.getElementById('globalConfirmModal');
          const titleEl = document.getElementById('globalConfirmTitle');
          const msgEl = document.getElementById('globalConfirmMessage');
          const confirmBtn = document.getElementById('globalConfirmBtn');
          const cancelBtn = document.getElementById('globalCancelBtn');
          
          if (titleEl) titleEl.textContent = title;
          if (msgEl) msgEl.textContent = message;
          if (modal) modal.classList.remove('hidden');
          
          const cleanup = () => {
            if (modal) modal.classList.add('hidden');
            confirmBtn.removeEventListener('click', onConfirm);
            cancelBtn.removeEventListener('click', onCancel);
          };
          
          const onConfirm = () => { cleanup(); resolve(true); };
          const onCancel = () => { cleanup(); resolve(false); };
          
          if (confirmBtn) confirmBtn.addEventListener('click', onConfirm);
          if (cancelBtn) cancelBtn.addEventListener('click', onCancel);
        });
      };
    </script>

    <!-- Global Confirmation Modal -->
    <div id="globalConfirmModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-[100] flex items-center justify-center p-4">
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-sm border border-slate-200 dark:border-slate-700">
        <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
          <h2 id="globalConfirmTitle" class="text-lg font-bold text-red-600 dark:text-red-400">Confirm Action</h2>
        </div>
        <div class="p-5 sm:p-6">
          <p id="globalConfirmMessage" class="text-slate-700 dark:text-slate-300"></p>
        </div>
        <div class="flex gap-3 justify-end p-5 sm:p-6 border-t border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 rounded-b-lg">
          <button type="button" id="globalCancelBtn" class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm">Cancel</button>
          <button type="button" id="globalConfirmBtn" class="px-4 py-2 bg-red-600 text-white hover:bg-red-700 rounded-lg transition-colors font-medium text-sm">Confirm</button>
        </div>
      </div>
    </div>
  </body>
</html>

<style is:global>
  * {
    @apply antialiased;
  }

  /* Hide default browser password toggle icons */
  input[type="password"]::-ms-reveal,
  input[type="password"]::-ms-clear {
    display: none;
  }
</style>
