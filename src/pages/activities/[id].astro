---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../db";
import { events, sessions, activities } from "../../db/schema";
import { eq } from "drizzle-orm";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}

// Get session and verify user
const [session] = await db
  .select()
  .from(sessions)
  .where(eq(sessions.id, sessionId))
  .limit(1);

if (!session || new Date(session.expiresAt) < new Date()) {
  return Astro.redirect("/auth/login");
}

// Get activity ID from URL
const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

// Get activity
const [activity] = await db
  .select()
  .from(activities)
  .where(eq(activities.id, id as string))
  .limit(1);

if (!activity) {
  return Astro.redirect("/dashboard");
}

// Get event and verify ownership
const [event] = await db
  .select()
  .from(events)
  .where(eq(events.id, activity.eventId))
  .limit(1);

if (!event || event.creatorId !== session.userId) {
  return Astro.redirect("/dashboard");
}

// Format timestamps for form input
const formatDatetimeLocal = (date: Date | null | undefined) => {
  if (!date) return "";
  try {
    return new Date(date).toISOString().slice(0, 16);
  } catch {
    return "";
  }
};

const startTimeValue = formatDatetimeLocal(activity.startTime);
const endTimeValue = formatDatetimeLocal(activity.endTime);
---

<Layout
  title={`Edit Activity - ${activity.title}`}
  description="Edit activity details"
>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <h1 class="text-2xl font-bold text-slate-900 dark:text-white">
            Edit Activity
          </h1>
          <a
            href={`/activities/?eventId=${event.id}`}
            class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors"
          >
            Back to Activities
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main
      class="flex-1 max-w-4xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8"
    >
      <!-- Edit Form Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <form id="editActivityForm" class="space-y-4">
          <!-- Activity Title -->
          <div>
            <label
              for="activityTitle"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Activity Title
            </label>
            <input
              type="text"
              id="activityTitle"
              name="title"
              value={activity.title}
              required
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Location -->
          <div>
            <label
              for="locationName"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Location (Optional)
            </label>
            <input
              type="text"
              id="locationName"
              name="locationName"
              value={activity.locationName || ""}
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- DateTime Range -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="startTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Start Time (Optional)
              </label>
              <input
                type="datetime-local"
                id="startTime"
                name="startTime"
                value={startTimeValue}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label
                for="endTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                End Time (Optional)
              </label>
              <input
                type="datetime-local"
                id="endTime"
                name="endTime"
                value={endTimeValue}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Sequence Order -->
          <div>
            <label
              for="sequenceOrder"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Sequence Order
            </label>
            <input
              type="number"
              id="sequenceOrder"
              name="sequenceOrder"
              value={activity.sequenceOrder}
              min="0"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Buttons -->
          <div class="flex gap-3 pt-4">
            <button
              type="submit"
              class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium"
            >
              Save Changes
            </button>
            <button
              type="button"
              id="addExpenseBtn"
              class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium"
            >
              💰 Add Expense
            </button>
            <button
              type="button"
              id="deleteBtn"
              class="px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium"
            >
              Delete Activity
            </button>
            <a
              href={`/activities/?eventId=${event.id}`}
              class="px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
            >
              Cancel
            </a>
          </div>
        </form>
      </div>
    </main>
  </div>

  <!-- Add Expense Modal -->
  <div
    id="addExpenseModal"
    class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
  >
    <div
      class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-md border border-slate-200 dark:border-slate-700 my-8"
    >
      <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
        <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white">
          Add Expense
        </h2>
      </div>

      <form id="addExpenseForm" class="p-5 sm:p-6 space-y-4">
        <div>
          <label
            for="expenseDescription"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Description
          </label>
          <input
            type="text"
            id="expenseDescription"
            name="description"
            placeholder="Expense details"
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
          />
        </div>

        <div>
          <label
            for="expenseCategory"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Category
          </label>
          <select
            id="expenseCategory"
            name="category"
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
          >
            <option value="meal">Meal / Food</option>
            <option value="transport">Transport</option>
            <option value="accommodation">Accommodation</option>
            <option value="parking">Parking</option>
            <option value="entertainment">Entertainment</option>
            <option value="tickets">Tickets</option>
            <option value="misc" selected>Miscellaneous</option>
          </select>
        </div>

        <div>
          <label
            for="expenseAmount"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Amount ($) <span class="text-red-600">*</span>
          </label>
          <input
            type="number"
            id="expenseAmount"
            name="amount"
            step="0.01"
            min="0"
            placeholder="0.00"
            required
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
          />
        </div>

        <div
          id="expenseError"
          class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
        >
        </div>

        <div
          class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700"
        >
          <button
            type="button"
            id="cancelExpenseBtn"
            class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
          >
            Cancel
          </button>
          <button
            type="submit"
            class="px-4 py-2 bg-green-600 text-white hover:bg-green-700 rounded-lg transition-colors font-medium text-sm"
          >
            Add Expense
          </button>
        </div>
      </form>
    </div>
  </div>

  <script
    define:vars={{
      activityId: id,
      eventId: activity.eventId,
      userId: session.userId,
    }}
  >
    const editForm = document.getElementById("editActivityForm");
    const deleteBtn = document.getElementById("deleteBtn");
    const addExpenseBtn = document.getElementById("addExpenseBtn");
    const addExpenseModal = document.getElementById("addExpenseModal");
    const addExpenseForm = document.getElementById("addExpenseForm");
    const cancelExpenseBtn = document.getElementById("cancelExpenseBtn");
    const expenseError = document.getElementById("expenseError");

    // Open Add Expense Modal
    addExpenseBtn.addEventListener("click", () => {
      addExpenseModal.classList.remove("hidden");
    });

    // Close Add Expense Modal
    cancelExpenseBtn.addEventListener("click", () => {
      addExpenseModal.classList.add("hidden");
      addExpenseForm.reset();
      expenseError.classList.add("hidden");
    });

    // Close modal on outside click
    addExpenseModal.addEventListener("click", (e) => {
      if (e.target === addExpenseModal) {
        addExpenseModal.classList.add("hidden");
        addExpenseForm.reset();
        expenseError.classList.add("hidden");
      }
    });

    // Add Expense Form Submission
    addExpenseForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      try {
        // Get the event to retrieve groupId
        const eventResponse = await fetch(`/api/events/${eventId}`);
        if (!eventResponse.ok) {
          expenseError.textContent =
            "Could not fetch event details. Please try again.";
          expenseError.classList.remove("hidden");
          return;
        }

        const eventData = await eventResponse.json();
        const groupId = eventData.event.groupId;

        if (!groupId) {
          expenseError.textContent =
            "This event doesn't have a group assigned yet. Please assign a group first.";
          expenseError.classList.remove("hidden");
          return;
        }

        // Get form data
        const formData = new FormData(addExpenseForm);
        const amount = parseFloat(formData.get("amount")) || 0;

        if (amount <= 0) {
          expenseError.textContent = "Amount must be greater than 0";
          expenseError.classList.remove("hidden");
          return;
        }

        // Create expense
        const expenseResponse = await fetch("/api/expenses/create", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            groupId: groupId,
            activityId: activityId,
            description: formData.get("description") || null,
            category: formData.get("category") || "misc",
            amount: Math.round(amount * 100),
            paidBy: userId,
          }),
        });

        if (!expenseResponse.ok) {
          const error = await expenseResponse.json();
          expenseError.textContent = error.error || "Failed to create expense";
          expenseError.classList.remove("hidden");
          return;
        }

        // Success
        alert(`Expense of $${amount.toFixed(2)} added successfully!`);
        addExpenseModal.classList.add("hidden");
        addExpenseForm.reset();
        expenseError.classList.add("hidden");
      } catch (error) {
        console.error("Error:", error);
        expenseError.textContent = "An error occurred. Please try again.";
        expenseError.classList.remove("hidden");
      }
    });

    editForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(editForm);
      const data = {
        activityId,
        eventId,
        title: formData.get("title"),
        locationName: formData.get("locationName") || null,
        startTime: formData.get("startTime") || null,
        endTime: formData.get("endTime") || null,
        sequenceOrder: parseInt(formData.get("sequenceOrder")) || 0,
      };

      try {
        const response = await fetch("/api/activities/update", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          alert(
            "Error: " +
              (error.error?.message ||
                error.error ||
                "Failed to update activity"),
          );
          return;
        }

        alert("Activity updated successfully!");
        window.location.href = `/activities/?eventId=${eventId}`;
      } catch (error) {
        alert("Error: " + error.message);
      }
    });

    deleteBtn.addEventListener("click", async () => {
      if (
        !confirm(
          "Are you sure you want to delete this activity? This cannot be undone.",
        )
      ) {
        return;
      }

      try {
        const response = await fetch("/api/activities/delete", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            activityId,
            eventId,
          }),
        });

        if (!response.ok) {
          const error = await response.json();
          alert(
            "Error: " +
              (error.error?.message ||
                error.error ||
                "Failed to delete activity"),
          );
          return;
        }

        alert("Activity deleted successfully!");
        window.location.href = `/activities/index?eventId=${eventId}`;
      } catch (error) {
        alert("Error: " + error.message);
      }
    });
  </script>
</Layout>
