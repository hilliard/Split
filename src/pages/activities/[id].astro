---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../db";
import { events, sessions, activities } from "../../db/schema";
import { eq } from "drizzle-orm";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}

// Get session and verify user
const [session] = await db
  .select()
  .from(sessions)
  .where(eq(sessions.id, sessionId))
  .limit(1);

if (!session || new Date(session.expiresAt) < new Date()) {
  return Astro.redirect("/auth/login");
}

// Get activity ID from URL
const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

// Get activity
const [activity] = await db
  .select()
  .from(activities)
  .where(eq(activities.id, id as string))
  .limit(1);

if (!activity) {
  return Astro.redirect("/dashboard");
}

// Get event and verify ownership
const [event] = await db
  .select()
  .from(events)
  .where(eq(events.id, activity.eventId))
  .limit(1);

if (!event || event.creatorId !== session.userId) {
  return Astro.redirect("/dashboard");
}

// Format timestamps for form input
const formatDatetimeLocal = (date: Date | null | undefined) => {
  if (!date) return "";
  try {
    return new Date(date).toISOString().slice(0, 16);
  } catch {
    return "";
  }
};

const startTimeValue = formatDatetimeLocal(activity.startTime);
const endTimeValue = formatDatetimeLocal(activity.endTime);
---

<Layout
  title={`Edit Activity - ${activity.title}`}
  description="Edit activity details"
>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <h1 class="text-2xl font-bold text-slate-900 dark:text-white">
            Edit Activity
          </h1>
          <a
            href={`/activities/?eventId=${event.id}`}
            class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors"
          >
            Back to Activities
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main
      class="flex-1 max-w-4xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8"
    >
      <!-- Edit Form Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <form id="editActivityForm" class="space-y-4">
          <!-- Activity Title -->
          <div>
            <label
              for="activityTitle"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Activity Title
            </label>
            <input
              type="text"
              id="activityTitle"
              name="title"
              value={activity.title}
              required
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Location -->
          <div>
            <label
              for="locationName"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Location (Optional)
            </label>
            <input
              type="text"
              id="locationName"
              name="locationName"
              value={activity.locationName || ""}
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- DateTime Range -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="startTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Start Time (Optional)
              </label>
              <input
                type="datetime-local"
                id="startTime"
                name="startTime"
                value={startTimeValue}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label
                for="endTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                End Time (Optional)
              </label>
              <input
                type="datetime-local"
                id="endTime"
                name="endTime"
                value={endTimeValue}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Sequence Order -->
          <div>
            <label
              for="sequenceOrder"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Sequence Order
            </label>
            <input
              type="number"
              id="sequenceOrder"
              name="sequenceOrder"
              value={activity.sequenceOrder}
              min="0"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Buttons -->
          <div class="flex gap-3 pt-4">
            <button
              type="submit"
              class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium"
            >
              Save Changes
            </button>
            <button
              type="button"
              id="deleteBtn"
              class="px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium"
            >
              Delete Activity
            </button>
            <a
              href={`/activities/?eventId=${event.id}`}
              class="px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
            >
              Cancel
            </a>
          </div>
        </form>
      </div>
    </main>
  </div>

  <script define:vars={{ activityId: id, eventId: activity.eventId }}>
    const editForm = document.getElementById("editActivityForm");
    const deleteBtn = document.getElementById("deleteBtn");

    editForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(editForm);
      const data = {
        activityId,
        eventId,
        title: formData.get("title"),
        locationName: formData.get("locationName") || null,
        startTime: formData.get("startTime") || null,
        endTime: formData.get("endTime") || null,
        sequenceOrder: parseInt(formData.get("sequenceOrder")) || 0,
      };

      try {
        const response = await fetch("/api/activities/update", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          alert(
            "Error: " +
              (error.error?.message ||
                error.error ||
                "Failed to update activity"),
          );
          return;
        }

        alert("Activity updated successfully!");
        window.location.href = `/activities/?eventId=${eventId}`;
      } catch (error) {
        alert("Error: " + error.message);
      }
    });

    deleteBtn.addEventListener("click", async () => {
      if (
        !confirm(
          "Are you sure you want to delete this activity? This cannot be undone.",
        )
      ) {
        return;
      }

      try {
        const response = await fetch("/api/activities/delete", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            activityId,
            eventId,
          }),
        });

        if (!response.ok) {
          const error = await response.json();
          alert(
            "Error: " +
              (error.error?.message ||
                error.error ||
                "Failed to delete activity"),
          );
          return;
        }

        alert("Activity deleted successfully!");
        window.location.href = `/activities/index?eventId=${eventId}`;
      } catch (error) {
        alert("Error: " + error.message);
      }
    });
  </script>
</Layout>
