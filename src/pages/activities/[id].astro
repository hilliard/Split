---
import { getSession } from '../../utils/session';
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { events, sessions, activities, groupMembers } from '../../db/schema';
import { eq, and } from 'drizzle-orm';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

const session = await getSession(sessionId);
if (!session) {
  Astro.cookies.delete('sessionId', { path: '/' });
  return Astro.redirect('/auth/login');
}

// Get session and verify user

// Get activity ID from URL
const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/dashboard');
}

// Get activity
const [activity] = await db
  .select()
  .from(activities)
  .where(eq(activities.id, id as string))
  .limit(1);

if (!activity) {
  return Astro.redirect('/dashboard');
}

// Get event and verify ownership
if (!activity.eventId) {
  return Astro.redirect('/dashboard');
}
const [event] = await db.select().from(events).where(eq(events.id, activity.eventId)).limit(1);

if (!event) {
  return Astro.redirect('/dashboard');
}

// Check authorization: user is creator OR member of the group
const isCreator = event.creatorId === session.userId;
let isGroupMember = false;

if (event.groupId) {
  const [membership] = await db
    .select()
    .from(groupMembers)
    .where(and(eq(groupMembers.userId, session.userId), eq(groupMembers.groupId, event.groupId)))
    .limit(1);
  isGroupMember = !!membership;
}

if (!isCreator && !isGroupMember) {
  return Astro.redirect('/dashboard');
}

// Format timestamps for form input
const formatDatetimeLocal = (date: Date | null | undefined) => {
  if (!date) return '';
  try {
    const d = new Date(date);
    const pad = (n: number) => n.toString().padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  } catch {
    return '';
  }
};

const startTimeValue = formatDatetimeLocal(activity.startTime);
const endTimeValue = formatDatetimeLocal(activity.endTime);
---

<Layout
  title={`Edit Activity - ${activity.title}`}
  description="Edit activity details"
  currentPage="activities"
>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Sub-header with breadcrumb and navigation -->
    <nav
      class="bg-slate-100 dark:bg-slate-700 border-b border-slate-200 dark:border-slate-600 sticky top-16 z-40"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex gap-2 h-12 items-center overflow-x-auto">
          <!-- Breadcrumb -->
          <a
            href={`/events/${event.id}`}
            class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 text-sm font-medium whitespace-nowrap"
          >
            {event.title}
          </a>
          <span class="text-slate-400 dark:text-slate-500">/</span>
          <a
            href={`/activities/?eventId=${event.id}`}
            class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 text-sm font-medium whitespace-nowrap"
          >
            Activities
          </a>
          <span class="text-slate-400 dark:text-slate-500">/</span>
          <span class="text-slate-700 dark:text-slate-300 text-sm font-medium whitespace-nowrap">
            Edit Activity
          </span>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <!-- Edit Form Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <form id="editActivityForm" class="space-y-4">
          <!-- Activity Title -->
          <div>
            <label
              for="activityTitle"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Activity Title
            </label>
            <input
              type="text"
              id="activityTitle"
              name="title"
              value={activity.title}
              required
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Location -->
          <div>
            <label
              for="locationName"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Location (Optional)
            </label>
            <input
              type="text"
              id="locationName"
              name="locationName"
              value={activity.locationName || ''}
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- DateTime Range -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="startTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Start Time (Optional)
              </label>
              <input
                type="datetime-local"
                id="startTime"
                name="startTime"
                value={startTimeValue}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label
                for="endTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                End Time (Optional)
              </label>
              <input
                type="datetime-local"
                id="endTime"
                name="endTime"
                value={endTimeValue}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Sequence Order -->
          <div>
            <label
              for="sequenceOrder"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Sequence Order
            </label>
            <input
              type="number"
              id="sequenceOrder"
              name="sequenceOrder"
              value={activity.sequenceOrder}
              min="0"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Details/Metadata Section -->
          <div>
            <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
              Details (Flight #, Address, Attendees, etc.)
            </label>

            <!-- Template Selector -->
            <div class="mb-4 flex gap-2 items-end">
              <div class="flex-1">
                <label
                  for="templateSelect"
                  class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1"
                >
                  Quick Templates
                </label>
                <select
                  id="templateSelect"
                  class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
                >
                  <option value="">-- Select a template --</option>
                  <option value="flight">✈️ One-Way Flight</option>
                  <option value="roundtrip_flight">🔄 Round-Trip Flight</option>
                  <option value="hotel">🏨 Hotel</option>
                  <option value="car_rental">🚗 Car Rental</option>
                  <option value="restaurant">🍽️ Restaurant/Dinner</option>
                  <option value="tourist">🎫 Tourist Activity</option>
                </select>
              </div>
              <button
                type="button"
                id="applyTemplateBtn"
                class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium text-sm whitespace-nowrap"
              >
                Apply Template
              </button>
            </div>

            <div id="metadataContainer" class="space-y-3">
              <!-- Dynamic metadata fields will be added here -->
            </div>
            <button
              type="button"
              id="addMetadataFieldBtn"
              class="mt-3 px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium text-sm"
            >
              + Add Detail
            </button>
          </div>

          <!-- Buttons -->
          <div class="flex gap-3 pt-4">
            <button
              type="submit"
              class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium"
            >
              Save Changes
            </button>
            <button
              type="button"
              id="addExpenseBtn"
              class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium"
            >
              💰 Add Expense
            </button>
            <button
              type="button"
              id="deleteBtn"
              class="px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium"
            >
              Delete Activity
            </button>
            <a
              href={`/activities/?eventId=${event.id}`}
              class="px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
            >
              Cancel
            </a>
          </div>
        </form>
      </div>
    </main>
  </div>

  <!-- Toast Notification -->
  <div
    id="toast"
    class="fixed bottom-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none z-50 max-w-xs"
  >
    <span id="toast-message"></span>
  </div>

  <!-- Add Expense Modal -->
  <div
    id="addExpenseModal"
    class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
  >
    <div
      class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-md border border-slate-200 dark:border-slate-700 my-8"
    >
      <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
        <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white">Add Expense</h2>
      </div>

      <form id="addExpenseForm" class="p-5 sm:p-6 space-y-4">
        <div>
          <label
            for="expenseDescription"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Description
          </label>
          <input
            type="text"
            id="expenseDescription"
            name="description"
            placeholder="Expense details"
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
          />
        </div>

        <div>
          <label
            for="expenseCategory"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Category
          </label>
          <select
            id="expenseCategory"
            name="category"
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
          >
            <option value="meal">Meal / Food</option>
            <option value="transport">Transport</option>
            <option value="flight">Flight</option>
            <option value="roundtrip_flight">🔄 Round-Trip Flight</option>
            <option value="accommodation">Accommodation</option>
            <option value="parking">Parking</option>
            <option value="entertainment">Entertainment</option>
            <option value="tickets">Tickets</option>
            <option value="misc" selected>Miscellaneous</option>
          </select>
        </div>

        <div>
          <label
            for="expenseAmount"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Amount ($) <span class="text-red-600">*</span>
          </label>
          <input
            type="number"
            id="expenseAmount"
            name="amount"
            step="0.01"
            min="0"
            placeholder="0.00"
            required
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
          />
        </div>

        <div
          id="expenseError"
          class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
        >
        </div>

        <div class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700">
          <button
            type="button"
            id="cancelExpenseBtn"
            class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
          >
            Cancel
          </button>
          <button
            type="submit"
            class="px-4 py-2 bg-green-600 text-white hover:bg-green-700 rounded-lg transition-colors font-medium text-sm"
          >
            Add Expense
          </button>
        </div>
      </form>
    </div>
  </div>

  <script
    define:vars={{
      activityId: id,
      eventId: activity.eventId,
      userId: session.userId,
      activity: activity,
    }}
  >
    const editForm = document.getElementById('editActivityForm');
    const deleteBtn = document.getElementById('deleteBtn');
    const addExpenseBtn = document.getElementById('addExpenseBtn');
    const addExpenseModal = document.getElementById('addExpenseModal');
    const addExpenseForm = document.getElementById('addExpenseForm');
    const cancelExpenseBtn = document.getElementById('cancelExpenseBtn');
    const expenseError = document.getElementById('expenseError');
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toast-message');

    // Toast notification helper
    function showToast(message) {
      toastMessage.textContent = message;
      toast.classList.remove('opacity-0');
      setTimeout(() => {
        toast.classList.add('opacity-0');
      }, 5000);
    }

    // Open Add Expense Modal
    addExpenseBtn.addEventListener('click', () => {
      addExpenseModal.classList.remove('hidden');
    });

    // Close Add Expense Modal
    cancelExpenseBtn.addEventListener('click', () => {
      addExpenseModal.classList.add('hidden');
      addExpenseForm.reset();
      expenseError.classList.add('hidden');
    });

    // Close modal on outside click
    addExpenseModal.addEventListener('click', (e) => {
      if (false && e.target === addExpenseModal) {
        addExpenseModal.classList.add('hidden');
        addExpenseForm.reset();
        expenseError.classList.add('hidden');
      }
    });

    // Add Expense Form Submission
    addExpenseForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      try {
        // Get the event to retrieve groupId
        const eventResponse = await fetch(`/api/events/${eventId}`);
        if (!eventResponse.ok) {
          expenseError.textContent = 'Could not fetch event details. Please try again.';
          expenseError.classList.remove('hidden');
          return;
        }

        const eventData = await eventResponse.json();
        const groupId = eventData.event.groupId;

        if (!groupId) {
          expenseError.textContent =
            "This event doesn't have a group assigned yet. Please assign a group first.";
          expenseError.classList.remove('hidden');
          return;
        }

        // Get form data
        const formData = new FormData(addExpenseForm);
        const amount = parseFloat(formData.get('amount')) || 0;

        if (amount <= 0) {
          expenseError.textContent = 'Amount must be greater than 0';
          expenseError.classList.remove('hidden');
          return;
        }

        // Create expense
        const expenseResponse = await fetch('/api/expenses/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            groupId: groupId,
            eventId: eventId,
            activityId: activityId,
            description: formData.get('description') || undefined,
            category: formData.get('category') || 'misc',
            amount: Math.round(amount * 100),
            paidBy: userId,
          }),
        });

        if (!expenseResponse.ok) {
          const error = await expenseResponse.json();
          expenseError.textContent = error.error || 'Failed to create expense';
          expenseError.classList.remove('hidden');
          return;
        }

        // Success
        showToast(`Expense of $${amount.toFixed(2)} added successfully!`);
        addExpenseModal.classList.add('hidden');
        addExpenseForm.reset();
        expenseError.classList.add('hidden');
      } catch (error) {
        console.error('Error:', error);
        expenseError.textContent = 'An error occurred. Please try again.';
        expenseError.classList.remove('hidden');
      }
    });

    // Metadata field handlers
    function addMetadataField(key = '', value = '') {
      const container = document.getElementById('metadataContainer');
      const fieldId = 'metadata-' + Date.now() + Math.random();
      const fieldHTML = `
        <div class="flex gap-2" id="${fieldId}">
          <input
            type="text"
            name="metadataKey"
            placeholder="Key (e.g., Flight Number)"
            value="${key}"
            class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
          />
          <input
            type="text"
            name="metadataValue"
            placeholder="Value (e.g., DL123)"
            value="${value}"
            class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
          />
          <button
            type="button"
            onclick="document.getElementById('${fieldId}').remove()"
            class="px-3 py-2 bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-200 rounded-lg hover:bg-red-200 dark:hover:bg-red-800 transition-colors text-sm font-medium"
          >
            ✕
          </button>
        </div>
      `;
      container.insertAdjacentHTML('beforeend', fieldHTML);
    }

    const addMetadataFieldBtn = document.getElementById('addMetadataFieldBtn');
    if (addMetadataFieldBtn) {
      addMetadataFieldBtn.addEventListener('click', (e) => {
        e.preventDefault();
        addMetadataField();
      });
    }

    // Template definitions
    const templates = {
      flight: [
        ['Airline Company', ''],
        ['Flight Number', ''],
        ['Confirmation Number', ''],
        ['Take Off Time', ''],
        ['Arrival Time', ''],
        ['Seat Number', ''],
      ],
      roundtrip_flight: [
        ['Airline Company', ''],
        ['Confirmation Number', ''],
        ['Outbound Flight #', ''],
        ['Outbound Take Off', ''],
        ['Outbound Arrival', ''],
        ['Outbound Seat', ''],
        ['Return Flight #', ''],
        ['Return Take Off', ''],
        ['Return Arrival', ''],
        ['Return Seat', ''],
      ],
      hotel: [
        ['Hotel Name', ''],
        ['Address', ''],
        ['Check-in Date', ''],
        ['Check-out Date', ''],
        ['Confirmation Code', ''],
        ['Room Type', ''],
        ['Parking', ''],
        ['Contact Number', ''],
      ],
      car_rental: [
        ['Rental Company', ''],
        ['Reservation #', ''],
        ['Vehicle Type', ''],
        ['Pick Up Location', ''],
        ['Pick Up Time', ''],
        ['Drop Off Location', ''],
        ['Drop Off Time', ''],
      ],
      restaurant: [
        ['Restaurant Name', ''],
        ['Address', ''],
        ['Reservation Time', ''],
        ['Party Size', ''],
        ['Reservation Name', ''],
        ['Phone Number', ''],
        ['Cuisine Type', ''],
        ['Special Requests', ''],
        ['Dietary Restrictions', ''],
      ],
      tourist: [
        ['Location/Attraction', ''],
        ['Address', ''],
        ['Activity Duration', ''],
        ['Meeting Point', ''],
        ['Suggested Time', ''],
        ['Entrance Fee', ''],
        ['What to Bring', ''],
        ['Contact Number', ''],
      ],
    };

    // Apply template function
    function applyTemplate(templateType) {
      if (!templateType || !templates[templateType]) return;

      const container = document.getElementById('metadataContainer');
      container.innerHTML = ''; // Clear existing fields

      templates[templateType].forEach(([key, value]) => {
        addMetadataField(key, value);
      });

      showToast(
        `${templateType.charAt(0).toUpperCase() + templateType.slice(1)} template applied!`
      );
    }

    // Template selector event listener
    const templateSelect = document.getElementById('templateSelect');
    const applyTemplateBtn = document.getElementById('applyTemplateBtn');

    applyTemplateBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const selectedTemplate = templateSelect.value;
      applyTemplate(selectedTemplate);
    });

    // Load existing metadata
    function loadMetadata() {
      if (activity && activity.metadata && typeof activity.metadata === 'object') {
        Object.entries(activity.metadata).forEach(([key, value]) => {
          addMetadataField(key, String(value));
        });
      }
    }

    loadMetadata();

    editForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(editForm);

      // Collect metadata fields
      const metadata = {};
      const metadataKeys = formData.getAll('metadataKey');
      const metadataValues = formData.getAll('metadataValue');

      for (let i = 0; i < metadataKeys.length; i++) {
        const key = metadataKeys[i]?.trim();
        const value = metadataValues[i]?.trim();
        if (key && value) {
          metadata[key] = value;
        }
      }

      const data = {
        activityId,
        eventId,
        title: formData.get('title'),
        locationName: formData.get('locationName') || null,
        startTime: formData.get('startTime') || null,
        endTime: formData.get('endTime') || null,
        sequenceOrder: parseInt(formData.get('sequenceOrder')) || 0,
        metadata: Object.keys(metadata).length > 0 ? metadata : {},
      };

      try {
        const response = await fetch('/api/activities/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          alert('Error: ' + (error.error?.message || error.error || 'Failed to update activity'));
          return;
        }

        showToast('Activity updated successfully!');
        setTimeout(() => {
          window.location.href = `/activities/?eventId=${eventId}`;
        }, 1500);
      } catch (error) {
        alert('Error: ' + error.message);
      }
    });

    const deleteActivityModal = document.getElementById('deleteActivityModal');
    const cancelDeleteActivityBtn = document.getElementById('cancelDeleteActivityBtn');
    const confirmDeleteActivityBtn = document.getElementById('confirmDeleteActivityBtn');

    deleteBtn.addEventListener('click', () => {
      deleteActivityModal.classList.remove('hidden');
    });

    if (cancelDeleteActivityBtn) {
      cancelDeleteActivityBtn.addEventListener('click', () => {
        deleteActivityModal.classList.add('hidden');
      });
    }

    if (confirmDeleteActivityBtn) {
      confirmDeleteActivityBtn.addEventListener('click', async () => {
        try {
          const response = await fetch('/api/activities/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              activityId,
              eventId,
            }),
          });

          if (!response.ok) {
            const error = await response.json();
            showToast(
              'Error: ' + (error.error?.message || error.error || 'Failed to delete activity')
            );
            return;
          }

          deleteActivityModal.classList.add('hidden');
          showToast('Activity deleted successfully!');
          setTimeout(() => {
            window.location.href = `/activities/index?eventId=${eventId}`;
          }, 1500);
        } catch (error) {
          showToast('Error: ' + error.message);
        }
      });
    }
  </script>
  <!-- Delete Activity Confirmation Modal -->
  <div
    id="deleteActivityModal"
    class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4"
  >
    <div
      class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-sm border border-slate-200 dark:border-slate-700"
    >
      <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
        <h2 class="text-lg font-bold text-red-600 dark:text-red-400">Delete Activity</h2>
      </div>
      <div class="p-5 sm:p-6">
        <p class="text-slate-700 dark:text-slate-300">
          Are you sure you want to delete this activity? This action cannot be undone.
        </p>
      </div>
      <div
        class="flex gap-3 justify-end p-5 sm:p-6 border-t border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 rounded-b-lg"
      >
        <button
          type="button"
          id="cancelDeleteActivityBtn"
          class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
          >Cancel</button
        >
        <button
          type="button"
          id="confirmDeleteActivityBtn"
          class="px-4 py-2 bg-red-600 text-white hover:bg-red-700 rounded-lg transition-colors font-medium text-sm"
          >Delete</button
        >
      </div>
    </div>
  </div>
</Layout>
