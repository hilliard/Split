---
import { getSession } from '../../utils/session';
import { formatTimeRange } from '../../utils/time-format';
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { events, sessions, activities, groupMembers } from '../../db/schema';
import { eq, and, asc } from 'drizzle-orm';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

const session = await getSession(sessionId);
if (!session) {
  Astro.cookies.delete('sessionId', { path: '/' });
  return Astro.redirect('/auth/login');
}

// Get session and verify user

// Get event ID from query parameters
const eventId = Astro.url.searchParams.get('eventId');

if (!eventId) {
  return Astro.redirect('/dashboard');
}

// Get event and verify ownership
const [event] = await db.select().from(events).where(eq(events.id, eventId)).limit(1);

if (!event) {
  return Astro.redirect('/dashboard');
}

const isCreator = event.creatorId === session.userId;
let isGroupMember = false;

if (event.groupId) {
  const [membership] = await db
    .select()
    .from(groupMembers)
    .where(and(eq(groupMembers.userId, session.userId), eq(groupMembers.groupId, event.groupId)))
    .limit(1);
  isGroupMember = !!membership;
}

if (!isCreator && !isGroupMember) {
  return Astro.redirect('/dashboard');
}

// Get all activities for this event
const eventActivities = await db
  .select()
  .from(activities)
  .where(eq(activities.eventId, eventId))
  .orderBy(asc(activities.sequenceOrder), asc(activities.startTime));

// Get userId from session
const userId = session.userId;
---

<Layout
  title={`Activities - ${event.title}`}
  description="Manage event activities"
  currentPage="activities"
>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Sub-header with breadcrumb and navigation -->
    <nav
      class="bg-slate-100 dark:bg-slate-700 border-b border-slate-200 dark:border-slate-600 sticky top-16 z-40"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex gap-2 h-12 items-center overflow-x-auto">
          <!-- Breadcrumb -->
          <a
            href={`/events/${event.id}`}
            class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 text-sm font-medium whitespace-nowrap"
          >
            {event.title}
          </a>
          <span class="text-slate-400 dark:text-slate-500">/</span>
          <span class="text-slate-700 dark:text-slate-300 text-sm font-medium whitespace-nowrap">
            Activities
          </span>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <!-- Add Activity Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6"
      >
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Add New Activity</h2>

        <form id="addActivityForm" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="activityTitle"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Activity Title
              </label>
              <input
                type="text"
                id="activityTitle"
                name="title"
                placeholder="e.g., Breakfast, Hotel Check-in"
                required
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label
                for="locationName"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Location (Optional)
              </label>
              <input
                type="text"
                id="locationName"
                name="locationName"
                placeholder="e.g., Downtown Café"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Time Range -->
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Start Time (Optional)
              </label>
              <div class="flex gap-2">
                <input
                  type="date"
                  id="activityStartDate"
                  name="startDate"
                  class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
                <input
                  type="time"
                  id="activityStartTime"
                  name="startTime"
                  class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                End Time (Optional)
              </label>
              <div class="flex gap-2">
                <input
                  type="date"
                  id="activityEndDate"
                  name="endDate"
                  class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
                <input
                  type="time"
                  id="activityEndTime"
                  name="endTime"
                  class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
              </div>
            </div>
          </div>

          <!-- Details/Metadata Section -->
          <div>
            <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
              Details (Flight #, Address, Attendees, etc.)
            </label>

            <!-- Template Selector -->
            <div class="mb-4 flex gap-2 items-end">
              <div class="flex-1">
                <label
                  for="addActivityTemplateSelect"
                  class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1"
                >
                  Quick Templates
                </label>
                <select
                  id="addActivityTemplateSelect"
                  class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
                >
                  <option value="">-- Select a template --</option>
                  <option value="flight">✈️ One-Way Flight</option>
                  <option value="roundtrip_flight">🔄 Round-Trip Flight</option>
                  <option value="hotel">🏨 Hotel</option>
                  <option value="car_rental">🚗 Car Rental</option>
                  <option value="restaurant">🍽️ Restaurant/Dinner</option>
                  <option value="tourist">🎫 Tourist Activity</option>
                </select>
              </div>
              <button
                type="button"
                id="addActivityApplyTemplateBtn"
                class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium text-sm whitespace-nowrap"
              >
                Apply Template
              </button>
            </div>

            <div id="addActivityMetadataContainer" class="space-y-3">
              <!-- Dynamic metadata fields will be added here -->
            </div>
            <button
              type="button"
              id="addActivityAddMetadataFieldBtn"
              class="mt-3 px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium text-sm"
            >
              + Add Detail
            </button>
          </div>

          <!-- Add Expense Toggle -->
          <div
            class="p-4 bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900 dark:to-emerald-900 border-2 border-green-400 dark:border-emerald-600 rounded-lg"
          >
            <label class="flex items-center gap-4 cursor-pointer">
              <!-- Toggle Switch -->
              <div
                class="relative inline-block w-14 h-8 bg-gray-300 dark:bg-gray-600 rounded-full transition-colors"
                id="toggleExpenseSwitch"
              >
                <div
                  class="absolute top-1 left-1 w-6 h-6 bg-white dark:bg-slate-200 rounded-full shadow-md transition-transform translate-x-0"
                  id="toggleExpenseThumb"
                >
                </div>
              </div>

              <input
                type="checkbox"
                id="addExpenseWithActivity"
                name="addExpenseWithActivity"
                class="hidden"
              />

              <div>
                <p
                  class="text-sm font-bold text-green-900 dark:text-green-100"
                  id="toggleExpenseLabel"
                >
                  ○ Add Expense
                </p>
                <p class="text-xs text-green-700 dark:text-green-300">
                  Create an expense for this activity
                </p>
              </div>
            </label>
          </div>

          <!-- Expense Fields (Hidden by default) -->
          <div
            id="expenseFieldsContainer"
            class="hidden space-y-4 p-4 bg-green-50 dark:bg-slate-700 rounded-lg border border-green-200 dark:border-slate-600"
          >
            <div>
              <label
                for="activityExpenseDescription"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Expense Description (Optional)
              </label>
              <input
                type="text"
                id="activityExpenseDescription"
                name="expenseDescription"
                placeholder="Will auto-fill with activity title"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              />
            </div>

            <div>
              <label
                for="activityExpenseCategory"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Category
              </label>
              <select
                id="activityExpenseCategory"
                name="expenseCategory"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              >
                <option value="meal">Meal / Food</option>
                <option value="transport">Transport</option>
                <option value="flight">Flight</option>
                <option value="roundtrip_flight">🔄 Round-Trip Flight</option>
                <option value="accommodation">Accommodation</option>
                <option value="parking">Parking</option>
                <option value="entertainment">Entertainment</option>
                <option value="tickets">Tickets</option>
                <option value="misc" selected>Miscellaneous</option>
              </select>
            </div>

            <div>
              <label
                for="activityExpenseAmount"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Amount ($)
              </label>
              <input
                type="number"
                id="activityExpenseAmount"
                name="expenseAmount"
                step="0.01"
                min="0"
                placeholder="0.00"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              />
            </div>
          </div>

          <div class="flex gap-3">
            <button
              type="submit"
              class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium"
            >
              Add Activity
            </button>
            <button
              type="reset"
              class="px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
            >
              Clear
            </button>
          </div>
        </form>
      </div>

      <!-- Activities List -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden"
      >
        <div class="p-6 sm:p-8">
          <!-- Filter Section -->
          <div class="mb-6 pb-6 border-b border-slate-200 dark:border-slate-700">
            <h3 class="text-sm font-medium text-slate-900 dark:text-white mb-3">
              🔍 Search & Filter
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label
                  for="searchTitle"
                  class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1"
                >
                  Activity Title
                </label>
                <input
                  type="text"
                  id="searchTitle"
                  placeholder="Search by title..."
                  class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
                />
              </div>
              <div>
                <label
                  for="searchMetadata"
                  class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1"
                >
                  Search by Detail (e.g., "DL123", "New York")
                </label>
                <input
                  type="text"
                  id="searchMetadata"
                  placeholder="Search in activity details..."
                  class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
                />
              </div>
            </div>
            <div class="flex gap-2 mt-3">
              <button
                type="button"
                id="clearFiltersBtn"
                class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium text-sm"
              >
                Clear Filters
              </button>
              <span id="filterResults" class="text-sm text-slate-600 dark:text-slate-400 py-2 px-2">
              </span>
            </div>
          </div>

          <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
            Activities ({eventActivities.length})
          </h2>

          {
            eventActivities.length === 0 ? (
              <p class="text-slate-600 dark:text-slate-400 text-center py-8">
                No activities yet. Add one to get started!
              </p>
            ) : (
              <div class="space-y-3">
                {eventActivities.map((activity: typeof activities.$inferSelect) => (
                  <div
                    class="activity-item border border-slate-200 dark:border-slate-700 rounded-lg p-4 flex justify-between items-start"
                    data-activity-id={activity.id}
                    data-metadata={JSON.stringify(activity.metadata || {})}
                    data-title={activity.title}
                    data-location={activity.locationName || ''}
                  >
                    <div class="flex-1">
                      <h3 class="font-medium text-slate-900 dark:text-white">{activity.title}</h3>
                      {activity.locationName && (
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">
                          📍 {activity.locationName}
                        </p>
                      )}
                      {activity.startTime && (
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">
                          🕐{' '}
                          {formatTimeRange(activity.startTime, activity.endTime, { mode: 'utc' })}
                        </p>
                      )}
                      {activity.metadata && Object.keys(activity.metadata).length > 0 && (
                        <div class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                          {Object.entries(activity.metadata).map(([key, value]) => (
                            <div class="inline-block bg-slate-100 dark:bg-slate-700 rounded px-2 py-1 mr-2 mb-1">
                              <span class="font-medium">{key}:</span> {String(value)}
                            </div>
                          ))}
                        </div>
                      )}
                    </div>
                    <div class="flex gap-2 ml-4">
                      <button
                        class="edit-btn px-3 py-2 text-sm bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200 rounded hover:bg-blue-200 dark:hover:bg-blue-800 transition-colors"
                        data-activity-id={activity.id}
                      >
                        Edit
                      </button>
                      <button
                        class="delete-btn px-3 py-2 text-sm bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-200 rounded hover:bg-red-200 dark:hover:bg-red-800 transition-colors"
                        data-activity-id={activity.id}
                      >
                        Delete
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </main>
  </div>

  <script define:vars={{ eventId, userId }}>
    // Toggle Expense Switch Handler
    const toggleExpenseSwitch = document.getElementById('toggleExpenseSwitch');
    const toggleExpenseThumb = document.getElementById('toggleExpenseThumb');
    const toggleExpenseLabel = document.getElementById('toggleExpenseLabel');
    const expenseFieldsContainer = document.getElementById('expenseFieldsContainer');
    const toggleExpenseCheckbox = document.getElementById('addExpenseWithActivity');

    if (toggleExpenseSwitch) {
      toggleExpenseSwitch.addEventListener('click', () => {
        const isChecked = toggleExpenseCheckbox.checked;
        toggleExpenseCheckbox.checked = !isChecked;

        if (toggleExpenseCheckbox.checked) {
          toggleExpenseThumb.classList.add('translate-x-6');
          toggleExpenseThumb.classList.remove('translate-x-1');
          toggleExpenseSwitch.classList.add('bg-green-500');
          toggleExpenseSwitch.classList.remove('bg-slate-300');
          toggleExpenseLabel.textContent = 'Yes, add an expense';
          expenseFieldsContainer.classList.remove('hidden');
        } else {
          toggleExpenseThumb.classList.remove('translate-x-6');
          toggleExpenseThumb.classList.add('translate-x-1');
          toggleExpenseSwitch.classList.remove('bg-green-500');
          toggleExpenseSwitch.classList.add('bg-slate-300');
          toggleExpenseLabel.textContent = 'No';
          expenseFieldsContainer.classList.add('hidden');
        }
      });
    }

    // Add Activity Metadata functions
    function escapeHtml(text) {
      if (!text) return '';
      return String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function addActivityAddMetadataField(key = '', value = '') {
      const container = document.getElementById('addActivityMetadataContainer');
      const fieldId = 'add-activity-metadata-' + Date.now() + Math.random();
      const escapedKey = escapeHtml(key);
      const escapedValue = escapeHtml(value);
      const fieldHTML = `
        <div class="flex gap-2" id="${fieldId}">
          <input
            type="text"
            name="metadataKey"
            placeholder="Key (e.g., Flight Number)"
            value="${escapedKey}"
            class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
          />
          <input
            type="text"
            name="metadataValue"
            placeholder="Value (e.g., DL123)"
            value="${escapedValue}"
            class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
          />
          <button
            type="button"
            onclick="document.getElementById('${fieldId}').remove()"
            class="px-3 py-2 bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-200 rounded-lg hover:bg-red-200 dark:hover:bg-red-800 transition-colors text-sm font-medium"
          >
            ✕
          </button>
        </div>
      `;
      container.insertAdjacentHTML('beforeend', fieldHTML);
    }

    const addActivityTemplates = {
      flight: [
        ['Airline Company', ''],
        ['Flight Number', ''],
        ['Confirmation Number', ''],
        ['Take Off Time', ''],
        ['Arrival Time', ''],
        ['Seat Number', ''],
      ],
      roundtrip_flight: [
        ['Airline Company', ''],
        ['Confirmation Number', ''],
        ['Outbound Flight #', ''],
        ['Outbound Take Off', ''],
        ['Outbound Arrival', ''],
        ['Outbound Seat', ''],
        ['Return Flight #', ''],
        ['Return Take Off', ''],
        ['Return Arrival', ''],
        ['Return Seat', ''],
      ],
      hotel: [
        ['Hotel Name', ''],
        ['Address', ''],
        ['Check-in Date', ''],
        ['Check-out Date', ''],
        ['Confirmation Code', ''],
        ['Room Type', ''],
        ['Parking', ''],
        ['Contact Number', ''],
      ],
      car_rental: [
        ['Rental Company', ''],
        ['Reservation #', ''],
        ['Vehicle Type', ''],
        ['Pick Up Location', ''],
        ['Pick Up Time', ''],
        ['Drop Off Location', ''],
        ['Drop Off Time', ''],
      ],
      restaurant: [
        ['Restaurant Name', ''],
        ['Address', ''],
        ['Reservation Time', ''],
        ['Party Size', ''],
        ['Reservation Name', ''],
        ['Phone Number', ''],
        ['Cuisine Type', ''],
        ['Special Requests', ''],
        ['Dietary Restrictions', ''],
      ],
      tourist: [
        ['Location/Attraction', ''],
        ['Address', ''],
        ['Activity Duration', ''],
        ['Meeting Point', ''],
        ['Suggested Time', ''],
        ['Entrance Fee', ''],
        ['What to Bring', ''],
        ['Contact Number', ''],
      ],
    };

    function applyAddActivityTemplate(templateType) {
      if (!templateType || !addActivityTemplates[templateType]) return;

      const container = document.getElementById('addActivityMetadataContainer');
      container.innerHTML = '';

      addActivityTemplates[templateType].forEach(([key, value]) => {
        addActivityAddMetadataField(key, value);
      });
    }

    const addActivityTemplateSelect = document.getElementById('addActivityTemplateSelect');
    const addActivityApplyTemplateBtn = document.getElementById('addActivityApplyTemplateBtn');
    const addActivityAddMetadataFieldBtn = document.getElementById(
      'addActivityAddMetadataFieldBtn'
    );

    if (addActivityApplyTemplateBtn) {
      addActivityApplyTemplateBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const selectedTemplate = addActivityTemplateSelect.value;
        applyAddActivityTemplate(selectedTemplate);
      });
    }

    if (addActivityAddMetadataFieldBtn) {
      addActivityAddMetadataFieldBtn.addEventListener('click', (e) => {
        e.preventDefault();
        addActivityAddMetadataField();
      });
    }

    // Add activity
    const addActivityForm = document.getElementById('addActivityForm');
    addActivityForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(addActivityForm);
      const startDate = formData.get('startDate');
      const startTime = formData.get('startTime');
      const endDate = formData.get('endDate');
      const endTime = formData.get('endTime');

      const startInput =
        startDate && startTime ? new Date(`${startDate}T${startTime}`).toISOString() : null;
      const endInput = endDate && endTime ? new Date(`${endDate}T${endTime}`).toISOString() : null;

      const data = {
        eventId,
        title: formData.get('title'),
        locationName: formData.get('locationName') || null,
        startTime: startInput,
        endTime: endInput,
        sequenceOrder: 0,
        metadata: (() => {
          const m = {};
          const keys = formData.getAll('metadataKey');
          const values = formData.getAll('metadataValue');
          keys.forEach((k, i) => {
            if (k?.trim()) m[k.trim()] = values[i]?.trim();
          });
          return Object.keys(m).length > 0 ? m : {};
        })(),
      };

      try {
        const response = await fetch('/api/activities/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          showToast('Error: ' + (error.error?.message || error.error || 'Failed to add activity'));
          return;
        }

        const activityData = await response.json();
        const activityId = activityData.activity.id;

        // If Add Expense toggle is enabled, create the expense
        if (toggleExpenseCheckbox && toggleExpenseCheckbox.checked) {
          const expenseAmount = parseFloat(formData.get('expenseAmount') || '0');

          if (expenseAmount <= 0) {
            showToast('Please enter a valid expense amount');
            window.location.reload();
            return;
          }

          // Get group ID from event
          try {
            const eventResponse = await fetch(`/api/events/${eventId}`);
            if (!eventResponse.ok) {
              showToast('Expense amount and category set, but error creating expense');
              window.location.reload();
              return;
            }

            const eventData = await eventResponse.json();
            const groupId = eventData.event.groupId;

            const expenseResponse = await fetch('/api/expenses/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                groupId: groupId,
                eventId: eventId,
                activityId: activityId,
                description: formData.get('expenseDescription') || undefined,
                category: formData.get('expenseCategory') || 'misc',
                amount: Math.round(expenseAmount * 100),
                paidBy: userId,
              }),
            });

            if (!expenseResponse.ok) {
              const error = await expenseResponse.json();
              showToast(
                'Activity created but error creating expense: ' + (error.error || 'Unknown error')
              );
              window.location.reload();
              return;
            }
          } catch (error) {
            console.error('Expense creation error:', error);
            showToast('Activity created but error creating expense');
          }
        } else {
          showToast('Activity created successfully!');
        }

        // Reload page to show new activity after brief delay for toast to be seen
        setTimeout(() => {
          window.location.reload();
        }, 3000);
      } catch (error) {
        showToast('Error: ' + error.message);
      }
    });

    // Delete activity modal logic
    const deleteActivityModal = document.getElementById('deleteActivityModal');
    const cancelDeleteActivityBtn = document.getElementById('cancelDeleteActivityBtn');
    const confirmDeleteActivityBtn = document.getElementById('confirmDeleteActivityBtn');
    let activityIdToDelete = null;

    document.querySelectorAll('.delete-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        activityIdToDelete = btn.dataset.activityId;
        deleteActivityModal.classList.remove('hidden');
      });
    });

    if (cancelDeleteActivityBtn) {
      cancelDeleteActivityBtn.addEventListener('click', () => {
        deleteActivityModal.classList.add('hidden');
        activityIdToDelete = null;
      });
    }

    if (confirmDeleteActivityBtn) {
      confirmDeleteActivityBtn.addEventListener('click', async () => {
        if (!activityIdToDelete) return;

        try {
          const response = await fetch('/api/activities/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              activityId: activityIdToDelete,
              eventId,
            }),
          });

          if (!response.ok) {
            const error = await response.json();
            showToast(
              'Error: ' + (error.error?.message || error.error || 'Failed to delete activity')
            );
            return;
          }

          deleteActivityModal.classList.add('hidden');
          showToast('Activity deleted successfully!');
          setTimeout(() => {
            window.location.reload();
          }, 3000);
        } catch (error) {
          showToast('Error: ' + error.message);
        }
      });
    }

    // Edit activity (show modal or inline edit)
    document.querySelectorAll('.edit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const activityId = btn.dataset.activityId;
        window.location.href = `/activities/${activityId}`;
      });
    });

    // Toast notification helper
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toast-message');

    function showToast(message) {
      if (!toast || !toastMessage) return;
      toastMessage.textContent = message;
      toast.classList.remove('opacity-0');
      setTimeout(() => {
        toast.classList.add('opacity-0');
      }, 3000);
    }

    // Activity Filtering
    const searchTitleInput = document.getElementById('searchTitle');
    const searchMetadataInput = document.getElementById('searchMetadata');
    const clearFiltersBtn = document.getElementById('clearFiltersBtn');
    const filterResults = document.getElementById('filterResults');
    const activityItems = document.querySelectorAll('.activity-item');

    function updateFilterResults() {
      const visibleCount = Array.from(activityItems).filter(
        (item) => !item.classList.contains('hidden')
      ).length;
      if (visibleCount === 0 && (searchTitleInput.value || searchMetadataInput.value)) {
        filterResults.textContent = 'No activities match your search.';
      } else if (searchTitleInput.value || searchMetadataInput.value) {
        filterResults.textContent = `Found ${visibleCount} activity/activities`;
      } else {
        filterResults.textContent = '';
      }
    }

    function applyFilters() {
      const titleSearch = searchTitleInput.value.toLowerCase().trim();
      const metadataSearch = searchMetadataInput.value.toLowerCase().trim();

      activityItems.forEach((item) => {
        const title = item.dataset.title?.toLowerCase() || '';
        const location = item.dataset.location?.toLowerCase() || '';
        const metadataStr = item.dataset.metadata || '{}';

        let metadata = {};
        try {
          metadata = JSON.parse(metadataStr);
        } catch (e) {
          metadata = {};
        }

        // Title search
        const titleMatches = !titleSearch || title.includes(titleSearch);

        // Metadata search - check title, location, and all metadata values
        let metadataMatches = true;
        if (metadataSearch) {
          const searchableText = [
            title,
            location,
            ...Object.values(metadata).map((v) => String(v).toLowerCase()),
          ].join(' ');
          metadataMatches = searchableText.includes(metadataSearch);
        }

        if (titleMatches && metadataMatches) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      });

      updateFilterResults();
    }

    searchTitleInput.addEventListener('input', applyFilters);
    searchMetadataInput.addEventListener('input', applyFilters);

    clearFiltersBtn.addEventListener('click', () => {
      searchTitleInput.value = '';
      searchMetadataInput.value = '';
      activityItems.forEach((item) => item.classList.remove('hidden'));
      filterResults.textContent = '';
    });
  </script>

  <!-- Delete Activity Confirmation Modal -->
  <div
    id="deleteActivityModal"
    class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4"
  >
    <div
      class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-sm border border-slate-200 dark:border-slate-700"
    >
      <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
        <h2 class="text-lg font-bold text-red-600 dark:text-red-400">Delete Activity</h2>
      </div>
      <div class="p-5 sm:p-6">
        <p class="text-slate-700 dark:text-slate-300">
          Are you sure you want to delete this activity? This action cannot be undone.
        </p>
      </div>
      <div
        class="flex gap-3 justify-end p-5 sm:p-6 border-t border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 rounded-b-lg"
      >
        <button
          type="button"
          id="cancelDeleteActivityBtn"
          class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
          >Cancel</button
        >
        <button
          type="button"
          id="confirmDeleteActivityBtn"
          class="px-4 py-2 bg-red-600 text-white hover:bg-red-700 rounded-lg transition-colors font-medium text-sm"
          >Delete</button
        >
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div
    id="toast"
    class="fixed bottom-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none z-50 max-w-xs"
  >
    <span id="toast-message"></span>
  </div>
</Layout>
