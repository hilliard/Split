---
import Layout from '@/layouts/Layout.astro';
import { getSession } from '@/utils/session';
import { isSystemAdmin } from '@/db/authorization';

const session = await getSession(Astro);

// Redirect if not logged in
if (!session || !session.userId) {
  return Astro.redirect('/auth/login');
}

// Check if user is admin
const isAdmin = await isSystemAdmin(session.userId);
if (!isAdmin) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Admin Dashboard">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">Admin Dashboard</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- User Management Section -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-2xl font-bold mb-4">User Management</h2>
        <div id="users-container" class="space-y-4">
          <div class="text-gray-500">Loading users...</div>
        </div>
      </div>

      <!-- Admin Info Section -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-2xl font-bold mb-4">Admin Information</h2>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-gray-600">Your ID</p>
            <p class="font-mono text-sm">{session.userId}</p>
          </div>
          <div>
            <p class="text-sm text-gray-600">Role</p>
            <p class="font-semibold">System Administrator</p>
          </div>
          <div class="pt-4 border-t">
            <p class="text-sm text-gray-600 mb-2">Quick Actions</p>
            <ul class="space-y-2 text-sm">
              <li><a href="/dashboard" class="text-blue-600 hover:underline">Back to Dashboard</a></li>
              <li><a href="/auth/logout" class="text-red-600 hover:underline">Logout</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    async function loadUsers() {
      try {
        const response = await fetch('/api/users/list');
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const users = await response.json();
        const container = document.getElementById('users-container');

        if (!container) return;

        if (users.length === 0) {
          container.innerHTML = '<div class="text-gray-500">No users found</div>';
          return;
        }

        container.innerHTML = `
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 border-b">
                <tr>
                  <th class="text-left px-4 py-2">Name</th>
                  <th class="text-left px-4 py-2">Email</th>
                  <th class="text-left px-4 py-2">Role</th>
                  <th class="text-left px-4 py-2">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y">
                ${users.map((user: any) => `
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-2">
                      ${user.firstName || ''} ${user.lastName || ''}
                    </td>
                    <td class="px-4 py-2">${user.email || user.username || '-'}</td>
                    <td class="px-4 py-2">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                        user.systemRole === 'admin'
                          ? 'bg-red-100 text-red-800'
                          : 'bg-gray-100 text-gray-800'
                      }">
                        ${user.systemRole || 'user'}
                      </span>
                    </td>
                    <td class="px-4 py-2 space-x-2">
                      <button onclick="toggleRoleMenu('${user.id}')" class="text-blue-600 hover:text-blue-800 text-xs">
                        Change Role
                      </button>
                      <button onclick="deleteUser('${user.id}')" class="text-red-600 hover:text-red-800 text-xs">
                        Delete
                      </button>
                      <div id="role-menu-${user.id}" class="hidden mt-2 bg-white border rounded shadow-lg p-2 absolute z-10">
                        <button onclick="updateUserRole('${user.id}', 'admin')" class="block w-full text-left px-2 py-1 hover:bg-gray-100 text-xs">
                          Make Admin
                        </button>
                        <button onclick="updateUserRole('${user.id}', 'user')" class="block w-full text-left px-2 py-1 hover:bg-gray-100 text-xs">
                          Make User
                        </button>
                      </div>
                    </td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        `;
      } catch (error) {
        console.error('Error loading users:', error);
        const container = document.getElementById('users-container');
        if (container) {
          container.innerHTML = '<div class="text-red-500">Error loading users</div>';
        }
      }
    }

    function toggleRoleMenu(userId: string) {
      const menu = document.getElementById(`role-menu-${userId}`);
      if (menu) {
        menu.classList.toggle('hidden');
      }
    }

    async function updateUserRole(userId: string, role: string) {
      try {
        const response = await fetch(`/api/users/${userId}/role`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ systemRole: role }),
        });

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        // Reload users
        loadUsers();
      } catch (error) {
        console.error('Error updating user role:', error);
        alert('Failed to update user role');
      }
    }

    async function deleteUser(userId: string) {
      if (!confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
        return;
      }

      try {
        const response = await fetch(`/api/users/${userId}/role`, {
          method: 'DELETE',
        });

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        // Reload users
        loadUsers();
      } catch (error) {
        console.error('Error deleting user:', error);
        alert('Failed to delete user');
      }
    }

    // Load users on page load
    loadUsers();
  </script>
</Layout>
