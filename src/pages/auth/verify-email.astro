---
import Layout from "@/layouts/Layout.astro";

const token = Astro.url.searchParams.get("token");
const email = Astro.url.searchParams.get("email");

// If no token/email, show error
const hasParams = token && email;
---

<Layout title="Verify Email - Split">
  <div class="min-h-screen bg-gradient-to-b from-blue-50 to-indigo-100 flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-lg shadow-xl p-8 space-y-6">
        {hasParams ? (
          <>
            <!-- Processing state -->
            <div id="verifyingState" class="space-y-6">
              <div class="flex justify-center">
                <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
              </div>
              <div class="text-center space-y-2">
                <h1 class="text-xl font-bold text-gray-900">Verifying your email...</h1>
                <p class="text-gray-600">Please wait while we confirm your email address</p>
              </div>
            </div>

            <!-- Success state (hidden initially) -->
            <div id="successState" class="space-y-6 hidden">
              <div class="flex justify-center">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center">
                  <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
              </div>
              <div class="text-center space-y-2">
                <h1 class="text-2xl font-bold text-gray-900">Email verified!</h1>
                <p class="text-gray-600">Your email has been confirmed successfully</p>
              </div>
              <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                <p class="text-sm text-green-800">
                  You're all set! You'll be redirected to the dashboard shortly.
                </p>
              </div>
              <button
                id="goToDashboardBtn"
                onclick="window.location.href = '/dashboard'"
                class="w-full px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition-colors"
              >
                Go to Dashboard
              </button>
            </div>

            <!-- Error state (hidden initially) -->
            <div id="errorState" class="space-y-6 hidden">
              <div class="flex justify-center">
                <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center">
                  <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </div>
              </div>
              <div class="text-center space-y-2">
                <h1 class="text-2xl font-bold text-gray-900">Verification failed</h1>
                <p id="errorMessage" class="text-gray-600">The verification link is invalid or expired</p>
              </div>
              <div class="bg-red-50 border border-red-200 rounded-lg p-4 space-y-3">
                <p class="text-sm text-red-800 font-medium">What can you do?</p>
                <ul class="text-sm text-red-700 space-y-2">
                  <li>• Try registering again with your email</li>
                  <li>• Make sure you're using the correct link</li>
                  <li>• The link may have expired (they last 24 hours)</li>
                </ul>
              </div>
              <a
                href="/auth/register"
                class="block w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors text-center"
              >
                Back to Registration
              </a>
            </div>
          </>
        ) : (
          <>
            <!-- No params state -->
            <div class="flex justify-center">
              <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center">
                <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div class="text-center space-y-2">
              <h1 class="text-2xl font-bold text-gray-900">Invalid link</h1>
              <p class="text-gray-600">The verification link is missing required parameters</p>
            </div>
            <a
              href="/auth/register"
              class="block w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors text-center"
            >
              Back to Registration
            </a>
          </>
        )}
      </div>
    </div>
  </div>

  {hasParams && (
    <script define:vars={{ token, email }}>
      // Auto-verify when page loads
      async function verifyEmail() {
        try {
          const response = await fetch(`/api/auth/verify-email?token=${token}&email=${encodeURIComponent(email)}`);
          const data = await response.json();

          const verifyingState = document.getElementById('verifyingState');
          const successState = document.getElementById('successState');
          const errorState = document.getElementById('errorState');

          if (response.ok && data.success) {
            // Show success
            verifyingState?.classList.add('hidden');
            successState?.classList.remove('hidden');

            // Auto-redirect after 3 seconds
            setTimeout(() => {
              window.location.href = '/dashboard';
            }, 3000);
          } else {
            // Show error
            verifyingState?.classList.add('hidden');
            errorState?.classList.remove('hidden');
            const errorMessageEl = document.getElementById('errorMessage');
            if (errorMessageEl) {
              errorMessageEl.textContent = data.error || 'Verification failed. Please try again.';
            }
          }
        } catch (error) {
          const verifyingState = document.getElementById('verifyingState');
          const errorState = document.getElementById('errorState');
          verifyingState?.classList.add('hidden');
          errorState?.classList.remove('hidden');
          const errorMessageEl = document.getElementById('errorMessage');
          if (errorMessageEl) {
            errorMessageEl.textContent = 'An error occurred. Please try again.';
          }
        }
      }

      // Run verification
      verifyEmail();
    </script>
  )}
</Layout>
