---
import Layout from "../../layouts/Layout.astro";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}
---

<Layout title="Dashboard" description="Your Split dashboard">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <h1 class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">
            Split
          </h1>
          <div class="flex items-center gap-4">
            <!-- User Info -->
            <div class="text-right hidden sm:block">
              <p
                id="userName"
                class="text-sm font-semibold text-slate-900 dark:text-white"
              >
                Loading...
              </p>
              <p
                id="userEmail"
                class="text-xs text-slate-600 dark:text-slate-400"
              >
              </p>
            </div>

            <!-- Theme toggle -->
            <button
              id="themeToggle"
              class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors text-lg font-bold"
              aria-label="Toggle dark mode"
            >
              <span id="themeIcon">☀️</span>
            </button>

            <!-- Logout button -->
            <button
              id="logoutBtn"
              class="px-4 py-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors font-semibold"
            >
              Logout
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Welcome Card -->
        <div
          class="md:col-span-2 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8"
        >
          <h2
            id="welcomeMessage"
            class="text-3xl font-bold text-slate-900 dark:text-white mb-1"
          >
          </h2>
          <p
            id="welcomeEmail"
            class="text-lg text-slate-600 dark:text-slate-400 mb-4"
          >
          </p>
          <p class="text-slate-600 dark:text-slate-400">
            Click the buttons below to create a new event or group and start
            tracking expenses.
          </p>
        </div>

        <!-- Quick Stats -->
        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8"
        >
          <h3
            class="text-sm font-semibold text-slate-600 dark:text-slate-400 uppercase mb-2"
          >
            Quick Stats
          </h3>
          <div class="space-y-4">
            <div>
              <p
                class="text-3xl font-bold text-indigo-600 dark:text-indigo-400"
              >
                0
              </p>
              <p class="text-sm text-slate-600 dark:text-slate-400">Groups</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-green-600 dark:text-green-400">
                $0
              </p>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Total balanced
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <a
          href="#"
          class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors"
        >
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">
            Create Event
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm">
            Create a new event to organize expenses
          </p>
        </a>

        <a
          href="#"
          class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors"
        >
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">
            Create Group
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm">
            Create a new group to split expenses with friends
          </p>
        </a>
      </div>

      <!-- Empty State -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-12 text-center"
      >
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-2">
          No events or groups yet
        </h3>
        <p class="text-slate-600 dark:text-slate-400">
          Get started by creating your first event or group
        </p>
      </div>
    </main>
  </div>

  <script is:inline>
    console.log("Dashboard script loaded");

    // Load user info
    async function loadUserInfo() {
      try {
        const response = await fetch("/api/auth/me");
        if (response.ok) {
          const user = await response.json();
          const username = user.username || user.email;

          console.log("🔧 loadUserInfo called with username:", username);

          const userName = document.getElementById("userName");
          if (userName) {
            userName.textContent = `Welcome ${username}`;
            console.log("✓ Set header userName to: Welcome " + username);
          }

          const userEmail = document.getElementById("userEmail");
          if (userEmail) {
            userEmail.textContent = user.email;
            console.log("✓ Set header userEmail to:", user.email);
          }

          const welcomeMessage = document.getElementById("welcomeMessage");
          console.log("🔍 welcomeMessage element:", welcomeMessage);
          console.log(
            "🔍 welcomeMessage HTML before:",
            welcomeMessage?.innerHTML,
          );

          if (welcomeMessage) {
            // Use plain text first to test
            welcomeMessage.textContent = `Welcome ${username}!`;
            console.log(
              "✓ Set welcomeMessage textContent to: Welcome " + username + "!",
            );
            console.log(
              "🔍 welcomeMessage text after:",
              welcomeMessage.textContent,
            );
          } else {
            console.error("✗✗✗ welcomeMessage element NOT found!");
          }

          const welcomeEmail = document.getElementById("welcomeEmail");
          if (welcomeEmail) {
            welcomeEmail.textContent = user.email;
            console.log("✓ Set welcomeEmail to:", user.email);
          }
        }
      } catch (error) {
        console.error("Failed to load user info:", error);
      }
    }

    // Update theme emoji based on dark class
    function updateThemeIcon() {
      const html = document.documentElement;
      const themeIcon = document.getElementById("themeIcon");

      if (html.classList.contains("dark")) {
        if (themeIcon) themeIcon.textContent = "🌙";
      } else {
        if (themeIcon) themeIcon.textContent = "☀️";
      }
    }

    // Initialize dashboard with event listeners
    async function initializeDashboard() {
      console.log("Initializing dashboard...");

      // Load user info first (before other initialization)
      await loadUserInfo();
      updateThemeIcon();

      // Theme toggle
      const themeToggle = document.getElementById("themeToggle");
      console.log("Theme toggle button:", themeToggle);

      if (themeToggle) {
        console.log("Button found, adding click listener");
        themeToggle.addEventListener("click", () => {
          console.log("Theme button clicked!");
          const html = document.documentElement;
          const body = document.body;
          const mainWrapper = document.querySelector(".min-h-screen");
          console.log("Current classes:", html.className);

          if (html.classList.contains("dark")) {
            console.log("Removing dark class");
            html.classList.remove("dark");
            if (body) {
              body.style.setProperty(
                "background-color",
                "rgb(255, 255, 255)",
                "important",
              );
              body.style.setProperty("color", "rgb(15, 23, 42)", "important");
            }
            if (mainWrapper) {
              mainWrapper.style.setProperty(
                "background-color",
                "rgb(245, 246, 248)",
                "important",
              );
            }
            localStorage.setItem("theme", "light");
          } else {
            console.log("Adding dark class");
            html.classList.add("dark");
            if (body) {
              body.style.setProperty(
                "background-color",
                "rgb(6, 6, 10)",
                "important",
              );
              body.style.setProperty(
                "color",
                "rgb(248, 250, 252)",
                "important",
              );
            }
            if (mainWrapper) {
              mainWrapper.style.setProperty(
                "background-color",
                "rgb(6, 6, 10)",
                "important",
              );
            }
            localStorage.setItem("theme", "dark");
          }
          console.log("New classes:", html.className);
          updateThemeIcon();
        });
      } else {
        console.error("Theme toggle button not found!");
      }

      // Logout button
      const logoutBtn = document.getElementById("logoutBtn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", async () => {
          try {
            await fetch("/api/auth/logout", { method: "POST" });
            window.location.href = "/";
          } catch (error) {
            console.error("Logout error:", error);
          }
        });
      }
    }

    // Wait for DOM to be ready
    if (document.readyState === "loading") {
      console.log("DOM still loading, waiting for DOMContentLoaded");
      document.addEventListener("DOMContentLoaded", initializeDashboard);
    } else {
      console.log("DOM already ready, initializing now");
      initializeDashboard();
    }
  </script>
</Layout>
