---
import Layout from "../../layouts/Layout.astro";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}
---

<Layout title="Dashboard" description="Your Split dashboard">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16 gap-4">
          <a
            href="/dashboard"
            class="text-lg sm:text-2xl font-bold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors flex-shrink-0"
          >
            ⚡ Split
          </a>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex items-center gap-1 flex-1 mx-6">
            <a
              href="/dashboard"
              class="px-4 py-2 rounded-lg text-sm font-medium transition-colors bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-200"
            >
              Dashboard
            </a>
            <a
              href="/events/create"
              class="px-4 py-2 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700"
            >
              Events
            </a>
            <a
              href="/groups/create"
              class="px-4 py-2 rounded-lg text-sm font-medium transition-colors text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700"
            >
              Groups
            </a>
          </nav>

          <!-- Right Side: User Info + Theme Toggle + Mobile Menu + Logout -->
          <div class="flex items-center gap-2 ml-auto">
            <!-- User Info - Hidden on mobile, shown on sm+ -->
            <div class="text-right hidden sm:block min-w-0">
              <p
                id="userName"
                class="text-xs sm:text-sm font-semibold text-slate-900 dark:text-white truncate"
              >
                Loading...
              </p>
              <p
                id="userEmail"
                class="text-xs text-slate-600 dark:text-slate-400 truncate"
              >
              </p>
            </div>

            <!-- Theme toggle -->
            <button
              type="button"
              id="themeToggle"
              onclick="window.toggleTheme && window.toggleTheme()"
              class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors text-lg flex-shrink-0"
              aria-label="Toggle dark mode"
            >
              <span id="themeIcon">☀️</span>
            </button>

            <!-- Mobile Menu Button -->
            <button
              id="mobileMenuBtn"
              class="md:hidden p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors flex-shrink-0"
              aria-label="Toggle menu"
            >
              <span class="text-2xl">☰</span>
            </button>

            <!-- Logout button -->
            <button
              id="logoutBtn"
              class="px-3 sm:px-4 py-2 text-xs sm:text-sm bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-semibold flex-shrink-0 whitespace-nowrap"
            >
              Logout
            </button>
          </div>
        </div>

        <!-- Mobile Navigation Menu -->
        <nav id="mobileMenu" class="hidden md:hidden pb-4 space-y-2">
          <a
            href="/dashboard"
            class="block px-4 py-2 rounded-lg text-sm font-medium bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-200"
          >
            Dashboard
          </a>
          <a
            href="/events/create"
            class="block px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
          >
            Create Event
          </a>
          <a
            href="/groups/create"
            class="block px-4 py-2 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
          >
            Create Group
          </a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main
      class="flex-1 max-w-7xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-4 sm:py-8"
    >
      <!-- Top Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
        <!-- Welcome Card -->
        <div
          class="md:col-span-2 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-8"
        >
          <h2
            id="welcomeMessage"
            class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-1"
          >
          </h2>
          <p
            id="welcomeEmail"
            class="text-base sm:text-lg text-slate-600 dark:text-slate-400 mb-3 sm:mb-4"
          >
          </p>
          <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
            Click the buttons below to create a new event or group and start
            tracking expenses.
          </p>
        </div>

        <!-- Quick Stats -->
        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-8"
        >
          <h3
            class="text-xs sm:text-sm font-semibold text-slate-600 dark:text-slate-400 uppercase mb-3 sm:mb-4"
          >
            Quick Stats
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-6">
            <button
              id="statsTripsBtn"
              class="text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <p
                id="statsEventCount"
                class="text-2xl sm:text-3xl font-bold text-blue-600 dark:text-blue-400 group-hover:underline"
              >
                0
              </p>
              <p
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Trips
              </p>
            </button>
            <button
              id="statsExpensesBtn"
              class="text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <p
                id="statsExpenseCount"
                class="text-2xl sm:text-3xl font-bold text-green-600 dark:text-green-400 group-hover:underline"
              >
                0
              </p>
              <p
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Expenses
              </p>
            </button>
            <button
              id="statsActivitiesBtn"
              class="text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <p
                id="statsActivityCount"
                class="text-2xl sm:text-3xl font-bold text-amber-600 dark:text-amber-400 group-hover:underline"
              >
                0
              </p>
              <p
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Activities
              </p>
            </button>
            <button
              id="statsGroupsBtn"
              class="text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <p
                id="statsGroupCount"
                class="text-2xl sm:text-3xl font-bold text-indigo-600 dark:text-indigo-400 group-hover:underline"
              >
                0
              </p>
              <p
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Groups
              </p>
            </button>
            <div>
              <p
                id="statsTotalExpenses"
                class="text-2xl sm:text-3xl font-bold text-purple-600 dark:text-purple-400"
              >
                $0
              </p>
              <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">
                Total Spent
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-6 mb-6 sm:mb-8">
        <a
          href="/events/create"
          class="block p-5 sm:p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors active:bg-slate-50 dark:active:bg-slate-700 text-left w-full"
        >
          <h3
            class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white mb-2"
          >
            Create Event
          </h3>
          <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">
            Create a new event to organize expenses
          </p>
        </a>

        <a
          href="/groups/create"
          class="block p-5 sm:p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors active:bg-slate-50 dark:active:bg-slate-700"
        >
          <h3
            class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white mb-2"
          >
            Create Group
          </h3>
          <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">
            Create a new group to split expenses with friends
          </p>
        </a>
      </div>

      <!-- Pending Invitations Section -->
      <div class="mb-6 sm:mb-8">
        <h2
          class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4"
        >
          Pending Invitations
        </h2>
        <div id="invitationsList" class="grid grid-cols-1 gap-4">
          <!-- Pending invitations will be loaded here -->
          <div
            id="invitationsEmpty"
            class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8 sm:p-12 text-center"
          >
            <h3
              class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white mb-2"
            >
              No pending invitations
            </h3>
            <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
              You'll see invitations here when someone invites you to a group
            </p>
          </div>
        </div>
      </div>

      <!-- My Groups Section -->
      <div class="mb-6 sm:mb-8">
        <h2
          class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4"
        >
          Your Groups
        </h2>
        <div id="groupsList" class="grid grid-cols-1 gap-4">
          <!-- Groups will be loaded here -->
          <div
            id="groupsEmpty"
            class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8 sm:p-12 text-center"
          >
            <h3
              class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white mb-2"
            >
              No groups yet
            </h3>
            <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
              Create a group or accept an invitation to get started
            </p>
          </div>
        </div>
      </div>

      <!-- Events Section -->
      <div>
        <h2
          class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4"
        >
          Your Events
        </h2>
        <div id="eventsList" class="grid grid-cols-1 gap-4">
          <!-- Events will be loaded here -->
          <div
            id="eventsEmpty"
            class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8 sm:p-12 text-center"
          >
            <h3
              class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white mb-2"
            >
              No events yet
            </h3>
            <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
              Create your first event to get started
            </p>
          </div>
        </div>
      </div>
    </main>

    <!-- Stats List Modal -->
    <div
      id="statsListModal"
      class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
    >
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-xl max-w-2xl w-full max-h-96 overflow-y-auto"
      >
        <!-- Modal Header -->
        <div
          class="sticky top-0 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-6 py-4 flex justify-between items-center"
        >
          <h2
            id="statsListTitle"
            class="text-xl font-bold text-slate-900 dark:text-white"
          >
            Items
          </h2>
          <button
            id="statsListCloseBtn"
            class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 text-2xl leading-none"
            aria-label="Close"
          >
            ×
          </button>
        </div>

        <!-- Modal Content -->
        <div id="statsListContent" class="p-6 space-y-3">
          <!-- Items will be rendered here -->
        </div>
      </div>
    </div>

    <!-- Create Event Modal -->
    <div
      id="createEventModal"
      class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
    >
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-2xl border border-slate-200 dark:border-slate-700 my-8"
      >
        <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
          <h2
            class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white"
          >
            Create New Event
          </h2>
        </div>

        <form id="createEventForm" class="p-5 sm:p-6 space-y-4">
          <!-- Event Name -->
          <div>
            <label
              for="eventName"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Event Name
            </label>
            <input
              type="text"
              id="eventName"
              name="name"
              required
              placeholder="e.g., Vegas Trip, Houston Trip"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Type & Timezone Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventType"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Event Type
              </label>
              <select
                id="eventType"
                name="type"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="general">General</option>
                <option value="trip">Trip</option>
                <option value="party">Party</option>
                <option value="dinner">Dinner</option>
                <option value="vacation">Vacation</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label
                for="eventTimezone"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Timezone
              </label>
              <select
                id="eventTimezone"
                name="timezone"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="UTC">UTC</option>
                <option value="America/New_York">America/New_York</option>
                <option value="America/Chicago">America/Chicago</option>
                <option value="America/Denver">America/Denver</option>
                <option value="America/Los_Angeles">America/Los_Angeles</option>
                <option value="Europe/London">Europe/London</option>
                <option value="Europe/Paris">Europe/Paris</option>
                <option value="Europe/Berlin">Europe/Berlin</option>
                <option value="Asia/Tokyo">Asia/Tokyo</option>
                <option value="Asia/Shanghai">Asia/Shanghai</option>
                <option value="Asia/Hong_Kong">Asia/Hong_Kong</option>
                <option value="Asia/Singapore">Asia/Singapore</option>
                <option value="Australia/Sydney">Australia/Sydney</option>
              </select>
            </div>
          </div>

          <!-- Location & Currency Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventLocation"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Location (Optional)
              </label>
              <input
                type="text"
                id="eventLocation"
                name="location"
                placeholder="e.g., Houston, TX"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label
                for="eventCurrency"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Currency
              </label>
              <select
                id="eventCurrency"
                name="currency"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="USD">USD - US Dollar</option>
                <option value="EUR">EUR - Euro</option>
                <option value="GBP">GBP - British Pound</option>
                <option value="CAD">CAD - Canadian Dollar</option>
                <option value="AUD">AUD - Australian Dollar</option>
                <option value="JPY">JPY - Japanese Yen</option>
                <option value="MXN">MXN - Mexican Peso</option>
                <option value="INR">INR - Indian Rupee</option>
              </select>
            </div>
          </div>

          <!-- Start & End Date Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventStartDate"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Start Date (Optional)
              </label>
              <input
                type="datetime-local"
                id="eventStartDateTime"
                name="startDate"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label
                for="eventEndDateTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                End Date (Optional)
              </label>
              <input
                type="datetime-local"
                id="eventEndDateTime"
                name="endDate"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Budget -->
          <div>
            <label
              for="eventBudget"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Budget (Optional)
            </label>
            <div class="relative">
              <span
                class="absolute left-4 top-3 text-slate-600 dark:text-slate-400 font-medium"
                id="budgetSymbol"
              >
                $
              </span>
              <input
                type="number"
                id="eventBudget"
                name="budget"
                step="0.01"
                min="0"
                placeholder="0.00"
                class="w-full pl-8 pr-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Description -->
          <div>
            <label
              for="eventDescription"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Description (Optional)
            </label>
            <textarea
              id="eventDescription"
              name="description"
              placeholder="Add details about this event..."
              rows="2"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base resize-none"
            ></textarea>
          </div>

          <!-- Error Message -->
          <div
            id="eventError"
            class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
          >
          </div>

          <!-- Action Buttons -->
          <div
            class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700"
          >
            <button
              type="button"
              id="cancelEventBtn"
              class="px-4 py-2 text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="px-4 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium text-sm min-h-touch flex items-center justify-center"
            >
              Create Event
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Toast Notification -->
    <div
      id="toast"
      class="fixed bottom-4 right-4 bg-green-500 text-white px-4 py-3 rounded-lg shadow-lg hidden z-[100] max-w-xs"
    >
      <div class="flex items-center gap-2">
        <span class="text-lg">✓</span>
        <span id="toastMessage">Event created successfully!</span>
      </div>
    </div>
  </div>

  <script is:inline>
    console.log("Dashboard script loaded");

    // Show toast notification
    function showToast(
      message = "Event created successfully!",
      duration = 3000,
    ) {
      const toast = document.getElementById("toast");
      const toastMessage = document.getElementById("toastMessage");
      if (toast && toastMessage) {
        toastMessage.textContent = message;
        toast.classList.remove("hidden");
        setTimeout(() => {
          toast.classList.add("hidden");
        }, duration);
      }
    }

    // Load and display events
    async function loadEvents() {
      try {
        const response = await fetch("/api/events/list");
        if (response.ok) {
          const data = await response.json();
          console.log("📋 Events from API:", data.events);
          const eventsList = document.getElementById("eventsList");
          const eventsEmpty = document.getElementById("eventsEmpty");

          if (data.events.length === 0) {
            if (eventsList) eventsList.innerHTML = eventsEmpty?.outerHTML || "";
          } else {
            if (eventsList) {
              eventsList.innerHTML = data.events
                .map((event) => {
                  try {
                    const startDate = event.startTime || event.startDate;
                    const endDate = event.endTime || event.endDate;
                    const startStr = startDate
                      ? new Date(startDate).toLocaleDateString()
                      : "";
                    const endStr = endDate
                      ? new Date(endDate).toLocaleDateString()
                      : "";

                    return `
                <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-6">
