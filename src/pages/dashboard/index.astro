    // Load stats for a specific group
    async function loadGroupStats(groupId) {
      try {
        const groupCard = document.querySelector(
          `[data-group-id="${groupId}"]`,
        );
        if (!groupCard) return;

        // Get group details (members)
        const response = await fetch(`/api/groups/list?id=${groupId}`);
        if (response.ok) {
          const data = await response.json();
          const memberCount = data.members ? data.members.length : 0;

          // Update member count
          const memberCountEl = groupCard.querySelector(".group-member-count");
          if (memberCountEl) memberCountEl.textContent = memberCount;

          // For now, set expenses and total to 0 since expenses are tied to events
          const expenseCountEl = groupCard.querySelector(
            ".group-expense-count",
          );
          const totalSpentEl = groupCard.querySelector(".group-total-spent");

          if (expenseCountEl) expenseCountEl.textContent = "0";
          if (totalSpentEl) totalSpentEl.textContent = "$0.00";
        }
      } catch (error) {
        console.error(`Failed to load stats for group ${groupId}:`, error);
        // Fallback - set to 0
        const groupCard = document.querySelector(
          `[data-group-id="${groupId}"]`,
        );
        if (groupCard) {
          const expenseCountEl = groupCard.querySelector(
            ".group-expense-count",
          );
          const totalSpentEl = groupCard.querySelector(".group-total-spent");
          if (expenseCountEl) expenseCountEl.textContent = "0";
          if (totalSpentEl) totalSpentEl.textContent = "$0.00";
        }
      }
    }

    // Update Quick Stats panel
    async function updateStats() {
      try {
        // Get groups
        const groupsResponse = await fetch("/api/groups/list");
        let groupCount = 0;
        let groupsMap = {}; // Map groupId to group name
        statsData.groups = [];
        if (groupsResponse.ok) {
          const groupsData = await groupsResponse.json();
          const groups = groupsData.groups || [];
          groupCount = groups.length;
          statsData.groups = groups;

          // Build a map of groupId -> groupName
          groups.forEach((group) => {
            groupsMap[group.id] = group.name;
          });

          const statsGroupCount = document.getElementById("statsGroupCount");
          if (statsGroupCount) {
            statsGroupCount.textContent = groupCount;
          }
        }

        // Get events
        const eventsResponse = await fetch("/api/events/list");
        let eventCount = 0;
        let totalExpenseCount = 0;
        let totalActivityCount = 0;
        let totalExpensesAmount = 0;
        statsData.trips = [];
        statsData.expenses = [];
        statsData.activities = [];

        if (eventsResponse.ok) {
          const eventsData = await eventsResponse.json();
          const events = eventsData.events || [];
          eventCount = events.length;

          // Enrich events with group names
          statsData.trips = events.map((event) => ({
            ...event,
            groupName: event.groupId ? groupsMap[event.groupId] : null,
          }));

          const statsEventCount = document.getElementById("statsEventCount");
          if (statsEventCount) {
            statsEventCount.textContent = eventCount;
          }

          // Fetch expenses and activities for all events
          for (const event of events) {
            try {
              const expensesResp = await fetch(
                `/api/expenses/list?eventId=${event.id}`,
              );
              if (expensesResp.ok) {
                const expensesData = await expensesResp.json();
                const expenses = expensesData.expenses || [];
                totalExpenseCount += expenses.length;

                // Add expenses to statsData and sum totals
                expenses.forEach((expense) => {
                  statsData.expenses.push({
                    ...expense,
                    tripName: event.name,
                    currency: event.currency || "USD",
                  });
                  totalExpensesAmount += parseFloat(expense.total) || 0;
                });
              } else {
                const errorData = await expensesResp.json().catch(() => ({}));
                console.warn(
                  `Failed to fetch expenses for event ${event.id}: ${expensesResp.status} ${errorData.error || expensesResp.statusText}`,
                );
              }
            } catch (e) {
              console.error(
                `Failed to fetch expenses for event ${event.id}:`,
                e,
              );
            }

            // Fetch activities for each event
            try {
              const activitiesResp = await fetch(
                `/api/activities/list?eventId=${event.id}`,
              );
              if (activitiesResp.ok) {
                const activitiesData = await activitiesResp.json();
                const activities = activitiesData.activities || [];
                totalActivityCount += activities.length;

                // Add activities to statsData
                activities.forEach((activity) => {
                  statsData.activities.push({
                    ...activity,
                    tripName: event.name,
                  });
                });
              } else {
                const errorData = await activitiesResp.json().catch(() => ({}));
                console.warn(
                  `Failed to fetch activities for event ${event.id}: ${activitiesResp.status} ${errorData.error || activitiesResp.statusText}`,
                );
              }
            } catch (e) {
              console.error(
                `Failed to fetch activities for event ${event.id}:`,
                e,
              );
            }
          }

          const statsActivityCount =
            document.getElementById("statsActivityCount");
          if (statsActivityCount) {
            statsActivityCount.textContent = totalActivityCount;
          }
        }

        // Update expense count
        const statsExpenseCount = document.getElementById("statsExpenseCount");
        if (statsExpenseCount) {
          statsExpenseCount.textContent = totalExpenseCount;
        }

        // Update total expenses amount
        const statsTotalExpenses =
          document.getElementById("statsTotalExpenses");
        if (statsTotalExpenses) {
          statsTotalExpenses.textContent = `$${totalExpensesAmount.toFixed(2)}`;
        }
      } catch (error) {
        console.error("Failed to update stats:", error);
      }
    }

