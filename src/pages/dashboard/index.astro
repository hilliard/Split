</Layout>

<script is:inline>
  console.log('Dashboard script loaded');

  // Show toast notification
  function showToast(message = 'Event created successfully!', duration = 3000) {
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toastMessage');
    if (toast && toastMessage) {
      toastMessage.textContent = message;
      toast.classList.remove('hidden');
      setTimeout(() => {
        toast.classList.add('hidden');
      }, duration);
    }
  }

  // Custom Confirmation Modal
  function customConfirm(message) {
    return new Promise((resolve) => {
      const modal = document.getElementById('settleConfirmModal');
      const msgEl = document.getElementById('settleConfirmMessage');
      const confirmBtn = document.getElementById('settleConfirmBtn');
      const cancelBtn = document.getElementById('settleCancelBtn');

      msgEl.textContent = message;
      modal.classList.remove('hidden');

      const cleanup = () => {
        modal.classList.add('hidden');
        confirmBtn.removeEventListener('click', onConfirm);
        cancelBtn.removeEventListener('click', onCancel);
      };

      const onConfirm = () => {
        cleanup();
        resolve(true);
      };
      const onCancel = () => {
        cleanup();
        resolve(false);
      };

      confirmBtn.addEventListener('click', onConfirm);
      cancelBtn.addEventListener('click', onCancel);
    });
  }

  // Load and display events
  async function loadEvents() {
    try {
      const response = await fetch('/api/events/list');
      if (response.ok) {
        const data = await response.json();
        console.log('📋 Events from API:', data.events);
        const eventsList = document.getElementById('eventsList');
        const eventsEmpty = document.getElementById('eventsEmpty');

        if (data.events.length === 0) {
          if (eventsList) eventsList.innerHTML = eventsEmpty?.outerHTML || '';
        } else {
          if (eventsList) {
            eventsList.innerHTML = data.events
              .map((event) => {
                try {
                  const startDate = event.startTime || event.startDate;
                  const endDate = event.endTime || event.endDate;
                  const startStr = startDate ? new Date(startDate).toLocaleDateString() : '';
                  const endStr = endDate ? new Date(endDate).toLocaleDateString() : '';

                  return `
                <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-6">
                  <div class="flex justify-between items-start mb-3">
                    <div>
                      <h3 class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white">${escapeHtml(event.title || event.name)}</h3>
                      ${event.location ? `<p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">📍 ${escapeHtml(event.location)}</p>` : ''}
                    </div>
                    <span class="text-xs sm:text-sm font-semibold text-indigo-600 dark:text-indigo-400">${event.currency}</span>
                  </div>
                  
                  ${event.description ? `<p class="text-sm text-slate-600 dark:text-slate-400 mb-3">${escapeHtml(event.description)}</p>` : ''}
                  
                  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-3 text-xs sm:text-sm">
                    ${
                      startStr
                        ? `<div>
                      <span class="text-slate-600 dark:text-slate-400">Start</span>
                      <p class="font-medium text-slate-900 dark:text-white">${startStr}</p>
                    </div>`
                        : ''
                    }
                    ${
                      endStr
                        ? `<div>
                      <span class="text-slate-600 dark:text-slate-400">End</span>
                      <p class="font-medium text-slate-900 dark:text-white">${endStr}</p>
                    </div>`
                        : ''
                    }
                    <div>
                      <span class="text-slate-600 dark:text-slate-400">Current Expenses</span>
                      <p class="font-medium text-slate-900 dark:text-white">${event.currency} ${parseFloat(event.currentExpenses || 0).toFixed(2)}</p>
                    </div>
                    ${
                      event.budget && parseFloat(event.budget) !== 0
                        ? `<div>
                      <span class="text-slate-600 dark:text-slate-400">Budget</span>
                      <p class="font-medium text-slate-900 dark:text-white">${event.currency} ${parseFloat(event.budget).toFixed(2)}</p>
                    </div>`
                        : ''
                    }
                  </div>
                  
                  <div class="pt-3 border-t border-slate-200 dark:border-slate-700 flex gap-2">
                    <button class="text-xs px-3 py-1.5 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded transition-colors flex-1 view-event-btn" data-event-id="${event.id}">View</button>
                    <button class="text-xs px-3 py-1.5 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 rounded transition-colors flex-1 edit-event-btn" data-event-id="${event.id}">Edit</button>
                  </div>
                </div>
              `;
                } catch (e) {
                  console.error('❌ Error rendering event:', event, e);
                  return '';
                }
              })
              .join('');

            // Add event listeners to View and Edit buttons
            document.querySelectorAll('.view-event-btn').forEach((btn) => {
              btn.addEventListener('click', (e) => {
                const eventId = e.target.dataset.eventId;
                window.location.href = `/events/${eventId}`;
              });
            });
            document.querySelectorAll('.edit-event-btn').forEach((btn) => {
              btn.addEventListener('click', (e) => {
                const eventId = e.target.dataset.eventId;
                window.location.href = `/events/${eventId}/edit`;
              });
            });
          }
        }
      }
    } catch (error) {
      console.error('Failed to load events:', error);
    }
  }

  // Escape HTML to prevent XSS
  function escapeHtml(text) {
    if (!text) return '';
    const map = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    };
    return text.replace(/[&<>"']/g, (m) => map[m]);
  }

  // Load user info
  async function loadUserInfo() {
    try {
      const response = await fetch('/api/auth/me');
      if (response.ok) {
        const user = await response.json();
        currentUserId = user.id; // Store user ID for owes calculation
        const username = user.username || user.email;

        console.log('🔧 loadUserInfo called with username:', username);

        const userName = document.getElementById('userName');
        if (userName) {
          userName.textContent = `Welcome ${username}`;
          console.log('✓ Set header userName to: Welcome ' + username);
        }

        const userEmail = document.getElementById('userEmail');
        if (userEmail) {
          userEmail.textContent = user.email;
          console.log('✓ Set header userEmail to:', user.email);
        }

        const welcomeMessage = document.getElementById('welcomeMessage');
        console.log('🔍 welcomeMessage element:', welcomeMessage);
        console.log('🔍 welcomeMessage HTML before:', welcomeMessage?.innerHTML);

        if (welcomeMessage) {
          // Use plain text first to test
          welcomeMessage.textContent = `Welcome ${username}!`;
          console.log('✓ Set welcomeMessage textContent to: Welcome ' + username + '!');
          console.log('🔍 welcomeMessage text after:', welcomeMessage.textContent);
        } else {
          console.error('✗✗✗ welcomeMessage element NOT found!');
        }

        const welcomeEmail = document.getElementById('welcomeEmail');
        if (welcomeEmail) {
          welcomeEmail.textContent = user.email;
          console.log('✓ Set welcomeEmail to:', user.email);
        }
      }
    } catch (error) {
      console.error('Failed to load user info:', error);
    }
  }

  // Load and display user groups
  async function loadGroups() {
    try {
      const response = await fetch('/api/groups/list');
      if (response.ok) {
        const data = await response.json();
        const groupsList = document.getElementById('groupsList');
        const groupsEmpty = document.getElementById('groupsEmpty');

        if (!data.groups || data.groups.length === 0) {
          if (groupsList) groupsList.innerHTML = groupsEmpty?.outerHTML || '';
        } else {
          if (groupsList) {
            groupsList.innerHTML = data.groups
              .map(
                (group) => `
                <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-6" data-group-id="${group.id}">
                  <div class="flex justify-between items-start mb-3">
                    <div>
                      <h3 class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white">${escapeHtml(group.name)}</h3>
                      <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">Created ${new Date(group.createdAt).toLocaleDateString()}</p>
                    </div>
                  </div>
                  
                  <!-- Group Stats -->
                  <div class="grid grid-cols-3 gap-2 mb-4 py-3 px-2 bg-slate-50 dark:bg-slate-700 rounded">
                    <div class="text-center">
                      <p class="text-sm font-bold text-slate-900 dark:text-white group-member-count">${group.memberCount || 0}</p>
                      <p class="text-xs text-slate-600 dark:text-slate-400">Members</p>
                    </div>
                    <div class="text-center">
                      <p class="text-sm font-bold text-slate-900 dark:text-white group-expense-count">—</p>
                      <p class="text-xs text-slate-600 dark:text-slate-400">Expenses</p>
                    </div>
                    <div class="text-center">
                      <p class="text-sm font-bold text-slate-900 dark:text-white group-total-spent">—</p>
                      <p class="text-xs text-slate-600 dark:text-slate-400">Total</p>
                    </div>
                  </div>
                  
                  <div class="pt-3 border-t border-slate-200 dark:border-slate-700 flex gap-2">
                    <button class="text-xs px-3 py-1.5 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-slate-700 rounded transition-colors flex-1 view-group-btn" data-group-id="${group.id}">View</button>
                    <button class="text-xs px-3 py-1.5 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700 rounded transition-colors flex-1 edit-group-btn" data-group-id="${group.id}">Edit</button>
                  </div>
                </div>
              `
              )
              .join('');

            // Load stats for each group
            for (const group of data.groups) {
              await loadGroupStats(group.id);
            }

            // Add event listeners to View and Edit buttons
            document.querySelectorAll('.view-group-btn').forEach((btn) => {
              btn.addEventListener('click', (e) => {
                const groupId = e.target.dataset.groupId;
                window.location.href = `/groups/${groupId}/manage`;
              });
            });
            document.querySelectorAll('.edit-group-btn').forEach((btn) => {
              btn.addEventListener('click', (e) => {
                const groupId = e.target.dataset.groupId;
                window.location.href = `/groups/${groupId}/edit`;
              });
            });
          }
        }
      }
    } catch (error) {
      console.error('Failed to load groups:', error);
    }
  }

  // Load stats for a specific group
  async function loadGroupStats(groupId) {
    try {
      const groupCard = document.querySelector(`[data-group-id="${groupId}"]`);
      if (!groupCard) return;

      // Get group details (members)
      const response = await fetch(`/api/groups/list?id=${groupId}`);
      if (response.ok) {
        const data = await response.json();
        const memberCount = data.members ? data.members.length : 0;

        // Update member count
        const memberCountEl = groupCard.querySelector('.group-member-count');
        if (memberCountEl) memberCountEl.textContent = memberCount;

        // For now, set expenses and total to 0 since expenses are tied to events
        const expenseCountEl = groupCard.querySelector('.group-expense-count');
        const totalSpentEl = groupCard.querySelector('.group-total-spent');

        if (expenseCountEl) expenseCountEl.textContent = '0';
        if (totalSpentEl) totalSpentEl.textContent = '$0.00';
      }
    } catch (error) {
      console.error(`Failed to load stats for group ${groupId}:`, error);
      // Fallback - set to 0
      const groupCard = document.querySelector(`[data-group-id="${groupId}"]`);
      if (groupCard) {
        const expenseCountEl = groupCard.querySelector('.group-expense-count');
        const totalSpentEl = groupCard.querySelector('.group-total-spent');
        if (expenseCountEl) expenseCountEl.textContent = '0';
        if (totalSpentEl) totalSpentEl.textContent = '$0.00';
      }
    }
  }

  // Update Quick Stats panel
  async function updateStats() {
    try {
      // Get groups
      const groupsResponse = await fetch('/api/groups/list');
      let groupCount = 0;
      let groupsMap = {}; // Map groupId to group name
      statsData.groups = [];
      if (groupsResponse.ok) {
        const groupsData = await groupsResponse.json();
        const groups = groupsData.groups || [];
        groupCount = groups.length;
        statsData.groups = groups;

        // Build a map of groupId -> groupName
        groups.forEach((group) => {
          groupsMap[group.id] = group.name;
        });

        const statsGroupCount = document.getElementById('statsGroupCount');
        if (statsGroupCount) {
          statsGroupCount.textContent = groupCount;
        }
      }

      // Get events
      const eventsResponse = await fetch('/api/events/list');
      let eventCount = 0;
      let totalExpenseCount = 0;
      let totalActivityCount = 0;
      let standaloneActivityCount = 0;
      let totalExpensesAmount = 0;
      statsData.trips = [];
      statsData.expenses = [];
      statsData.activities = [];

      if (eventsResponse.ok) {
        const eventsData = await eventsResponse.json();
        const events = eventsData.events || [];
        eventCount = events.length;

        // Enrich events with group names
        statsData.trips = events.map((event) => ({
          ...event,
          displayTitle: event.title || event.name || 'Untitled Trip',
          groupName: event.groupId ? groupsMap[event.groupId] : null,
        }));

        const statsEventCount = document.getElementById('statsEventCount');
        if (statsEventCount) {
          statsEventCount.textContent = eventCount;
        }

        // Fetch expenses and activities for all events
        for (const event of events) {
          try {
            const expensesResp = await fetch(`/api/expenses/list?eventId=${event.id}`);
            if (expensesResp.ok) {
              const expensesData = await expensesResp.json();
              const expenses = expensesData.expenses || [];
              totalExpenseCount += expenses.length;

              // Add expenses to statsData and sum totals
              expenses.forEach((expense) => {
                const mySplit = expense.splits?.find((s) => s.userId === currentUserId);
                const myShareAmount = mySplit
                  ? parseFloat(mySplit.amountDollars) || 0
                  : parseFloat(expense.total) || 0;

                statsData.expenses.push({
                  ...expense,
                  tripName: event.title || event.name || 'Untitled Trip',
                  currency: event.currency || 'USD',
                  myShareAmount,
                  hasMySplit: Boolean(mySplit),
                });
                totalExpensesAmount += parseFloat(expense.total) || 0;

                // Track owes: if current user didn't pay for this expense, they owe money
                if (expense.paidBy !== currentUserId && expense.splits) {
                  if (mySplit) {
                    statsData.owes.push({
                      id: expense.id,
                      description: expense.description,
                      amount: parseFloat(mySplit.amountDollars) || 0,
                      amountCents: mySplit.amountCents,
                      currency: event.currency || 'USD',
                      paidBy: expense.payerName,
                      paidById: expense.paidBy,
                      tripName: event.title || event.name || 'Untitled Trip',
                      groupId: event.groupId,
                    });
                  }
                }
              });
            } else {
              const errorData = await expensesResp.json().catch(() => ({}));
              console.warn(
                `Failed to fetch expenses for event ${event.id}: ${expensesResp.status} ${errorData.error || expensesResp.statusText}`
              );
            }
          } catch (e) {
            console.error(`Failed to fetch expenses for event ${event.id}:`, e);
          }

          // Fetch activities for each event
          try {
            const activitiesResp = await fetch(`/api/activities/list?eventId=${event.id}`, {
              credentials: 'same-origin',
            });
            if (activitiesResp.ok) {
              const activitiesData = await activitiesResp.json();
              const activities = activitiesData.activities || [];
              totalActivityCount += activities.length;

              // Add activities to statsData
              activities.forEach((activity) => {
                statsData.activities.push({
                  ...activity,
                  tripName: event.title || event.name || 'Untitled Trip',
                });
              });
            } else {
              const errorData = await activitiesResp.json().catch(() => ({}));
              console.warn(
                `Failed to fetch activities for event ${event.id}: ${activitiesResp.status} ${errorData.error || activitiesResp.statusText}`
              );
            }
          } catch (e) {
            console.error(`Failed to fetch activities for event ${event.id}:`, e);
          }
        }

        // Fetch standalone activities and add to totalActivityCount
        try {
          const standaloneResp = await fetch('/api/activities/list?standalone=1', {
            credentials: 'same-origin',
          });
          if (standaloneResp.ok) {
            const standaloneData = await standaloneResp.json();
            const standaloneActivities = standaloneData.activities || [];
            standaloneActivityCount = standaloneActivities.length;
            totalActivityCount += standaloneActivityCount;
            // Add standalone activities to statsData.activities with tripName 'Standalone'
            standaloneActivities.forEach((activity) => {
              statsData.activities.push({
                ...activity,
                tripName: 'Standalone',
              });
            });
          } else {
            const errorData = await standaloneResp.json().catch(() => ({}));
            console.warn(
              `Failed to fetch standalone activities: ${standaloneResp.status} ${errorData.error || standaloneResp.statusText}`
            );
          }
        } catch (e) {
          console.error('Failed to fetch standalone activities:', e);
        }

        const statsActivityCount = document.getElementById('statsActivityCount');
        if (statsActivityCount) {
          statsActivityCount.textContent = totalActivityCount;
        }
      }

      // Update expense count
      const statsExpenseCount = document.getElementById('statsExpenseCount');
      if (statsExpenseCount) {
        statsExpenseCount.textContent = totalExpenseCount;
      }

      // (Total Spent is now handled by the user-total fetch at the top of the file)

      // Calculate and update total owes amount
      const totalOwes = statsData.owes.reduce((sum, owe) => sum + owe.amount, 0);
      const statsOwesAmount = document.getElementById('statsOwesAmount');
      if (statsOwesAmount) {
        statsOwesAmount.textContent = `$${totalOwes.toFixed(2)}`;
      }
    } catch (error) {
      console.error('Failed to update stats:', error);
    }
  }

  // Store data for stats list modal
  let statsData = {
    trips: [],
    expenses: [],
    activities: [],
    groups: [],
    owes: [],
  };
  let currentUserId = null; // Will be set by loadUserInfo

  // Show stats list modal
  function showStatsList(type, title) {
    const modal = document.getElementById('statsListModal');
    const titleElement = document.getElementById('statsListTitle');
    const content = document.getElementById('statsListContent');

    titleElement.textContent = title;

    let items = [];
    let html = '';

    if (type === 'trips') {
      items = statsData.trips;
      html = items
        .map(
          (trip) => `
          <a href="/events/${trip.id}" class="block p-4 bg-slate-50 dark:bg-slate-700 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-600 transition-colors">
            <h3 class="font-semibold text-slate-900 dark:text-white">${escapeHtml(trip.displayTitle || trip.title || trip.name || 'Untitled Trip')}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">${trip.groupName ? `Group: ${escapeHtml(trip.groupName)}` : 'Personal'}</p>
          </a>
        `
        )
        .join('');
    } else if (type === 'expenses') {
      items = statsData.expenses;
      html = items
        .map(
          (exp) => `
          <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
            <div class="flex justify-between items-start gap-3">
              <div class="flex-1">
                <h3 class="font-semibold text-slate-900 dark:text-white">${escapeHtml(exp.description)}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">${escapeHtml(exp.tripName)}</p>
                <p class="text-xs text-slate-500 dark:text-slate-500 mt-1">Paid by: ${escapeHtml(exp.payerName || 'Unknown')}</p>
                <p class="text-xs text-slate-500 dark:text-slate-500 mt-1">${exp.hasMySplit ? 'Your share' : 'Total'}</p>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="font-semibold text-green-600 dark:text-green-400">${exp.currency || 'USD'} ${parseFloat(exp.myShareAmount || 0).toFixed(2)}</p>
              </div>
            </div>
          </div>
        `
        )
        .join('');
    } else if (type === 'activities') {
      items = statsData.activities;
      html = items
        .map((act) => {
          // Show 'Standalone' if eventId is null or tripName is missing
          const tripLabel =
            act.tripName || (act.eventId === null || act.eventId === undefined ? 'Standalone' : '');
          return `
                <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
                  <h3 class="font-semibold text-slate-900 dark:text-white">${escapeHtml(act.title || act.name || 'Untitled Activity')}</h3>
                  <p class="text-sm text-slate-600 dark:text-slate-400">${escapeHtml(tripLabel)}</p>
                </div>
              `;
        })
        .join('');
    } else if (type === 'groups') {
      items = statsData.groups;
      html = items
        .map(
          (grp) => `
          <a href="/groups/${grp.id}/manage" class="block p-4 bg-slate-50 dark:bg-slate-700 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-600 transition-colors">
            <h3 class="font-semibold text-slate-900 dark:text-white">${escapeHtml(grp.name)}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">${grp.memberCount || 0} members</p>
          </a>
        `
        )
        .join('');
    } else if (type === 'owes') {
      items = statsData.owes;
      html = items
        .map((owe) => {
          const activeDebt = window.globalBalances?.find(
            (b) =>
              b.fromUserId === currentUserId &&
              b.toUserId === owe.paidById &&
              b.groupId === owe.groupId &&
              b.amountCents > 0
          );
          const showSettleBtn = owe.groupId && owe.paidById && !!activeDebt;

          return `
          <div class="p-4 bg-red-50 dark:bg-red-900/20 rounded-lg border border-red-200 dark:border-red-800">
            <div class="flex justify-between items-start gap-3">
              <div class="flex-1">
                <h3 class="font-semibold text-slate-900 dark:text-white">${escapeHtml(owe.description)}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">${escapeHtml(owe.tripName)}</p>
                <p class="text-xs text-slate-500 dark:text-slate-500 mt-1">Owed to: ${escapeHtml(owe.paidBy || 'Unknown')}</p>
              </div>
              <div class="text-right flex-shrink-0 flex flex-col items-end gap-2">
                <p class="font-semibold text-red-600 dark:text-red-400">${owe.currency} ${owe.amount.toFixed(2)}</p>
                ${
                  showSettleBtn
                    ? `
                  <button class="text-xs px-3 py-1 bg-red-600 hover:bg-red-700 text-white rounded transition-colors quick-settle-btn"
                    data-to-user-id="${owe.paidById}"
                    data-to-user-name="${escapeHtml(owe.paidBy)}"
                    data-amount-cents="${owe.amountCents}"
                    data-group-id="${owe.groupId}"
                    data-desc="${escapeHtml(owe.description)}">
                    Settle
                  </button>
                `
                    : ''
                }
              </div>
            </div>
          </div>
        `;
        })
        .join('');
    }

    if (items.length === 0) {
      html = `<p class="text-center text-slate-600 dark:text-slate-400 py-8">No ${title.toLowerCase()} yet</p>`;
    }

    content.innerHTML = html;

    // Add event listeners for quick settle
    if (type === 'owes') {
      content.querySelectorAll('.quick-settle-btn').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          const target = e.currentTarget;
          const toUserId = target.dataset.toUserId;
          const toUserName = target.dataset.toUserName;
          const amountCents = parseInt(target.dataset.amountCents);
          const groupId = target.dataset.groupId;
          const desc = target.dataset.desc;
          const amountDollars = (amountCents / 100).toFixed(2);

          const isConfirmed = await customConfirm(
            `Settle $${amountDollars} for "${desc}" with ${toUserName}?`
          );
          if (!isConfirmed) {
            return;
          }

          target.disabled = true;
          target.textContent = 'Processing...';

          try {
            const response = await fetch('/api/settlements/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                groupId,
                fromUserId: currentUserId,
                toUserId,
                amountCents,
                description: `Settled specific expense: ${desc}`,
              }),
            });
            if (response.ok) {
              showToast('Settlement recorded! 🎉');
              window.location.reload(); // Reload to refresh all stats
            } else {
              const error = await response.json();
              showToast(error.error || 'Failed to record settlement', 4000);
              target.disabled = false;
              target.textContent = 'Settle';
            }
          } catch (error) {
            console.error('Error recording settlement:', error);
            showToast('Error recording settlement', 4000);
            target.disabled = false;
            target.textContent = 'Settle';
          }
        });
      });
    }

    modal.classList.remove('hidden');
  }

  // Close stats list modal
  function closeStatsList() {
    const modal = document.getElementById('statsListModal');
    modal.classList.add('hidden');
  }

  // Load and display pending invitations
  async function loadPendingInvitations() {
    try {
      const response = await fetch('/api/dashboard/pending-invitations');

      // Handle 404 (endpoint not yet available)
      if (response.status === 404) {
        console.warn(
          '⚠️ Pending invitations endpoint not available. Please restart the dev server.'
        );
        return;
      }

      if (response.ok) {
        const data = await response.json();
        const invitationsList = document.getElementById('invitationsList');
        const invitationsEmpty = document.getElementById('invitationsEmpty');

        if (!data.invitations || data.invitations.length === 0) {
          if (invitationsList) invitationsList.innerHTML = invitationsEmpty?.outerHTML || '';
        } else {
          if (invitationsList) {
            invitationsList.innerHTML = data.invitations
              .map(
                (inv) => `
                <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-6">
                  <div class="flex justify-between items-start mb-3">
                    <div class="flex-1">
                      <h3 class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white">${escapeHtml(inv.groupName)}</h3>
                      <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">
                        Invited by <span class="font-medium">${escapeHtml(inv.invitedByName)}</span>
                      </p>
                    </div>
                    <span class="text-xs px-2 py-1 bg-amber-100 dark:bg-amber-900 text-amber-800 dark:text-amber-200 rounded font-medium flex-shrink-0">
                      Pending
                    </span>
                  </div>
                  
                  <div class="mb-3 text-xs sm:text-sm text-slate-600 dark:text-slate-400">
                    Expires: <span class="font-medium">${new Date(inv.expiresAt).toLocaleDateString()}</span>
                  </div>
                  
                  <div class="pt-3 border-t border-slate-200 dark:border-slate-700 flex gap-2">
                    <button class="text-sm px-4 py-2 bg-indigo-600 dark:bg-indigo-700 text-white hover:bg-indigo-700 dark:hover:bg-indigo-600 rounded transition-colors flex-1 accept-invitation-btn font-medium" data-invitation-id="${inv.id}">
                      Accept
                    </button>
                    <button class="text-sm px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-600 rounded transition-colors flex-1 decline-invitation-btn font-medium" data-invitation-id="${inv.id}">
                      Decline
                    </button>
                  </div>
                </div>
              `
              )
              .join('');

            // Add event listeners to accept/decline buttons
            document.querySelectorAll('.accept-invitation-btn').forEach((btn) => {
              btn.addEventListener('click', async (e) => {
                const invitationId = e.target.dataset.invitationId;
                try {
                  btn.disabled = true;
                  btn.textContent = 'Accepting...';
                  const response = await fetch('/api/groups/invitations/accept', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ invitationId }),
                  });
                  if (response.ok) {
                    showToast("Invitation accepted! You've joined the group.");
                    loadPendingInvitations();
                  } else {
                    const error = await response.json();
                    showToast(error.error || 'Failed to accept invitation', 4000);
                    btn.disabled = false;
                    btn.textContent = 'Accept';
                  }
                } catch (error) {
                  console.error('Error accepting invitation:', error);
                  showToast('Error accepting invitation', 4000);
                  btn.disabled = false;
                  btn.textContent = 'Accept';
                }
              });
            });

            document.querySelectorAll('.decline-invitation-btn').forEach((btn) => {
              btn.addEventListener('click', async (e) => {
                const invitationId = e.target.dataset.invitationId;
                try {
                  btn.disabled = true;
                  btn.textContent = 'Declining...';
                  const response = await fetch('/api/groups/invitations/decline', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ invitationId }),
                  });
                  if (response.ok) {
                    showToast('Invitation declined.');
                    loadPendingInvitations();
                  } else {
                    const error = await response.json();
                    showToast(error.error || 'Failed to decline invitation', 4000);
                    btn.disabled = false;
                    btn.textContent = 'Decline';
                  }
                } catch (error) {
                  console.error('Error declining invitation:', error);
                  showToast('Error declining invitation', 4000);
                  btn.disabled = false;
                  btn.textContent = 'Decline';
                }
              });
            });
          }
        }
      }
    } catch (error) {
      console.error('Failed to load pending invitations:', error);
    }
  }

  // Load and display outstanding balances
  async function loadSettlements() {
    try {
      // Fetch outstanding balances for the current user across all groups
      let allBalances = [];
      try {
        const balancesResp = await fetch('/api/dashboard/balances');
        if (balancesResp.ok) {
          const data = await balancesResp.json();
          allBalances = data.balances || [];
          window.globalBalances = allBalances;
        }
      } catch (e) {
        console.warn('Failed to load outstanding balances:', e);
      }

      // Display balances
      const balancesList = document.getElementById('balancesList');
      const balancesEmpty = document.getElementById('balancesEmpty');

      if (!allBalances || allBalances.length === 0) {
        if (balancesList) balancesList.innerHTML = balancesEmpty?.outerHTML || '';
      } else {
        if (balancesList) {
          balancesList.innerHTML = allBalances
            .map((balance) => {
              // If fromUserId === currentUserId, the user owes money
              const userOwes = balance.fromUserId === currentUserId;
              const otherUserName = userOwes ? balance.toUserName : balance.fromUserName;

              return `
                <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-6">
                  <div class="flex justify-between items-start mb-3">
                    <div class="flex-1">
                      <h3 class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white">
                        ${userOwes ? `You owe ${escapeHtml(otherUserName)}` : `${escapeHtml(otherUserName)} owes you`}
                      </h3>
                      <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 mt-1">
                        Group: ${escapeHtml(balance.groupName)}
                      </p>
                    </div>
                    <span class="text-sm font-bold ${userOwes ? 'text-amber-600 dark:text-amber-400' : 'text-green-600 dark:text-green-400'} flex-shrink-0">
                      $${parseFloat(balance.amountCents / 100).toFixed(2)}
                    </span>
                  </div>
                  
                  <div class="pt-3 border-t border-slate-200 dark:border-slate-700 flex gap-2">
                    ${
                      userOwes
                        ? `
                      <button class="text-sm px-4 py-2 bg-amber-600 dark:bg-amber-700 text-white hover:bg-amber-700 dark:hover:bg-amber-600 rounded transition-colors flex-1 settle-up-btn font-medium" 
                        data-to-user-id="${balance.toUserId}" 
                        data-to-user-name="${escapeHtml(balance.toUserName)}" 
                        data-amount-cents="${balance.amountCents}"
                        data-group-id="${balance.groupId}">
                        Settle Up
                      </button>
                    `
                        : `
                      <span class="text-xs px-4 py-2 text-slate-600 dark:text-slate-400 flex-1 text-center">
                        Awaiting their payment
                      </span>
                    `
                    }
                  </div>
                </div>
              `;
            })
            .join('');

          // Settlement Selection Modal Logic
          const selectionModal = document.getElementById('settlementSelectionModal');
          const closeSelectionBtn = document.getElementById('closeSettlementSelectionBtn');
          const selectAllCheckbox = document.getElementById('selectAllExpensesCheckbox');
          const expensesList = document.getElementById('settlementExpensesList');
          const selectedTotalEl = document.getElementById('settlementSelectedTotal');
          const fullAmountText = document.getElementById('settlementFullAmountText');
          const titleEl = document.getElementById('settlementSelectionTitle');
          const confirmBtn = document.getElementById('confirmSettlementSelectionBtn');

          let currentSettleState = {
            toUserId: null,
            toUserName: null,
            groupId: null,
            fullAmountCents: 0,
            specificOwes: [],
          };

          function setSpecificExpenseSelectionEnabled(isEnabled) {
            expensesList.querySelectorAll('.expense-checkbox').forEach((cb) => {
              cb.disabled = !isEnabled;
              if (!isEnabled) {
                cb.checked = true;
              }
            });
          }

          function updateSelectedTotal() {
            const selectAllLabel = document.getElementById('selectAllExpensesLabel');

            if (selectAllCheckbox.checked) {
              // Style 'Pay Full Amount' as selected
              selectAllLabel.className =
                'flex items-center gap-3 p-3 border-2 rounded-lg cursor-pointer transition-colors shadow-sm bg-indigo-50 dark:bg-indigo-900/30 border-indigo-500';

              selectedTotalEl.textContent = `$${(currentSettleState.fullAmountCents / 100).toFixed(2)}`;
              confirmBtn.disabled = false;
              confirmBtn.classList.remove('opacity-50', 'cursor-not-allowed');

              // Style all individual items as unselected
              expensesList.querySelectorAll('.expense-checkbox').forEach((cb) => {
                const label = cb.closest('.expense-label');
                if (label) {
                  label.className =
                    'expense-label flex items-start gap-3 p-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-750 transition-colors opacity-60';
                }
              });
              return;
            } else {
              // Style 'Pay Full Amount' as unselected
              selectAllLabel.className =
                'flex items-center gap-3 p-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-750 transition-colors';
            }

            const checkboxes = expensesList.querySelectorAll('.expense-checkbox');
            let totalCents = 0;

            checkboxes.forEach((cb) => {
              const label = cb.closest('.expense-label');
              if (cb.checked) {
                totalCents += parseInt(cb.value);
                if (label) {
                  label.className =
                    'expense-label flex items-start gap-3 p-3 border-2 rounded-lg cursor-pointer transition-colors shadow-sm bg-indigo-50 dark:bg-indigo-900/30 border-indigo-500';
                }
              } else {
                if (label) {
                  label.className =
                    'expense-label flex items-start gap-3 p-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-750 transition-colors';
                }
              }
            });

            selectedTotalEl.textContent = `$${(totalCents / 100).toFixed(2)}`;

            if (totalCents === 0) {
              confirmBtn.disabled = true;
              confirmBtn.classList.add('opacity-50', 'cursor-not-allowed');
            } else {
              confirmBtn.disabled = false;
              confirmBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            }
          }

          if (closeSelectionBtn) {
            closeSelectionBtn.addEventListener('click', () => {
              selectionModal.classList.add('hidden');
            });
          }

          if (selectAllCheckbox) {
            selectAllCheckbox.addEventListener('change', (e) => {
              const isChecked = e.target.checked;
              setSpecificExpenseSelectionEnabled(!isChecked);
              updateSelectedTotal();
            });
          }

          if (confirmBtn) {
            confirmBtn.addEventListener('click', async () => {
              let amountCents = 0;
              let description = '';

              if (selectAllCheckbox.checked) {
                amountCents = currentSettleState.fullAmountCents;
                description = 'Settled via Split Dashboard (Full Amount)';
              } else {
                const checkedBoxes = Array.from(
                  expensesList.querySelectorAll('.expense-checkbox:checked')
                );
                if (checkedBoxes.length === 0) return;

                amountCents = checkedBoxes.reduce((sum, cb) => sum + parseInt(cb.value), 0);
                const names = checkedBoxes.map((cb) => cb.dataset.desc);

                // Truncate description if it gets too long
                description = `Settled: ${names.join(', ')}`;
                if (description.length > 200) {
                  description = description.substring(0, 197) + '...';
                }
              }

              confirmBtn.disabled = true;
              confirmBtn.innerHTML = '<span class="animate-spin mr-2">⏳</span> Processing...';

              try {
                const response = await fetch('/api/settlements/create', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    groupId: currentSettleState.groupId,
                    fromUserId: currentUserId,
                    toUserId: currentSettleState.toUserId,
                    amountCents,
                    description,
                  }),
                });
                if (response.ok) {
                  showToast('Settlement recorded successfully! 🎉');
                  setTimeout(() => window.location.reload(), 2000);
                } else {
                  const error = await response.json();
                  showToast(error.error || 'Failed to record settlement', 4000);
                  confirmBtn.disabled = false;
                  confirmBtn.innerHTML = '💸 Record Payment';
                }
              } catch (error) {
                console.error('Error recording settlement:', error);
                showToast('Error recording settlement', 4000);
                confirmBtn.disabled = false;
                confirmBtn.innerHTML = '💸 Record Payment';
              }
            });
          }

          // Add event listeners to Settle Up buttons
          document.querySelectorAll('.settle-up-btn').forEach((btn) => {
            btn.addEventListener('click', async (e) => {
              const target = e.currentTarget;
              const toUserId = target.dataset.toUserId;
              const toUserName = target.dataset.toUserName;
              const amountCents = parseInt(target.dataset.amountCents);
              const groupId = target.dataset.groupId;
              const amountDollars = (amountCents / 100).toFixed(2);

              // Find specific expenses owed to this user in this group
              const specificOwes = statsData.owes.filter(
                (owe) => owe.groupId === groupId && owe.paidById === toUserId
              );

              if (specificOwes.length > 0 && selectionModal) {
                // Show Selection Modal
                currentSettleState = {
                  toUserId,
                  toUserName,
                  groupId,
                  fullAmountCents: amountCents,
                  specificOwes,
                };

                titleEl.textContent = `Settle Up with ${toUserName}`;
                fullAmountText.textContent = `$${amountDollars}`;

                // Reset checkboxes
                selectAllCheckbox.checked = true;

                expensesList.innerHTML = specificOwes
                  .map(
                    (owe) => `
                    <label class="expense-label flex items-start gap-3 p-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-750 transition-colors opacity-60">
                      <div class="pt-0.5">
                        <input type="checkbox" value="${owe.amountCents}" data-desc="${escapeHtml(owe.description)}" class="expense-checkbox w-4 h-4 text-indigo-600 rounded border-gray-300 focus:ring-indigo-500" checked />
                      </div>
                      <div class="flex-1">
                        <div class="flex justify-between items-start">
                          <span class="block font-medium text-slate-900 dark:text-white">${escapeHtml(owe.description)}</span>
                          <span class="block font-semibold text-slate-900 dark:text-white">$${(owe.amountCents / 100).toFixed(2)}</span>
                        </div>
                        <span class="block text-xs text-slate-500 dark:text-slate-400 mt-1">${escapeHtml(owe.tripName)}</span>
                      </div>
                    </label>
                  `
                  )
                  .join('');

                expensesList.querySelectorAll('.expense-checkbox').forEach((cb) => {
                  cb.addEventListener('change', updateSelectedTotal);
                });

                setSpecificExpenseSelectionEnabled(false);
                updateSelectedTotal();
                confirmBtn.innerHTML = '💸 Record Payment';
                selectionModal.classList.remove('hidden');
              } else {
                // Fallback: simple confirmation
                const isConfirmed = await customConfirm(
                  `Are you sure you want to record a $${amountDollars} payment to ${toUserName}?`
                );
                if (!isConfirmed) return;

                target.disabled = true;
                target.textContent = 'Processing...';

                try {
                  const response = await fetch('/api/settlements/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      groupId,
                      fromUserId: currentUserId,
                      toUserId,
                      amountCents,
                      description: 'Settled via Split Dashboard',
                    }),
                  });
                  if (response.ok) {
                    showToast('Settlement recorded successfully! 🎉');
                    setTimeout(() => window.location.reload(), 2000);
                  } else {
                    const error = await response.json();
                    showToast(error.error || 'Failed to record settlement', 4000);
                    target.disabled = false;
                    target.textContent = 'Settle Up';
                  }
                } catch (error) {
                  console.error('Error recording settlement:', error);
                  showToast('Error recording settlement', 4000);
                  target.disabled = false;
                  target.textContent = 'Settle Up';
                }
              }
            });
          });
        }
      }

      // Fetch events to get completed settlements
      const eventsResponse = await fetch('/api/events/list');
      let allCompletedSettlements = [];
      if (eventsResponse.ok) {
        const eventsData = await eventsResponse.json();
        const events = eventsData.events || [];
        for (const event of events) {
          try {
            const settlementsResp = await fetch(`/api/settlements/for-event?eventId=${event.id}`);
            if (settlementsResp.ok) {
              const data = await settlementsResp.json();
              allCompletedSettlements = allCompletedSettlements.concat(data.completed || []);
            }
          } catch (e) {}
        }
      }

      // Display completed settlements
      const completedSettlementsList = document.getElementById('completedSettlementsList');
      const completedSettlementsEmpty = document.getElementById('completedSettlementsEmpty');

      // Filter to only show completed settlements involving current user
      const userCompletedSettlements = allCompletedSettlements.filter(
        (s) => s.isCurrentUserPayer || s.isCurrentUserReceiver
      );

      if (!userCompletedSettlements || userCompletedSettlements.length === 0) {
        if (completedSettlementsList)
          completedSettlementsList.innerHTML = completedSettlementsEmpty?.outerHTML || '';
      } else {
        if (completedSettlementsList) {
          completedSettlementsList.innerHTML = userCompletedSettlements
            .map((settlement) => {
              return `
                <div class="bg-green-50 dark:bg-slate-700 rounded-lg shadow-sm border border-green-200 dark:border-green-600 p-5 sm:p-6">
                  <div class="flex justify-between items-start mb-3">
                    <div class="flex-1">
                      <h3 class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white">
                        ${escapeHtml(settlement.fromName)} → ${escapeHtml(settlement.toName)}
                      </h3>
                      <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 mt-1">
                        ${settlement.description ? escapeHtml(settlement.description) : 'Payment settlement'}
                      </p>
                    </div>
                    <span class="text-sm font-bold text-green-600 dark:text-green-400 flex-shrink-0">
                      $${parseFloat(settlement.amount).toFixed(2)}
                    </span>
                  </div>
                  
                  <div class="mb-3 text-xs text-slate-500 dark:text-slate-400">
                    Created ${new Date(settlement.createdAt).toLocaleDateString()}
                    ${settlement.paymentMethod ? `via ${escapeHtml(settlement.paymentMethod)}` : ''}
                    <br />
                    <span class="text-green-600 dark:text-green-400 font-medium">
                      ✓ Completed ${new Date(settlement.completedAt).toLocaleDateString()}
                    </span>
                  </div>
                </div>
              `;
            })
            .join('');
        }
      }
    } catch (error) {
      console.error('Failed to load settlements:', error);
    }
  }

