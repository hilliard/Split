---
import Layout from "../../layouts/Layout.astro";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}
---

<Layout title="Dashboard" description="Your Split dashboard">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <h1 class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">
            Split
          </h1>
          <div class="flex items-center gap-4">
            <!-- Theme toggle -->
            <button
              id="themeToggle"
              class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors"
              aria-label="Toggle dark mode"
            >
              <svg
                id="sunIcon"
                class="w-5 h-5 text-slate-600 dark:text-slate-400"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
                ></path>
              </svg>
            </button>

            <!-- Logout button -->
            <button
              id="logoutBtn"
              class="px-4 py-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors font-semibold"
            >
              Logout
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Welcome Card -->
        <div
          class="md:col-span-2 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8"
        >
          <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">
            Welcome back!
          </h2>
          <p class="text-slate-600 dark:text-slate-400">
            Click the buttons below to create a new event or group and start
            tracking expenses.
          </p>
        </div>

        <!-- Quick Stats -->
        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8"
        >
          <h3
            class="text-sm font-semibold text-slate-600 dark:text-slate-400 uppercase mb-2"
          >
            Quick Stats
          </h3>
          <div class="space-y-4">
            <div>
              <p
                class="text-3xl font-bold text-indigo-600 dark:text-indigo-400"
              >
                0
              </p>
              <p class="text-sm text-slate-600 dark:text-slate-400">Groups</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-green-600 dark:text-green-400">
                $0
              </p>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Total balanced
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <a
          href="#"
          class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors"
        >
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">
            Create Event
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm">
            Create a new event to organize expenses
          </p>
        </a>

        <a
          href="#"
          class="block p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors"
        >
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">
            Create Group
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm">
            Create a new group to split expenses with friends
          </p>
        </a>
      </div>

      <!-- Empty State -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-12 text-center"
      >
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-2">
          No events or groups yet
        </h3>
        <p class="text-slate-600 dark:text-slate-400">
          Get started by creating your first event or group
        </p>
      </div>
    </main>
  </div>

  <script>
    // Theme toggle
    const themeToggle = document.getElementById(
      "themeToggle",
    ) as HTMLButtonElement;
    themeToggle.addEventListener("click", () => {
      const html = document.documentElement;
      if (html.classList.contains("dark")) {
        html.classList.remove("dark");
        localStorage.setItem("theme", "light");
      } else {
        html.classList.add("dark");
        localStorage.setItem("theme", "dark");
      }
    });

    // Logout
    const logoutBtn = document.getElementById("logoutBtn") as HTMLButtonElement;
    logoutBtn.addEventListener("click", async () => {
      try {
        await fetch("/api/auth/logout", { method: "POST" });
        window.location.href = "/";
      } catch (error) {
        console.error("Logout error:", error);
      }
    });
  </script>
</Layout>
