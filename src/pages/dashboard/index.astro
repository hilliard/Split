            html:not(.dark) [class*="bg-slate-50"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-slate-900"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-slate-600"] {
              color: rgb(71, 85, 105) !important;
            }
            html:not(.dark) [class*="text-slate-400"] {
              color: rgb(148, 163, 184) !important;
            }
            html:not(.dark) [class*="border-slate-200"] {
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) [class*="bg-slate-800"],
            html:not(.dark) [class*="bg-slate-900"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-white"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="hover:bg-slate"] {
              backgroundColor: inherit !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem("theme", "light");
        console.log("✅ Switched to light mode");
        if (icon) icon.textContent = "☀️";
      } else {
        // Switch to DARK mode
        console.log("→ Switching to dark mode");
        html.classList.add("dark");
        document.body.style.setProperty(
          "background-color",
          "rgb(6, 6, 10)",
          "important",
        );
        document.body.style.setProperty(
          "color",
          "rgb(248, 250, 252)",
          "important",
        );

        // Set inline styles on main div for dark mode
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(6, 6, 10)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(248, 250, 252)", "important");
        }

        // Remove light mode styles and apply dark mode styles
        let lightStyles = document.getElementById("dynamicLightStyles");
        if (lightStyles) lightStyles.remove();

        // Inject dark mode styles
        if (!document.getElementById("dynamicDarkStyles")) {
          const style = document.createElement("style");
          style.id = "dynamicDarkStyles";
          style.textContent = `
            html.dark header {
              background-color: rgb(15, 23, 42) !important;
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark main {
              background-color: rgb(6, 6, 10) !important;
            }
            html.dark [class*="bg-white"],
            html.dark [class*="bg-slate-50"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="bg-slate-800"] {
              background-color: rgb(30, 41, 59) !important;
            }
            html.dark [class*="bg-slate-900"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="text-slate-900"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-slate-600"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-slate-400"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-white"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-indigo-300"] {
              color: rgb(165, 180, 252) !important;
            }
            html.dark [class*="text-indigo-400"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-600"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-700"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="border-slate-200"] {
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark [class*="border-slate-700"] {
              border-color: rgb(51, 65, 85) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem("theme", "dark");
        console.log("✅ Switched to dark mode");
        if (icon) icon.textContent = "🌙";
      }
    };

    // Setup theme toggle - set initial icon and styles
    function setupThemeToggle() {
      const btn = document.getElementById("themeToggle");
      const icon = document.getElementById("themeIcon");
      const html = document.documentElement;
      const body = document.body;
      const mainDiv = document.querySelector("div.min-h-screen");

      if (!btn) {
        console.error("❌ Theme toggle button not found");
        return;
      }

      console.log("✅ Theme toggle setup started");

      // Update icon to match current theme on initialization
      const isDark = html.classList.contains("dark");
      if (icon) icon.textContent = isDark ? "🌙" : "☀️";

      // Inject CSS styles for current theme (both light and dark)
      if (isDark && !document.getElementById("dynamicDarkStyles")) {
        // Inject dark mode CSS
        const darkStyle = document.createElement("style");
        darkStyle.id = "dynamicDarkStyles";
        darkStyle.textContent = `
          html.dark header {
            background-color: rgb(15, 23, 42) !important;
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark main {
            background-color: rgb(6, 6, 10) !important;
          }
          html.dark [class*="bg-white"],
          html.dark [class*="bg-slate-50"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="bg-slate-800"] {
            background-color: rgb(30, 41, 59) !important;
          }
          html.dark [class*="bg-slate-900"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="text-slate-900"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-slate-600"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-slate-400"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-white"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="border-slate-200"] {
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark [class*="border-slate-700"] {
            border-color: rgb(51, 65, 85) !important;
          }
        `;
        document.head.appendChild(darkStyle);
      } else if (!isDark && !document.getElementById("dynamicLightStyles")) {
        // Inject light mode CSS
        const lightStyle = document.createElement("style");
        lightStyle.id = "dynamicLightStyles";
        lightStyle.textContent = `
          html:not(.dark) header {
            background-color: rgb(255, 255, 255) !important;
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) main {
            background-color: rgb(245, 246, 248) !important;
          }
          html:not(.dark) [class*="bg-white"],
          html:not(.dark) [class*="bg-slate-50"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-slate-900"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-slate-600"] {
            color: rgb(71, 85, 105) !important;
          }
          html:not(.dark) [class*="text-slate-400"] {
            color: rgb(148, 163, 184) !important;
          }
          html:not(.dark) [class*="border-slate-200"] {
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) [class*="bg-slate-800"],
          html:not(.dark) [class*="bg-slate-900"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-white"] {
            color: rgb(15, 23, 42) !important;
          }
        `;
        document.head.appendChild(lightStyle);
      }

      // Apply inline styles with setProperty to match current theme
      if (isDark) {
        html.style.setProperty("color-scheme", "dark", "important");
        body.style.setProperty(
          "background-color",
          "rgb(6, 6, 10)",
          "important",
        );
        body.style.setProperty("color", "rgb(248, 250, 252)", "important");
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(6, 6, 10)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(248, 250, 252)", "important");
        }
      } else {
        html.style.setProperty("color-scheme", "light", "important");
        body.style.setProperty(
          "background-color",
          "rgb(255, 255, 255)",
          "important",
        );
        body.style.setProperty("color", "rgb(15, 23, 42)", "important");
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(255, 255, 255)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(15, 23, 42)", "important");
        }
      }

      console.log("✅ Theme toggle ready");
    }

    // Initialize dashboard with event listeners
    async function initializeDashboard() {
      console.log("Initializing dashboard...");

      try {
        // Load user info first (before other initialization)
        await loadUserInfo();
        // Load events list
        await loadEvents();
        // Load user groups
        await loadGroups();
        // Update stats panel
        await updateStats();
        // Load pending invitations
        await loadPendingInvitations();

        // Setup theme toggle - with explicit logging
        console.log("Before setupThemeToggle");
        setupThemeToggle();
        console.log("After setupThemeToggle");

        // Logout button
        const logoutBtn = document.getElementById("logoutBtn");
        if (logoutBtn) {
          logoutBtn.addEventListener("click", async () => {
            try {
              await fetch("/api/auth/logout", { method: "POST" });
              window.location.href = "/";
            } catch (error) {
              console.error("Logout error:", error);
            }
          });
        }

        // Mobile menu toggle
        const mobileMenuBtn = document.getElementById("mobileMenuBtn");
        const mobileMenu = document.getElementById("mobileMenu");

        if (mobileMenuBtn && mobileMenu) {
          mobileMenuBtn.addEventListener("click", () => {
            mobileMenu.classList.toggle("hidden");
          });

          // Close menu when clicking on a link
          const links = mobileMenu.querySelectorAll("a");
          links.forEach((link) => {
            link.addEventListener("click", () => {
              mobileMenu.classList.add("hidden");
            });
          });
        }

        // Stats List Modal Event Listeners
        const statsListCloseBtn = document.getElementById("statsListCloseBtn");
        const statsListModal = document.getElementById("statsListModal");

        if (statsListCloseBtn) {
          statsListCloseBtn.addEventListener("click", closeStatsList);
        }

        if (statsListModal) {
          statsListModal.addEventListener("click", (e) => {
            if (e.target === statsListModal) {
              closeStatsList();
            }
          });
        }

        // Stats buttons
        const statsTripsBtn = document.getElementById("statsTripsBtn");
        const statsExpensesBtn = document.getElementById("statsExpensesBtn");
        const statsActivitiesBtn =
          document.getElementById("statsActivitiesBtn");
        const statsGroupsBtn = document.getElementById("statsGroupsBtn");

        if (statsTripsBtn) {
          statsTripsBtn.addEventListener("click", () => {
            showStatsList("trips", "Trips");
          });
        }

        if (statsExpensesBtn) {
          statsExpensesBtn.addEventListener("click", () => {
            showStatsList("expenses", "Expenses");
          });
        }

        if (statsActivitiesBtn) {
          statsActivitiesBtn.addEventListener("click", () => {
            showStatsList("activities", "Activities");
          });
        }

        if (statsGroupsBtn) {
          statsGroupsBtn.addEventListener("click", () => {
            showStatsList("groups", "Groups");
          });
        }

        // Create Event Form Handler
        const createEventForm = document.getElementById("createEventForm");
        const createEventModal = document.getElementById("createEventModal");
        const eventError = document.getElementById("eventError");

        console.log("🔍 Form elements found:", {
          form: !!createEventForm,
          modal: !!createEventModal,
          error: !!eventError,
        });

        if (createEventForm) {
          console.log("📝 Attaching form submit listener");
          createEventForm.addEventListener("submit", async (e) => {
            e.preventDefault();
            console.log("📝 Form submitted!");

            // Get form fields - handle both old and new field names
            const titleInput =
              document.getElementById("eventTitle") ||
              document.getElementById("eventName");
            const descriptionInput =
              document.getElementById("eventDescription");
            const startDateTimeInput =
              document.getElementById("eventStartDateTime") ||
              document.getElementById("eventStartDate");
            const endDateTimeInput =
              document.getElementById("eventEndDateTime") ||
              document.getElementById("eventEndDate");
            const typeSelect = document.getElementById("eventType");
            const timezoneSelect = document.getElementById("eventTimezone");
            const currencySelect = document.getElementById("eventCurrency");
            const budgetInput = document.getElementById("eventBudget");
            const locationInput = document.getElementById("eventLocation");
            const isVirtualCheckbox = document.getElementById("eventIsVirtual");
            const isPublicCheckbox = document.getElementById("eventIsPublic");

            console.log("🔍 Input elements found:", {
              title: !!titleInput,
              description: !!descriptionInput,
              startDateTime: !!startDateTimeInput,
              endDateTime: !!endDateTimeInput,
              type: !!typeSelect,
              timezone: !!timezoneSelect,
              currency: !!currencySelect,
              budget: !!budgetInput,
              location: !!locationInput,
              isVirtual: !!isVirtualCheckbox,
              isPublic: !!isPublicCheckbox,
            });

            // Get values with proper handling for datetime-local vs date inputs
            const title = titleInput?.value?.trim() || "";
            const description = descriptionInput?.value?.trim() || "";
            const startDateTime = startDateTimeInput?.value?.trim() || "";
            const endDateTime = endDateTimeInput?.value?.trim() || "";
            const type = typeSelect?.value || "general";
            const timezone = timezoneSelect?.value || "UTC";
            const currency = currencySelect?.value || "USD";
            const budget = budgetInput?.value?.trim() || "";
            const location = locationInput?.value?.trim() || "";
            const isVirtual = isVirtualCheckbox?.checked || false;
            const isPublic = isPublicCheckbox?.checked !== false;

            console.log("📝 Form values collected:", {
              title,
              description,
              startDateTime,
              endDateTime,
              type,
              timezone,
              currency,
              budget,
              location,
              isVirtual,
              isPublic,
            });

            if (eventError) {
              eventError.textContent = "";
              eventError.classList.add("hidden");
            }

            try {
              // Convert datetime-local (2026-04-07T14:30) to ISO string
              let startTime = startDateTime;
              let endTime = endDateTime;

              if (startDateTime && startDateTime.includes("T")) {
                // datetime-local format, convert to ISO
                startTime = new Date(startDateTime).toISOString();
              } else if (startDateTime) {
                // date format, convert to ISO at start of day
                startTime = new Date(startDateTime + "T00:00:00").toISOString();
              }

              if (endDateTime && endDateTime.includes("T")) {
                endTime = new Date(endDateTime).toISOString();
              } else if (endDateTime) {
                endTime = new Date(endDateTime + "T23:59:59").toISOString();
              }

              console.log("📦 Converted times:", { startTime, endTime });

              const response = await fetch("/api/events/create", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  name: title,
                  title,
                  description,
                  location,
                  startDate: startDateTime,
                  startTime,
                  endDate: endDateTime,
                  endTime,
                  currency,
                  budget: budget ? budget : undefined,
                  type,
                  timezone,
                  isVirtual,
                  isPublic,
                }),
              });

              const data = await response.json();

              if (!response.ok) {
                const errorMsg = data.error || "Failed to create event";
                console.error("Event creation error:", errorMsg);
                if (eventError) {
                  eventError.textContent = errorMsg;
                  eventError.classList.remove("hidden");
                }
              } else {
                console.log("✓ Event created:", data.event.id);
                createEventForm.reset();
                if (createEventModal) {
                  createEventModal.classList.add("hidden");
                }
                showToast("Event created successfully!");
                await loadEvents();
                // Redirect to event detail page
                window.location.href = `/events/${data.event.id}`;
              }
            } catch (error) {
              console.error("Network error:", error);
              if (eventError) {
                eventError.textContent = "An error occurred. Please try again.";
                eventError.classList.remove("hidden");
              }
            }
          });
        }

        // Create Event Modal Button - Show/Hide
        const createEventBtn = document.getElementById("createEventBtn");
        const cancelEventBtn = document.getElementById("cancelEventBtn");

        if (createEventBtn && createEventModal) {
          createEventBtn.addEventListener("click", () => {
            createEventModal.classList.remove("hidden");
          });
        }

        if (cancelEventBtn && createEventModal) {
          cancelEventBtn.addEventListener("click", () => {
            createEventModal.classList.add("hidden");
          });
        }
      } catch (error) {
        console.error("Dashboard initialization error:", error);
      }
    }

    // Always wait for DOM to be fully ready
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initializeDashboard);
    } else if (document.readyState === "interactive") {
      // Interactive means DOM is ready but styles/images still loading
      // Safe to initialize
      initializeDashboard();
    } else {
      // Complete means everything is loaded
      // Use requestAnimationFrame to ensure DOM is painted
      requestAnimationFrame(() => {
        initializeDashboard();
      });
    }
  </script>
</Layout>
