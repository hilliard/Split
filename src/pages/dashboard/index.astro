---
import Layout from '../../layouts/Layout.astro';
import { getSession } from '../../utils/session';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

const session = await getSession(sessionId);
if (!session) {
  Astro.cookies.delete('sessionId', { path: '/' });
  return Astro.redirect('/auth/login');
}

const errorParam = Astro.url.searchParams.get('error');
---

<Layout title="Dashboard" description="Your Split dashboard" currentPage="dashboard">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Sub-header -->
    <nav
      class="bg-slate-100 dark:bg-slate-700 border-b border-slate-200 dark:border-slate-600 sticky top-16 z-40"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex gap-2 h-12 items-center overflow-x-auto">
          <span class="text-slate-700 dark:text-slate-300 text-sm font-medium whitespace-nowrap">
            Dashboard
          </span>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main
      class="flex-1 max-w-7xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-4 sm:py-8"
      data-user-id={session.userId}
    >
      {
        errorParam === 'unauthorized_edit' && (
          <div class="mb-6 p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg flex items-start gap-3">
            <div class="text-red-500 dark:text-red-400 mt-0.5">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                  clip-rule="evenodd"
                />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-red-800 dark:text-red-200">Access Denied</h3>
              <p class="mt-1 text-sm text-red-700 dark:text-red-300">
                You do not have permission to edit this event. Only the event creator can make
                changes.
              </p>
            </div>
          </div>
        )
      }

      <!-- Top Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
        <!-- Welcome Card -->
        <div
          class="md:col-span-2 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-8"
        >
          <h2
            id="welcomeMessage"
            class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-1"
          >
          </h2>
          <p
            id="welcomeEmail"
            class="text-base sm:text-lg text-slate-600 dark:text-slate-400 mb-3 sm:mb-4"
          >
          </p>
          <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
            Click the buttons below to create a new event or group and start tracking expenses.
          </p>
        </div>

        <!-- Quick Stats -->
        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-8"
        >
          <h3
            class="text-xs sm:text-sm font-semibold text-slate-600 dark:text-slate-400 uppercase mb-3 sm:mb-4"
          >
            Quick Stats
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 items-start">
            <button
              id="statsTripsBtn"
              class="flex w-full flex-col items-start text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <span
                id="statsEventCount"
                class="text-2xl sm:text-3xl font-bold text-blue-600 dark:text-blue-400 group-hover:underline"
              >
                0
              </span>
              <span
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Events
              </span>
            </button>
            <button
              id="statsExpensesBtn"
              class="flex w-full flex-col items-start text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <span
                id="statsExpenseCount"
                class="text-2xl sm:text-3xl font-bold text-green-600 dark:text-green-400 group-hover:underline"
              >
                0
              </span>
              <span
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Expenses
              </span>
            </button>
            <button
              id="statsActivitiesBtn"
              class="flex w-full flex-col items-start text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <span
                id="statsActivityCount"
                class="text-2xl sm:text-3xl font-bold text-amber-600 dark:text-amber-400 group-hover:underline"
              >
                0
              </span>
              <span
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Activities
              </span>
            </button>
            <button
              id="statsGroupsBtn"
              class="flex w-full flex-col items-start text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <span
                id="statsGroupCount"
                class="text-2xl sm:text-3xl font-bold text-indigo-600 dark:text-indigo-400 group-hover:underline"
              >
                0
              </span>
              <span
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Groups
              </span>
            </button>
            <button
              id="statsOwesBtn"
              class="flex w-full flex-col items-start text-left hover:opacity-80 transition-opacity cursor-pointer group"
            >
              <span
                id="statsOwesAmount"
                class="text-2xl sm:text-3xl font-bold text-red-600 dark:text-red-400 group-hover:underline"
              >
                $0
              </span>
              <span
                class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 group-hover:underline"
              >
                Owes
              </span>
            </button>
            <div
              class="flex w-full flex-col items-start text-left min-[457px]:pl-[10px] min-[457px]:ml-3"
            >
              <span
                id="statsTotalExpenses"
                class="text-2xl sm:text-3xl font-bold text-purple-600 dark:text-purple-400"
              >
                $0
              </span>
              <span class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 whitespace-nowrap">
                Total Spent
              </span>
            </div>
          </div>
        </div>
      </div>
      <script type="module">
        window.addEventListener('DOMContentLoaded', () => {
          const mainEl = document.querySelector('main[data-user-id]');
          const currentUserId = mainEl?.dataset?.userId;
          if (currentUserId) {
            fetch(`/api/expenses/user-total?userId=${currentUserId}`)
              .then((r) => r.json())
              .then((data) => {
                const dollars = (data.totalCents / 100).toFixed(2);
                const el = document.getElementById('statsTotalExpenses');
                if (el) el.textContent = `$${dollars}`;
              })
              .catch((err) => console.error('Failed to load total spent', err));
          }
        });
      </script>
    </main>

    <!-- Action Buttons -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-6 mb-6 sm:mb-8">
      <a
        href="/events/create"
        class="block p-5 sm:p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors active:bg-slate-50 dark:active:bg-slate-700 text-left w-full"
      >
        <h3 class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white mb-2">
          Create Event
        </h3>
        <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">
          Create a new event to organize expenses
        </p>
      </a>

      <a
        href="/groups/create"
        class="block p-5 sm:p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors active:bg-slate-50 dark:active:bg-slate-700"
      >
        <h3 class="text-base sm:text-lg font-semibold text-slate-900 dark:text-white mb-2">
          Create Group
        </h3>
        <p class="text-xs sm:text-sm text-slate-600 dark:text-slate-400">
          Create a new group to split expenses with friends
        </p>
      </a>
    </div>

    <!-- Pending Invitations Section -->
    <div class="mb-6 sm:mb-8">
      <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4">
        Pending Invitations
      </h2>
      <div id="invitationsList" class="grid grid-cols-1 gap-4">
        <!-- Pending invitations will be loaded here -->
        <div
          id="invitationsEmpty"
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8 sm:p-12 text-center"
        >
          <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white mb-2">
            No pending invitations
          </h3>
          <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
            You'll see invitations here when someone invites you to a group
          </p>
        </div>
      </div>
    </div>

    <!-- My Groups Section -->
    <div class="mb-6 sm:mb-8">
      <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4">Your Groups</h2>
      <div id="groupsList" class="grid grid-cols-1 gap-4">
        <!-- Groups will be loaded here -->
        <div
          id="groupsEmpty"
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8 sm:p-12 text-center"
        >
          <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white mb-2">
            No groups yet
          </h3>
          <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
            Create a group or accept an invitation to get started
          </p>
        </div>
      </div>
    </div>

    <!-- Events Section -->
    <div>
      <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4">Your Events</h2>
      <div id="eventsList" class="grid grid-cols-1 gap-4">
        <!-- Events will be loaded here -->
        <div
          id="eventsEmpty"
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8 sm:p-12 text-center"
        >
          <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white mb-2">
            No events yet
          </h3>
          <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
            Create your first event to get started
          </p>
        </div>
      </div>
    </div>

    <!-- Outstanding Balances Section -->
    <div class="mt-6 sm:mt-8">
      <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4">
        Outstanding Balances
      </h2>
      <div id="balancesList" class="grid grid-cols-1 gap-4">
        <!-- Balances will be loaded here -->
        <div
          id="balancesEmpty"
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8 sm:p-12 text-center"
        >
          <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white mb-2">
            All settled up!
          </h3>
          <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
            You don't owe anyone and nobody owes you right now.
          </p>
        </div>
      </div>
    </div>

    <!-- Completed Settlements Section -->
    <div class="mt-6 sm:mt-8">
      <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-4">
        Completed Settlements
      </h2>
      <div id="completedSettlementsList" class="grid grid-cols-1 gap-4">
        <!-- Completed settlements will be loaded here -->
        <div
          id="completedSettlementsEmpty"
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-8 sm:p-12 text-center"
        >
          <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white mb-2">
            No completed settlements yet
          </h3>
          <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
            Completed payment records will appear here
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats List Modal -->
  <div
    id="statsListModal"
    class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
  >
    <div
      class="bg-white dark:bg-slate-800 rounded-lg shadow-xl max-w-2xl w-full max-h-96 overflow-y-auto"
    >
      <!-- Modal Header -->
      <div
        class="sticky top-0 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-4 sm:px-6 py-4 flex justify-between items-center z-10"
      >
        <div class="flex items-center gap-2 sm:gap-3">
          <button
            id="statsListBackBtn"
            class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:bg-blue-50 dark:hover:bg-blue-900/30 flex items-center gap-1 transition-colors px-3 py-1.5 -ml-2 rounded-md border border-transparent hover:border-blue-100 dark:hover:border-blue-800"
            aria-label="Back to Dashboard"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
                clip-rule="evenodd"></path>
            </svg>
            <span class="text-sm font-bold">Back</span>
          </button>
          <h2
            id="statsListTitle"
            class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white"
          >
            Items
          </h2>
        </div>
        <button
          id="statsListCloseBtn"
          class="text-slate-400 hover:text-slate-600 dark:text-slate-500 dark:hover:text-slate-300 text-2xl leading-none px-2 py-1 transition-colors rounded hover:bg-slate-100 dark:hover:bg-slate-700"
          aria-label="Close"
        >
          ×
        </button>
      </div>

      <!-- Modal Content -->
      <div id="statsListContent" class="p-6 space-y-3">
        <!-- Items will be rendered here -->
      </div>
    </div>
  </div>

  <!-- Create Event Modal -->
  <div
    id="createEventModal"
    class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
  >
    <div
      class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-2xl border border-slate-200 dark:border-slate-700 my-8"
    >
      <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
        <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white">
          Create New Event
        </h2>
      </div>

      <form id="createEventForm" class="p-5 sm:p-6 space-y-4">
        <!-- Event Name -->
        <div>
          <label
            for="eventName"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Event Name
          </label>
          <input
            type="text"
            id="eventName"
            name="name"
            required
            placeholder="e.g., Vegas Trip, Houston Trip"
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
          />
        </div>

        <!-- Type & Timezone Row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label
              for="eventType"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Event Type
            </label>
            <select
              id="eventType"
              name="type"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            >
              <option value="general">General</option>
              <option value="trip">Trip</option>
              <option value="party">Party</option>
              <option value="dinner">Dinner</option>
              <option value="vacation">Vacation</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label
              for="eventTimezone"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Timezone
            </label>
            <select
              id="eventTimezone"
              name="timezone"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            >
              <option value="UTC">UTC</option>
              <option value="America/New_York">America/New_York</option>
              <option value="America/Chicago">America/Chicago</option>
              <option value="America/Denver">America/Denver</option>
              <option value="America/Los_Angeles">America/Los_Angeles</option>
              <option value="Europe/London">Europe/London</option>
              <option value="Europe/Paris">Europe/Paris</option>
              <option value="Europe/Berlin">Europe/Berlin</option>
              <option value="Asia/Tokyo">Asia/Tokyo</option>
              <option value="Asia/Shanghai">Asia/Shanghai</option>
              <option value="Asia/Hong_Kong">Asia/Hong_Kong</option>
              <option value="Asia/Singapore">Asia/Singapore</option>
              <option value="Australia/Sydney">Australia/Sydney</option>
            </select>
          </div>
        </div>

        <!-- Location & Currency Row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label
              for="eventLocation"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Location (Optional)
            </label>
            <input
              type="text"
              id="eventLocation"
              name="location"
              placeholder="e.g., Houston, TX"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>
          <div>
            <label
              for="eventCurrency"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Currency
            </label>
            <select
              id="eventCurrency"
              name="currency"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            >
              <option value="USD">USD - US Dollar</option>
              <option value="EUR">EUR - Euro</option>
              <option value="GBP">GBP - British Pound</option>
              <option value="CAD">CAD - Canadian Dollar</option>
              <option value="AUD">AUD - Australian Dollar</option>
              <option value="JPY">JPY - Japanese Yen</option>
              <option value="MXN">MXN - Mexican Peso</option>
              <option value="INR">INR - Indian Rupee</option>
            </select>
          </div>
        </div>

        <!-- Start & End Date Row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label
              for="eventStartDate"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Start Date (Optional)
            </label>
            <input
              type="datetime-local"
              id="eventStartDateTime"
              name="startDate"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>
          <div>
            <label
              for="eventEndDateTime"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              End Date (Optional)
            </label>
            <input
              type="datetime-local"
              id="eventEndDateTime"
              name="endDate"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>
        </div>

        <!-- Budget -->
        <div>
          <label
            for="eventBudget"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Budget (Optional)
          </label>
          <div class="relative">
            <span
              class="absolute left-4 top-3 text-slate-600 dark:text-slate-400 font-medium"
              id="budgetSymbol"
            >
              $
            </span>
            <input
              type="number"
              id="eventBudget"
              name="budget"
              step="0.01"
              min="0"
              placeholder="0.00"
              class="w-full pl-8 pr-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>
        </div>

        <!-- Description -->
        <div>
          <label
            for="eventDescription"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Description (Optional)
          </label>
          <textarea
            id="eventDescription"
            name="description"
            placeholder="Add details about this event..."
            rows="2"
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base resize-none"
          ></textarea>
        </div>

        <!-- Error Message -->
        <div
          id="eventError"
          class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
        >
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700">
          <button
            type="button"
            id="cancelEventBtn"
            class="px-4 py-2 text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
          >
            Cancel
          </button>
          <button
