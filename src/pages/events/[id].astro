    async function loadContent() {
      // Load both activities and expenses, then render them together
      try {
        const [activitiesResponse, expensesResponse] = await Promise.all([
          fetch(`/api/activities/list?eventId=${eventId}`),
          fetch(`/api/expenses/list?eventId=${eventId}`),
        ]);

        const activitiesData = await activitiesResponse.json();
        const expensesData = await expensesResponse.json();

        let html = "";

        // Add expenses first (at the top)
        if (
          expensesData.success &&
          expensesData.expenses &&
          expensesData.expenses.length > 0
        ) {
          html += expensesData.expenses
            .map((expense) => {
              const amount = expense.amount.toFixed(2);
              const tip = expense.tipAmount
                ? parseFloat(expense.tipAmount).toFixed(2)
                : "0.00";
              const total = (
                expense.amount + parseFloat(expense.tipAmount || 0)
              ).toFixed(2);
              const createdDate = new Date(
                expense.createdAt,
              ).toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                hour: "2-digit",
                minute: "2-digit",
              });

              return `<div class="p-4 bg-green-50 dark:bg-green-900 rounded-lg border border-green-200 dark:border-green-700">
              <div class="flex justify-between items-start mb-2">
                <h3 class="font-semibold text-slate-900 dark:text-white">${expense.description || "Untitled Expense"}</h3>
                <div class="flex gap-2 items-center">
                  <span class="text-xs px-2 py-1 bg-green-200 dark:bg-green-800 text-green-800 dark:text-green-200 rounded font-medium">
                    $${total}
                  </span>
                  <button 
                    data-expense-id="${expense.id}" 
                    data-amount="${amount}"
                    data-tip="${tip}"
                    data-description="${expense.description || ""}"
                    data-category="${expense.category || "misc"}"
                    data-metadata='${JSON.stringify(expense.metadata || {})}'
                    class="editExpenseBtn text-xs px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded hover:bg-blue-200 dark:hover:bg-blue-800 transition-colors">
                    ✏️ Edit
                  </button>
                </div>
              </div>
              <p class="text-sm text-slate-600 dark:text-slate-400 mb-1">💰 Paid by: ${expense.payerName || "Unknown"}</p>
              ${expense.category ? `<p class="text-sm text-slate-600 dark:text-slate-400 mb-1">📂 Category: ${expense.category}</p>` : ""}
              ${tip !== "0.00" ? `<p class="text-sm text-slate-600 dark:text-slate-400 mb-1">💡 Tip: $${tip}</p>` : ""}
              ${(() => {
                if (
                  !expense.metadata ||
                  Object.keys(expense.metadata).length === 0
                )
                  return "";
                let metadataHtml = "";
                for (const [k, v] of Object.entries(expense.metadata)) {
                  metadataHtml += `<p class='text-xs text-slate-700 dark:text-slate-300'>📋 <strong>${k}:</strong> ${v}</p>`;
                }
                return `<div class='mt-2 pt-2 border-t border-green-200 dark:border-green-700 space-y-1'>${metadataHtml}</div>`;
              })()}
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-2">🕐 ${createdDate}</p>
            </div>`;
            })
            .join("");
        }

        // Add activities (below expenses)
        if (activitiesData.activities && activitiesData.activities.length > 0) {
          html += activitiesData.activities
            .map((activity) => {
              const startTime = activity.startTime
                ? new Date(activity.startTime).toLocaleString("en-US", {
                    month: "short",
                    day: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                  })
                : null;

              return `<div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg border border-slate-200 dark:border-slate-600">
              <div class="flex justify-between items-start mb-2">
                <h3 class="font-semibold text-slate-900 dark:text-white">${activity.title}</h3>
                <a href="/activities/${activity.id}" class="text-xs px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded hover:bg-blue-200 dark:hover:bg-blue-800">Edit</a>
              </div>
              ${activity.locationName ? `<p class="text-sm text-slate-600 dark:text-slate-400 mb-1">📍 ${activity.locationName}</p>` : ""}
              ${startTime ? `<p class="text-xs text-slate-500 dark:text-slate-400">🕐 ${startTime}</p>` : ""}
            </div>`;
            })
            .join("");
        }

        // If nothing, show empty message
        if (!html) {
          html = `
            <div class="text-center py-8">
              <p class="text-slate-600 dark:text-slate-400">No activities or expenses yet. Click "+ Add Activity" or "💰 Add Expense" to create one!</p>
            </div>
          `;
        }

        // Set the combined HTML once
        activitiesList.innerHTML = html;

        // Attach edit handlers to expense buttons
        document.querySelectorAll(".editExpenseBtn").forEach((btn) => {
          btn.addEventListener("click", (e) => {
            const expense = {
              id: e.target.dataset.expenseId,
              amount: parseFloat(e.target.dataset.amount),
              tip: parseFloat(e.target.dataset.tip),
              description: e.target.dataset.description,
              category: e.target.dataset.category,
              metadata: e.target.dataset.metadata
                ? JSON.parse(e.target.dataset.metadata)
                : {},
            };
            openEditExpenseModal(expense);
          });
        });
      } catch (error) {
        console.error("Error loading content:", error);
        activitiesList.innerHTML =
          '<p class="text-red-600 dark:text-red-400">Error loading activities and expenses</p>';
      }
    }

    function openEditExpenseModal(expense) {
      const modal = document.getElementById("editExpenseModal");
      document.getElementById("editExpenseId").value = expense.id;
      document.getElementById("editExpenseAmount").value = expense.amount;
      document.getElementById("editExpenseTip").value = expense.tip;
      document.getElementById("editExpenseDescription").value =
        expense.description;
      document.getElementById("editExpenseCategory").value = expense.category;

      // Load and display metadata
      const metadataContainer = document.getElementById(
        "editExpenseMetadataContainer",
      );
      if (metadataContainer && expense.metadata) {
        metadataContainer.innerHTML = "";
        Object.entries(expense.metadata).forEach(([key, value]) => {
          addEditExpenseMetadataField(key, value);
        });
      }

      modal.classList.remove("hidden");
      // Update tip suggestion when modal opens
      updateEditExpenseTipSuggestion();
    }

    // Edit Expense Modal Handlers
    const editExpenseModal = document.getElementById("editExpenseModal");
