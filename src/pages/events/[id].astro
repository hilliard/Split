    // Submit activity form
    if (addActivityForm) {
      addActivityForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        console.log("✅ Add Activity form submitted");

        const formData = new FormData(addActivityForm);
        const activityError = document.getElementById("activityError");
        const submitBtn = addActivityForm.querySelector(
          'button[type="submit"]',
        );

        if (activityError) {
          activityError.textContent = "";
          activityError.classList.add("hidden");
        }

        if (submitBtn) submitBtn.disabled = true;

        try {
          // Collect metadata fields
          const metadata = {};
          const metadataKeys = formData.getAll("metadataKey");
          const metadataValues = formData.getAll("metadataValue");

          for (let i = 0; i < metadataKeys.length; i++) {
            const key = metadataKeys[i]?.trim();
            const value = metadataValues[i]?.trim();
            if (key && value) {
              metadata[key] = value;
            }
          }

          console.log("📤 Sending activity creation request:", {
            eventId,
            title: formData.get("title"),
            locationName: formData.get("locationName"),
            metadata,
          });

          const response = await fetch("/api/activities/create", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              eventId: eventId,
              title: formData.get("title"),
              locationName: formData.get("locationName") || null,
              startTime: formData.get("startTime") || null,
              endTime: formData.get("endTime") || null,
              sequenceOrder: 0,
              metadata: Object.keys(metadata).length > 0 ? metadata : {},
            }),
          });

          const data = await response.json();

          if (!response.ok) {
            console.error("❌ Activity creation failed:", data.error);
            if (activityError) {
              activityError.textContent =
                data.error?.message ||
                data.error ||
                "Failed to create activity";
              activityError.classList.remove("hidden");
            }
          } else {
            console.log("✅ Activity created successfully:", data.activity);
            const newActivityId = data.activity.id;
            const activityTitle = formData.get("title");

            // Handle expense if checkbox is checked
            const addExpenseCheckbox = document.getElementById(
              "addExpenseWithActivity",
            );
            if (addExpenseCheckbox && addExpenseCheckbox.checked) {
              const expenseAmount =
                parseFloat(formData.get("expenseAmount")) || 0;

              if (expenseAmount > 0) {
                try {
                  const expenseResponse = await fetch("/api/expenses/create", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                      groupId: currentGroupId,
                      eventId: eventId,
                      activityId: newActivityId,
                      amount: expenseAmount,
                      description:
                        formData.get("expenseDescription") || activityTitle,
                      category: formData.get("expenseCategory") || "misc",
                      paidBy: currentUserId,
                    }),
                  });

                  if (!expenseResponse.ok) {
                    console.error("Failed to create expense");
                  }
                } catch (error) {
                  console.error("Error creating expense:", error);
                }
              }
            }

            console.log("🔄 Closing modal and refreshing content...");
            addActivityModal.classList.add("hidden");

            console.log("📊 Calling loadContent...");
            loadContent(); // Refresh activities and expenses list

            console.log("💰 Updating totals...");
            updateTripTotal(); // Update trip total
            loadBreakdown(); // Update breakdown
            loadDetailedSummary(); // Update detailed summary

            console.log("✅ Activity submission complete!");
          }
        } catch (error) {
          console.error("❌ Catch block error:", error);
          if (activityError) {
            activityError.textContent = "An error occurred. Please try again.";
            activityError.classList.remove("hidden");
          }
        } finally {
          console.log("🏁 Finally block - disabling submit button");
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    }

    // Helper function to get selected split members
    function getSelectedSplitMembers() {
      const checkboxes = document.querySelectorAll(
        '#splitAmongContainer input[type="checkbox"]:checked',
      );
      const selectedIds = Array.from(checkboxes).map((cb) => cb.dataset.userId);
      return selectedIds.length > 0 ? selectedIds : [currentUserId]; // Default to current user if none selected
    }

    // Function to update split calculation display
    function updateSplitCalculation() {
      const amountInput = document.getElementById("directExpenseAmount");
      const tipInput = document.getElementById("directExpenseTip");
      const amount = parseFloat(amountInput?.value || "0");
      const tip = parseFloat(tipInput?.value || "0");
      const total = amount + tip;

      const selectedMembers = document.querySelectorAll(
        '#splitAmongContainer input[type="checkbox"]:checked',
      );
      const splitCount = selectedMembers.length || 1;
      const splitPerPerson = (total / splitCount).toFixed(2);

      const splitPerPersonEl = document.getElementById("splitPerPerson");
      if (splitPerPersonEl) {
        splitPerPersonEl.textContent = `$${splitPerPerson}`;
      }
    }

    // Function to load and render group members
    async function loadGroupMembers() {
      try {
        const response = await fetch(`/api/groups/list?id=${currentGroupId}`);
        if (!response.ok) {
          console.error("Failed to fetch group:", response.status);
          return;
        }

        const data = await response.json();
        const members = data.members || [];
        const container = document.getElementById("splitAmongContainer");

        if (!container) return;

        container.innerHTML = "";

        if (members.length === 0) {
          container.innerHTML =
            '<p class="text-xs text-slate-500 dark:text-slate-400">No members found</p>';
          return;
        }

        // Create checkboxes for each member
        members.forEach((member) => {
          const div = document.createElement("div");
          div.className = "flex items-center";

          const checkbox = document.createElement("input");
          checkbox.type = "checkbox";
          checkbox.id = `split_${member.userId}`;
          checkbox.dataset.userId = member.userId;
          checkbox.className = "w-4 h-4 text-blue-600 rounded cursor-pointer";
          checkbox.checked = true; // Default all checked
          checkbox.addEventListener("change", updateSplitCalculation);

          const label = document.createElement("label");
          label.htmlFor = `split_${member.userId}`;
          label.className =
            "ml-2 text-sm text-slate-700 dark:text-slate-300 cursor-pointer";
          label.textContent = `${member.firstName} ${member.lastName}`;

          div.appendChild(checkbox);
          div.appendChild(label);
          container.appendChild(div);
        });

        // Update calculation after loading members
        updateSplitCalculation();
      } catch (error) {
        console.error("Failed to load group members:", error);
      }
    }

    // Direct Expense Modal Handlers
    const addExpenseBtn = document.getElementById("addExpenseBtn");
    const addExpenseModal = document.getElementById("addExpenseModal");
    const cancelDirectExpenseBtn = document.getElementById(
      "cancelDirectExpenseBtn",
    );
    const addDirectExpenseForm = document.getElementById(
      "addDirectExpenseForm",
    );
    const directExpenseAmountInput = document.getElementById(
      "directExpenseAmount",
    );
    const directExpenseTipInput = document.getElementById("directExpenseTip");
    const directExpenseTipBtn = document.getElementById("directExpenseTipBtn");
    const directExpenseTipSuggest = document.getElementById(
      "directExpenseTipSuggest",
    );

    // Update tip suggestion when amount changes
    function updateDirectExpenseTipSuggestion() {
      if (!directExpenseAmountInput) return;
      const amount = parseFloat(directExpenseAmountInput.value) || 0;
      if (amount > 0) {
        const tip20 = parseFloat((amount * 0.2).toFixed(2));
        directExpenseTipSuggest.textContent = `Suggested 20% tip: $${tip20.toFixed(2)}`;
      } else {
        directExpenseTipSuggest.textContent = "";
      }
      // Update split calculation when amount changes
      updateSplitCalculation();
    }

    if (directExpenseAmountInput) {
      directExpenseAmountInput.addEventListener(
        "input",
        updateDirectExpenseTipSuggestion,
      );
    }

    // Update split calculation when tip changes
    if (directExpenseTipInput) {
      directExpenseTipInput.addEventListener("input", updateSplitCalculation);
    }

    // 20% tip button handler
    if (directExpenseTipBtn) {
      directExpenseTipBtn.addEventListener("click", (e) => {
        e.preventDefault();
        const amount = parseFloat(directExpenseAmountInput.value) || 0;
        const tip20 = parseFloat((amount * 0.2).toFixed(2));
        directExpenseTipInput.value = tip20;
      });
