        addExpenseModal.classList.add("hidden");
        addDirectExpenseForm.reset();
      });
    }

    // Close modal on backdrop click
    if (addExpenseModal) {
      addExpenseModal.addEventListener("click", (e) => {
        if (e.target === addExpenseModal) {
          addExpenseModal.classList.add("hidden");
          addDirectExpenseForm.reset();
        }
      });
    }

    // Submit direct expense form
    if (addDirectExpenseForm) {
      addDirectExpenseForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(addDirectExpenseForm);
        const directExpenseError =
          document.getElementById("directExpenseError");
        const submitBtn = addDirectExpenseForm.querySelector(
          'button[type="submit"]',
        );

        if (directExpenseError) {
          directExpenseError.textContent = "";
          directExpenseError.classList.add("hidden");
        }

        if (submitBtn) submitBtn.disabled = true;

        try {
          const description = formData.get("description") || "Expense";
          const amount = parseFloat(formData.get("amount")) || 0;
          const tip = parseFloat(formData.get("tip")) || 0;
          const category = formData.get("category") || "misc";

          if (!amount || isNaN(amount) || amount <= 0) {
            if (directExpenseError) {
              directExpenseError.textContent = "Please enter a valid amount.";
              directExpenseError.classList.remove("hidden");
            }
            return;
          }

          // Collect expense metadata
          const metadata = {};
          const metadataKeys = formData.getAll("expenseMetadataKey");
          const metadataValues = formData.getAll("expenseMetadataValue");

          for (let i = 0; i < metadataKeys.length; i++) {
            const key = metadataKeys[i]?.trim();
            const value = metadataValues[i]?.trim();
            if (key && value) {
              metadata[key] = value;
            }
          }

          const response = await fetch("/api/expenses/create", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              groupId: currentGroupId,
              eventId: eventId,
              amount: amount, // Already in dollars, API will convert to cents
              tipAmount: tip, // Already in dollars, API will convert to cents
              description,
              category,
              paidBy: currentUserId,
              splitAmong: getSelectedSplitMembers(), // Include who to split among
              metadata: Object.keys(metadata).length > 0 ? metadata : {},
            }),
          });

          const data = await response.json();

          if (!response.ok) {
            if (directExpenseError) {
              directExpenseError.textContent =
                data.error?.message || data.error || "Failed to create expense";
              directExpenseError.classList.remove("hidden");
            }
          } else {
            addExpenseModal.classList.add("hidden");
            addDirectExpenseForm.reset();
            loadContent(); // Refresh activities and expenses list
            updateTripTotal(); // Update trip total
            loadBreakdown(); // Update breakdown
            loadDetailedSummary(); // Update detailed summary
            showToast("✅ Expense added successfully!");
          }
        } catch (error) {
          if (directExpenseError) {
            directExpenseError.textContent =
              "An error occurred. Please try again.";
            directExpenseError.classList.remove("hidden");
          }
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    }

    // Group linking handlers
    const selectGroupModal = document.getElementById("selectGroupModal");
    const cancelSelectGroupBtn = document.getElementById(
      "cancelSelectGroupBtn",
    );
    const groupsList = document.getElementById("groupsList");

    if (cancelSelectGroupBtn) {
