    // Load trip total cost
    async function updateTripTotal() {
      try {
        const response = await fetch(`/api/expenses/list?eventId=${eventId}`);
        if (response.ok) {
          const data = await response.json();
          const expenses = data.expenses || [];
          let totalCost = 0;

          console.log(`✅ Found ${expenses.length} expenses`);
          console.log("Expenses:", expenses);

          expenses.forEach((expense) => {
            const amount = parseFloat(expense.amount) || 0;
            const tip = parseFloat(expense.tipAmount) || 0;
            const expenseTotal = amount + tip;
            console.log(
              `  Expense: $${amount.toFixed(2)} + $${tip.toFixed(2)} tip = $${expenseTotal.toFixed(2)}`,
            );
            totalCost += expenseTotal;
          });

          console.log(`Total cost: $${totalCost.toFixed(2)}`);

          const tripTotalCostEl = document.getElementById("tripTotalCost");
          if (tripTotalCostEl) {
            // Get currency from the page or default to USD
            const currencySpan = document.querySelector("[data-currency]");
            const currency =
              currencySpan?.getAttribute("data-currency") || "USD";
            tripTotalCostEl.textContent = `${currency} $${totalCost.toFixed(2)}`;
          }
        }
      } catch (error) {
        console.error("Failed to update trip total:", error);
      }
    }

    // Load and display detailed trip summary
    async function loadDetailedSummary() {
      try {
        // Get all expenses
        const expensesResponse = await fetch(
          `/api/expenses/list?eventId=${eventId}`,
        );
        if (!expensesResponse.ok) {
          return;
        }

        const expensesData = await expensesResponse.json();
        const expenses = expensesData.expenses || [];

        // Get balances/settlements
        const balancesResponse = await fetch(
          `/api/expenses/balances?eventId=${eventId}`,
        );
        if (!balancesResponse.ok) {
          return;
        }

        const balancesData = await balancesResponse.json();
        const settlements = balancesData.settlements || [];

        // Calculate individual balances
        const personBalances = {};
        expenses.forEach((expense) => {
          // Add to payer
          if (!personBalances[expense.payerName]) {
            personBalances[expense.payerName] = { paid: 0, owed: 0 };
          }
          personBalances[expense.payerName].paid += expense.total;

          // Add to those who owe
          if (expense.splits) {
            expense.splits.forEach((split) => {
              const splitPerson = Object.values(
                balancesData.members || {},
              ).find((m) => m.id === split.userId);
              if (splitPerson) {
                const personName = splitPerson.name;
                if (!personBalances[personName]) {
                  personBalances[personName] = { paid: 0, owed: 0 };
                }
                personBalances[personName].owed += parseFloat(
                  split.amountDollars,
                );
              }
            });
          }
        });

        // Display individual balances
        const balancesEl = document.getElementById("individualBalances");
        if (balancesEl) {
          balancesEl.innerHTML = Object.entries(personBalances)
            .map(
              ([name, balance]) => `
            <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg border border-slate-200 dark:border-slate-600">
              <p class="font-semibold text-slate-900 dark:text-white mb-3">${name}</p>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-slate-600 dark:text-slate-400">Paid</span>
                  <span class="font-semibold text-green-600 dark:text-green-400">$${balance.paid.toFixed(2)}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-600 dark:text-slate-400">Owes</span>
                  <span class="font-semibold text-red-600 dark:text-red-400">$${balance.owed.toFixed(2)}</span>
                </div>
                <div class="border-t border-slate-200 dark:border-slate-600 pt-2 flex justify-between">
                  <span class="font-semibold text-slate-900 dark:text-white">Net</span>
                  <span class="font-bold ${balance.paid - balance.owed >= 0 ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400"}">
                    $${(balance.paid - balance.owed).toFixed(2)}
                  </span>
                </div>
              </div>
            </div>
          `,
            )
            .join("");
        }

        // Group expenses by category
        const expensesByCtg = {};
        expenses.forEach((expense) => {
          const category = expense.category || "Miscellaneous";
          if (!expensesByCtg[category]) {
            expensesByCtg[category] = [];
          }
          expensesByCtg[category].push(expense);
        });

        // Display expenses by category
        const categoryEl = document.getElementById("expensesByCategory");
        if (categoryEl) {
          categoryEl.innerHTML = Object.entries(expensesByCtg)
            .map(
              ([category, categoryExpenses]) => `
            <div>
              <h4 class="font-semibold text-slate-900 dark:text-white mb-3 capitalize">${category}</h4>
              <div class="space-y-2">
                ${categoryExpenses
                  .map(
                    (exp) => `
                  <div class="p-3 bg-slate-50 dark:bg-slate-700 rounded border border-slate-200 dark:border-slate-600">
                    <div class="flex justify-between items-start mb-1">
                      <div>
                        <p class="font-medium text-slate-900 dark:text-white">${exp.description}</p>
                        <p class="text-xs text-slate-500 dark:text-slate-400">Paid by ${exp.payerName}</p>
                      </div>
                      <div class="text-right">
                        <p class="font-semibold text-slate-900 dark:text-white">$${exp.amount.toFixed(2)}</p>
                        ${exp.tip > 0 ? `<p class="text-xs text-slate-500 dark:text-slate-400">+ $${exp.tip.toFixed(2)} tip</p>` : ""}
                      </div>
                    </div>
                    ${
                      exp.splits && exp.splits.length > 0
                        ? `
                      <div class="text-xs text-slate-600 dark:text-slate-400 mt-2 pt-2 border-t border-slate-200 dark:border-slate-600">
                        Split among ${exp.splits.length} people
                      </div>
                    `
                        : ""
                    }
                  </div>
                `,
                  )
                  .join("")}
              </div>
            </div>
          `,
            )
            .join("");
        }

        // Display settlement summary
        const settlementEl = document.getElementById("settlementSummary");
        if (settlementEl) {
          if (settlements.length === 0) {
            settlementEl.innerHTML = `
              <div class="text-center p-6 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
                <p class="text-green-700 dark:text-green-300 font-semibold">✅ All settled up!</p>
                <p class="text-sm text-green-600 dark:text-green-400">No one owes anyone money.</p>
              </div>
            `;
          } else {
            settlementEl.innerHTML = settlements
              .map(
                (s) => `
              <div class="p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg">
                <p class="font-semibold text-slate-900 dark:text-white">
                  <span class="text-amber-700 dark:text-amber-300">${s.fromName}</span>
                  owes
                  <span class="text-amber-700 dark:text-amber-300">${s.toName}</span>
                </p>
                <p class="text-lg font-bold text-amber-600 dark:text-amber-400 mt-1">
                  $${s.amount.toFixed(2)}
                </p>
              </div>
            `,
              )
              .join("");
          }
        }
      } catch (error) {
        console.error("Failed to load detailed summary:", error);
      }
    }

    // Load and display trip breakdown
    async function loadBreakdown() {
      try {
        const breakdownEl = document.getElementById("breakdownContent");
        if (!breakdownEl) return;

        const response = await fetch(
          `/api/expenses/balances?eventId=${eventId}`,
        );
        if (response.ok) {
          const data = await response.json();
          const settlements = data.settlements || [];

          if (settlements.length === 0) {
            breakdownEl.innerHTML = `
              <div class="text-center py-8">
                <p class="text-slate-600 dark:text-slate-400">✅ All settled up! No one owes anyone money.</p>
              </div>
            `;
          } else {
            breakdownEl.innerHTML = `
              <div class="space-y-3">
                ${settlements
                  .map(
                    (settlement) => `
                  <div class="p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg">
                    <p class="font-semibold text-slate-900 dark:text-white">
                      <span class="text-amber-700 dark:text-amber-300">${settlement.fromName}</span>
                      owes
                      <span class="text-amber-700 dark:text-amber-300">${settlement.toName}</span>
                    </p>
                    <p class="text-lg font-bold text-amber-600 dark:text-amber-400 mt-1">
                      $${settlement.amount.toFixed(2)}
                    </p>
                  </div>
                `,
                  )
                  .join("")}
              </div>
            `;
          }
        }
      } catch (error) {
        console.error("Failed to load breakdown:", error);
        const breakdownEl = document.getElementById("breakdownContent");
        if (breakdownEl) {
          breakdownEl.innerHTML =
            '<p class="text-red-600 dark:text-red-400">Failed to load breakdown</p>';
        }
      }
    }

    // Initialize: Load group info, content, total, and breakdown
    // Toast notification helper
    const toast = document.getElementById("toast");
    const toastMessage = document.getElementById("toast-message");

    function showToast(message) {
      if (!toast || !toastMessage) return;
      toastMessage.textContent = message;
      toast.classList.remove("opacity-0");
      setTimeout(() => {
        toast.classList.add("opacity-0");
      }, 3000);
    }

    loadGroupInfo();
    loadContent();
    updateTripTotal();
    loadBreakdown();
    loadDetailedSummary();
  </script>

  <!-- Toast Notification -->
  <div
    id="toast"
    class="fixed bottom-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none z-50 max-w-xs"
  >
    <span id="toast-message"></span>
  </div>
</Layout>
