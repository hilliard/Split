      selectGroupModal.addEventListener("click", (e) => {
        if (e.target === selectGroupModal) {
          selectGroupModal.classList.add("hidden");
        }
      });
    }

    async function loadUserGroups() {
      try {
        const response = await fetch("/api/groups/my-groups");
        if (response.ok) {
          const data = await response.json();

          if (data.groups && data.groups.length > 0) {
            groupsList.innerHTML = data.groups
              .map(
                (group) => `
              <button
                type="button"
                class="w-full p-4 text-left bg-slate-50 dark:bg-slate-700 hover:bg-slate-100 dark:hover:bg-slate-600 rounded-lg border border-slate-200 dark:border-slate-600 transition-colors"
                onclick="linkGroupToEvent('${group.id}', '${group.name.replace(/'/g, "\\'")}')">
