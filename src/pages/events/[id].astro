              );
            }
          } catch (error) {
            alert("Error deleting expense: " + error.message);
          }
        }
      });
    }

    // Calculate tip suggestion for edit expense
    const editExpenseTipBtn = document.getElementById("editExpenseTipBtn");
    const editExpenseAmountInput = document.getElementById("editExpenseAmount");
    const editExpenseTipInput = document.getElementById("editExpenseTip");
    const editExpenseTipSuggest = document.getElementById(
      "editExpenseTipSuggest",
    );

    // Update tip suggestion when amount changes
    function updateEditExpenseTipSuggestion() {
      if (!editExpenseAmountInput) return;
      const amount = parseFloat(editExpenseAmountInput.value) || 0;
      if (amount > 0) {
        const tip20 = parseFloat((amount * 0.2).toFixed(2));
        editExpenseTipSuggest.textContent = `Suggested 20% tip: $${tip20.toFixed(2)}`;
      } else {
        editExpenseTipSuggest.textContent = "";
      }
    }

    if (editExpenseAmountInput) {
      editExpenseAmountInput.addEventListener(
        "input",
        updateEditExpenseTipSuggestion,
      );
    }

    if (editExpenseTipBtn) {
      editExpenseTipBtn.addEventListener("click", (e) => {
        e.preventDefault();
        const amount = parseFloat(editExpenseAmountInput.value) || 0;
        const tip20 = parseFloat((amount * 0.2).toFixed(2));
        editExpenseTipInput.value = tip20;
      });
    }

    // Update expense
    if (editExpenseForm) {
      editExpenseForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const expenseId = document.getElementById("editExpenseId").value;
        const amount = parseFloat(
          document.getElementById("editExpenseAmount").value,
        );
        const tipAmount = parseFloat(
          document.getElementById("editExpenseTip").value,
        );
        const description = document.getElementById(
          "editExpenseDescription",
        ).value;
        const category = document.getElementById("editExpenseCategory").value;
        const editExpenseError = document.getElementById("editExpenseError");

        if (!expenseId || !amount || isNaN(amount)) {
          editExpenseError.textContent =
            "Please fill in all required fields correctly.";
          editExpenseError.classList.remove("hidden");
          return;
        }

        // Collect metadata
        const metadata = {};
        const metadataKeys = document.querySelectorAll(
          'input[name="editExpenseMetadataKey"]',
        );
        const metadataValues = document.querySelectorAll(
          'input[name="editExpenseMetadataValue"]',
        );

        for (let i = 0; i < metadataKeys.length; i++) {
          const key = metadataKeys[i].value.trim();
          const value = metadataValues[i].value.trim();
          if (key && value) {
            metadata[key] = value;
          }
        }

        try {
          const response = await fetch("/api/expenses/update", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              expenseId,
              amount,
              tipAmount,
              description,
              category,
              metadata: Object.keys(metadata).length > 0 ? metadata : {},
            }),
          });

          if (response.ok) {
            editExpenseModal.classList.add("hidden");
            editExpenseForm.reset();
            loadContent();
            updateTripTotal(); // Update trip total
            loadBreakdown(); // Update breakdown
            loadDetailedSummary(); // Update detailed summary
            showToast("Expense updated successfully");
          } else {
            const error = await response.json();
            editExpenseError.textContent =
              "Failed to update expense: " + (error.error || "Unknown error");
            editExpenseError.classList.remove("hidden");
          }
        } catch (error) {
