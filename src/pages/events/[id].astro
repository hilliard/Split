---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../db";
import { events, sessions } from "../../db/schema";
import { eq } from "drizzle-orm";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}

// Get event ID from URL
const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

// Get session and verify user
const [session] = await db
  .select()
  .from(sessions)
  .where(eq(sessions.id, sessionId))
  .limit(1);

if (!session || new Date(session.expiresAt) < new Date()) {
  return Astro.redirect("/auth/login");
}

// Get event by ID
const [event] = await db
  .select()
  .from(events)
  .where(eq(events.id, id as string))
  .limit(1);

// Verify event exists and belongs to current user
if (!event || event.creatorId !== session.userId) {
  return Astro.redirect("/dashboard");
}

// Format timestamps for display
const startDate = event.startTime
  ? new Date(event.startTime).toLocaleDateString("en-US", {
      weekday: "long",
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "Not set";

const endDate = event.endTime
  ? new Date(event.endTime).toLocaleDateString("en-US", {
      weekday: "long",
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "Not set";

const budget = event.budgetCents
  ? (event.budgetCents / 100).toFixed(2)
  : "Not set";
---

<Layout title={event.title} description={event.description || "Event details"}>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16 gap-4">
          <a
            href="/dashboard"
            class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-semibold text-sm sm:text-base"
          >
            ← Back to Dashboard
          </a>
          <h1
            class="text-xl sm:text-2xl font-bold text-indigo-600 dark:text-indigo-400 truncate"
          >
            Split
          </h1>
          <div class="flex gap-2">
            <button
              id="themeToggle"
              onclick="window.toggleTheme && window.toggleTheme()"
              class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors text-lg"
            >
              <span id="themeIcon">☀️</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main
      class="flex-1 max-w-4xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8"
    >
      <!-- Event Header Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6"
      >
        <div class="flex justify-between items-start mb-4">
          <div>
            <h1
              class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-2"
            >
              {event.title}
            </h1>
            {
              event.timezone && (
                <p class="text-lg text-slate-600 dark:text-slate-400">
                  🌍 {event.timezone}
                  {event.isVirtual && " (Virtual)"}
                </p>
              )
            }
          </div>
          <span
            class="text-xl font-semibold text-indigo-600 dark:text-indigo-400"
          >
            {event.currency}
          </span>
        </div>

        {
          event.description && (
            <p class="text-base text-slate-700 dark:text-slate-300 mb-6 leading-relaxed">
              {event.description}
            </p>
          )
        }

        <!-- Key Details Grid -->
        <div
          class="grid grid-cols-1 sm:grid-cols-3 gap-4 py-6 border-t border-b border-slate-200 dark:border-slate-700"
        >
          <div>
            <p
              class="text-sm font-medium text-slate-600 dark:text-slate-400 mb-2"
            >
              Start Date
            </p>
            <p class="text-lg font-semibold text-slate-900 dark:text-white">
              {startDate}
            </p>
          </div>
          <div>
            <p
              class="text-sm font-medium text-slate-600 dark:text-slate-400 mb-2"
            >
              End Date
            </p>
            <p class="text-lg font-semibold text-slate-900 dark:text-white">
              {endDate}
            </p>
          </div>
          <div>
            <p
              class="text-sm font-medium text-slate-600 dark:text-slate-400 mb-2"
            >
              Total Budget
            </p>
            <p class="text-lg font-semibold text-green-600 dark:text-green-400">
              {event.currency}
              {budget}
            </p>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-6 flex gap-3 flex-wrap">
          <a
            href={`/events/${event.id}/edit`}
            class="inline-flex items-center px-6 py-2.5 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium"
          >
            ✏️ Edit Event
          </a>
          <a
            href={`/activities/?eventId=${event.id}`}
            class="inline-flex items-center px-6 py-2.5 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium"
          >
            📋 Manage Activities
          </a>
          <button
            id="deleteBtn"
            class="inline-flex items-center px-6 py-2.5 bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-200 rounded-lg hover:bg-red-200 dark:hover:bg-red-800 transition-colors font-medium"
          >
            🗑️ Delete Event
          </button>
        </div>
      </div>

      <!-- Group Section -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6"
      >
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-slate-900 dark:text-white">
            Group
          </h2>
          <button
            id="manageGroupBtn"
            class="text-sm px-4 py-2 bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 rounded-lg hover:bg-indigo-200 dark:hover:bg-indigo-800 transition-colors font-medium"
          >
            Manage Group
          </button>
        </div>

        <div
          id="groupInfo"
          class="mb-4 p-4 bg-slate-50 dark:bg-slate-700 rounded-lg"
        >
          <p class="text-slate-600 dark:text-slate-400 mb-2">
            Loading group...
          </p>
        </div>

        <div id="groupMembers" class="space-y-2"></div>
      </div>

      <!-- Activities Section -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-slate-900 dark:text-white">
            Activities & Expenses
          </h2>
          <button
            id="addActivityBtn"
            class="text-sm px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium"
          >
            + Add Activity
          </button>
        </div>

        <div id="activitiesList" class="space-y-3">
          <p class="text-slate-600 dark:text-slate-400">
            Loading activities...
          </p>
        </div>
      </div>

      <!-- Add Activity Modal -->
      <div
        id="addActivityModal"
        class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
      >
        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-md border border-slate-200 dark:border-slate-700 my-8"
        >
          <div
            class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700"
          >
            <h2
              class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white"
            >
              Add Activity
            </h2>
          </div>

          <form id="addActivityForm" class="p-5 sm:p-6 space-y-4">
            <div>
              <label
                for="activityTitle"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Activity Title
              </label>
              <input
                type="text"
                id="activityTitle"
                name="title"
                required
                placeholder="e.g., Breakfast, Hotel Check-in, Transport"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>

            <div>
              <label
                for="activityLocation"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Location (Optional)
              </label>
              <input
                type="text"
                id="activityLocation"
                name="locationName"
                placeholder="e.g., Downtown Café, Hotel Lobby"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label
                  for="activityStartTime"
                  class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
                >
                  Start Time (Optional)
                </label>
                <input
                  type="datetime-local"
                  id="activityStartTime"
                  name="startTime"
                  class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
              </div>
              <div>
                <label
                  for="activityEndTime"
                  class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
                >
                  End Time (Optional)
                </label>
                <input
                  type="datetime-local"
                  id="activityEndTime"
                  name="endTime"
                  class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
              </div>
            </div>

            <div
              id="activityError"
              class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
            >
            </div>

            <div
              class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700"
            >
              <button
                type="button"
                id="cancelActivityBtn"
                class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
              >
                Cancel
              </button>
              <button
                type="submit"
                class="px-4 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium text-sm"
              >
                Add Activity
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>

  <script define:vars={{ eventId: id }}>
    // Global theme toggle function accessible from HTML onclick
    window.toggleTheme = function () {
      console.log("🖱️ Theme toggle clicked");

      const html = document.documentElement;
      const isDark = html.classList.contains("dark");
      const icon = document.getElementById("themeIcon");
      const mainDiv = document.querySelector("div.min-h-screen");

      if (isDark) {
        // Switch to LIGHT mode
        console.log("→ Switching to light mode");
        html.classList.remove("dark");
        document.body.style.setProperty(
          "background-color",
          "rgb(255, 255, 255)",
          "important",
        );
        document.body.style.setProperty(
          "color",
          "rgb(15, 23, 42)",
          "important",
        );

        // Clear inline styles from main div
        if (mainDiv) {
          mainDiv.style.backgroundColor = "";
          mainDiv.style.color = "";
        }

        // Remove dark mode styles and apply light mode styles
        let darkStyles = document.getElementById("dynamicDarkStyles");
        if (darkStyles) darkStyles.remove();

        // Inject light mode styles
        if (!document.getElementById("dynamicLightStyles")) {
          const style = document.createElement("style");
          style.id = "dynamicLightStyles";
          style.textContent = `
            html:not(.dark) header {
              background-color: rgb(255, 255, 255) !important;
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) main {
              background-color: rgb(245, 246, 248) !important;
            }
            html:not(.dark) [class*="bg-white"],
            html:not(.dark) [class*="bg-slate-50"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-slate-900"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-slate-600"] {
              color: rgb(71, 85, 105) !important;
            }
            html:not(.dark) [class*="text-slate-400"] {
              color: rgb(148, 163, 184) !important;
            }
            html:not(.dark) [class*="border-slate-200"] {
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) [class*="bg-slate-800"],
            html:not(.dark) [class*="bg-slate-900"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-white"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-indigo-300"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-400"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-600"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-700"] {
              color: rgb(67, 56, 202) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem("theme", "light");
        console.log("✅ Switched to light mode");
        if (icon) icon.textContent = "☀️";
      } else {
        // Switch to DARK mode
        console.log("→ Switching to dark mode");
        html.classList.add("dark");
        document.body.style.setProperty(
          "background-color",
          "rgb(6, 6, 10)",
          "important",
        );
        document.body.style.setProperty(
          "color",
          "rgb(248, 250, 252)",
          "important",
        );

        // Set inline styles on main div for dark mode
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(6, 6, 10)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(248, 250, 252)", "important");
        }

        // Remove light mode styles and apply dark mode styles
        let lightStyles = document.getElementById("dynamicLightStyles");
        if (lightStyles) lightStyles.remove();

        // Inject dark mode styles
        if (!document.getElementById("dynamicDarkStyles")) {
          const style = document.createElement("style");
          style.id = "dynamicDarkStyles";
          style.textContent = `
            html.dark header {
              background-color: rgb(15, 23, 42) !important;
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark main {
              background-color: rgb(6, 6, 10) !important;
            }
            html.dark [class*="bg-white"],
            html.dark [class*="bg-slate-50"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="bg-slate-800"] {
              background-color: rgb(30, 41, 59) !important;
            }
            html.dark [class*="bg-slate-900"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="text-slate-900"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-slate-600"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-slate-400"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-white"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-indigo-300"] {
              color: rgb(165, 180, 252) !important;
            }
            html.dark [class*="text-indigo-400"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-600"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-700"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="border-slate-200"] {
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark [class*="border-slate-700"] {
              border-color: rgb(51, 65, 85) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem("theme", "dark");
        console.log("✅ Switched to dark mode");
        if (icon) icon.textContent = "🌙";
      }
    };

    // Setup theme toggle on page load
    function setupThemeToggle() {
      const btn = document.getElementById("themeToggle");
      const icon = document.getElementById("themeIcon");
      const html = document.documentElement;
      const body = document.body;
      const mainDiv = document.querySelector("div.min-h-screen");

      if (!btn) {
        console.error("❌ Theme toggle button not found");
        return;
      }

      console.log("✅ Theme toggle setup started");

      // Update icon to match current theme on initialization
      const isDark = html.classList.contains("dark");
      if (icon) icon.textContent = isDark ? "🌙" : "☀️";

      // Inject CSS styles for current theme (both light and dark)
      if (isDark && !document.getElementById("dynamicDarkStyles")) {
        // Inject dark mode CSS
        const darkStyle = document.createElement("style");
        darkStyle.id = "dynamicDarkStyles";
        darkStyle.textContent = `
          html.dark header {
            background-color: rgb(15, 23, 42) !important;
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark main {
            background-color: rgb(6, 6, 10) !important;
          }
          html.dark [class*="bg-white"],
          html.dark [class*="bg-slate-50"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="bg-slate-800"] {
            background-color: rgb(30, 41, 59) !important;
          }
          html.dark [class*="bg-slate-900"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="text-slate-900"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-slate-600"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-slate-400"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-white"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-indigo-300"] {
            color: rgb(165, 180, 252) !important;
          }
          html.dark [class*="text-indigo-400"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="text-indigo-600"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="text-indigo-700"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="border-slate-200"] {
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark [class*="border-slate-700"] {
            border-color: rgb(51, 65, 85) !important;
          }
        `;
        document.head.appendChild(darkStyle);
      } else if (!isDark && !document.getElementById("dynamicLightStyles")) {
        // Inject light mode CSS
        const lightStyle = document.createElement("style");
        lightStyle.id = "dynamicLightStyles";
        lightStyle.textContent = `
          html:not(.dark) header {
            background-color: rgb(255, 255, 255) !important;
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) main {
            background-color: rgb(245, 246, 248) !important;
          }
          html:not(.dark) [class*="bg-white"],
          html:not(.dark) [class*="bg-slate-50"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-slate-900"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-slate-600"] {
            color: rgb(71, 85, 105) !important;
          }
          html:not(.dark) [class*="text-slate-400"] {
            color: rgb(148, 163, 184) !important;
          }
          html:not(.dark) [class*="border-slate-200"] {
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) [class*="bg-slate-800"],
          html:not(.dark) [class*="bg-slate-900"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-white"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-indigo-300"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-400"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-600"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-700"] {
            color: rgb(67, 56, 202) !important;
          }
        `;
        document.head.appendChild(lightStyle);
      }

      // Apply inline styles with setProperty to match current theme
      if (isDark) {
        html.style.setProperty("color-scheme", "dark", "important");
        body.style.setProperty(
          "background-color",
          "rgb(6, 6, 10)",
          "important",
        );
        body.style.setProperty("color", "rgb(248, 250, 252)", "important");
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(6, 6, 10)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(248, 250, 252)", "important");
        }
      } else {
        html.style.setProperty("color-scheme", "light", "important");
        body.style.setProperty(
          "background-color",
          "rgb(255, 255, 255)",
          "important",
        );
        body.style.setProperty("color", "rgb(15, 23, 42)", "important");
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(255, 255, 255)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(15, 23, 42)", "important");
        }
      }

      console.log("✅ Theme toggle ready");
    }

    // Initialize theme on page load (wait for DOM to be fully ready)
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupThemeToggle);
    } else {
      setTimeout(setupThemeToggle, 0);
    }

    // Delete event handler
    const deleteBtn = document.getElementById("deleteBtn");
    if (deleteBtn) {
      deleteBtn.addEventListener("click", async () => {
        if (
          confirm(
            "Are you sure you want to delete this event? This action cannot be undone.",
          )
        ) {
          try {
            const response = await fetch(`/api/events/${eventId}`, {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
            });

            if (response.ok) {
              window.location.href = "/dashboard";
            } else {
              alert("Failed to delete event");
            }
          } catch (error) {
            alert("Error deleting event: " + error.message);
          }
        }
      });
    }

    // Load group and activities
    console.log("Event ID:", eventId);
    const groupMembers = document.getElementById("groupMembers");
    const activitiesList = document.getElementById("activitiesList");
    const addActivityBtn = document.getElementById("addActivityBtn");
    const addActivityModal = document.getElementById("addActivityModal");
    const cancelActivityBtn = document.getElementById("cancelActivityBtn");
    const addActivityForm = document.getElementById("addActivityForm");

    async function loadGroupInfo() {
      try {
        const response = await fetch(
          `/api/events/${eventId}?includeGroup=true`,
        );
        if (response.ok) {
          const data = await response.json();
          if (data.group) {
            groupInfo.innerHTML = `
              <div class="flex justify-between items-center">
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-white">${data.group.name}</h3>
                </div>
                <span class="text-xs font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-100 dark:bg-indigo-900 px-3 py-1 rounded">
                  ${data.members ? data.members.length : 0} members
                </span>
              </div>
            `;

            if (data.members) {
              groupMembers.innerHTML = data.members
                .map(
                  (member) =>
                    `<div class="flex items-center p-3 bg-slate-50 dark:bg-slate-700 rounded-lg">
                  <span class="text-slate-900 dark:text-white">${member.firstName} ${member.lastName}</span>
                  ${member.phone ? `<span class="text-xs text-slate-500 ml-auto">${member.phone}</span>` : ""}
                </div>`,
                )
                .join("");
            }
          } else {
            groupInfo.innerHTML = `
              <p class="text-slate-600 dark:text-slate-400">No group assigned. <a href="/groups/create" class="text-indigo-600 dark:text-indigo-400 hover:underline">Create one</a></p>
            `;
          }
        }
      } catch (error) {
        groupInfo.innerHTML =
          '<p class="text-red-600 dark:text-red-400">Error loading group info</p>';
      }
    }

    async function loadActivities() {
      try {
        const response = await fetch(`/api/activities/list?eventId=${eventId}`);
        const data = await response.json();

        if (data.activities && data.activities.length > 0) {
          activitiesList.innerHTML = data.activities
            .map((activity) => {
              const startTime = activity.startTime
                ? new Date(activity.startTime).toLocaleString("en-US", {
                    month: "short",
                    day: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                  })
                : null;

              return `<div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg border border-slate-200 dark:border-slate-600">
              <div class="flex justify-between items-start mb-2">
                <h3 class="font-semibold text-slate-900 dark:text-white">${activity.title}</h3>
                <a href="/activities/${activity.id}" class="text-xs px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded hover:bg-blue-200 dark:hover:bg-blue-800">Edit</a>
              </div>
              ${activity.locationName ? `<p class="text-sm text-slate-600 dark:text-slate-400 mb-1">📍 ${activity.locationName}</p>` : ""}
              ${startTime ? `<p class="text-xs text-slate-500 dark:text-slate-400">🕐 ${startTime}</p>` : ""}
            </div>`;
            })
            .join("");
        } else {
          activitiesList.innerHTML = `
            <div class="text-center py-8">
              <p class="text-slate-600 dark:text-slate-400">No activities yet. Click "+ Add Activity" to create one!</p>
            </div>
          `;
        }
      } catch (error) {
        activitiesList.innerHTML =
          '<p class="text-red-600 dark:text-red-400">Error loading activities</p>';
      }
    }

    // Load initial data
    loadGroupInfo();
    loadActivities();

    // Activity modal handlers
    if (addActivityBtn) {
      addActivityBtn.addEventListener("click", () => {
        addActivityModal.classList.remove("hidden");
        document.getElementById("activityTitle").focus();
      });
    }

    if (cancelActivityBtn) {
      cancelActivityBtn.addEventListener("click", () => {
        addActivityModal.classList.add("hidden");
        addActivityForm.reset();
      });
    }

    // Close modal on backdrop click
    if (addActivityModal) {
      addActivityModal.addEventListener("click", (e) => {
        if (e.target === addActivityModal) {
          addActivityModal.classList.add("hidden");
          addActivityForm.reset();
        }
      });
    }

    // Submit activity form
    if (addActivityForm) {
      addActivityForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(addActivityForm);
        const activityError = document.getElementById("activityError");
        const submitBtn = addActivityForm.querySelector(
          'button[type="submit"]',
        );

        if (activityError) {
          activityError.textContent = "";
          activityError.classList.add("hidden");
        }

        if (submitBtn) submitBtn.disabled = true;

        try {
          const response = await fetch("/api/activities/create", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              eventId: eventId,
              title: formData.get("title"),
              locationName: formData.get("locationName") || null,
              startTime: formData.get("startTime") || null,
              endTime: formData.get("endTime") || null,
              sequenceOrder: 0,
            }),
          });

          const data = await response.json();

          if (!response.ok) {
            if (activityError) {
              activityError.textContent =
                data.error?.message ||
                data.error ||
                "Failed to create activity";
              activityError.classList.remove("hidden");
            }
          } else {
            addActivityModal.classList.add("hidden");
            addActivityForm.reset();
            loadActivities(); // Refresh activities list
          }
        } catch (error) {
          if (activityError) {
            activityError.textContent = "An error occurred. Please try again.";
            activityError.classList.remove("hidden");
          }
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    }
  </script>
</Layout>
