---
import Layout from "../../../layouts/Layout.astro";
import { db } from "../../../db";
import { events, sessions } from "../../../db/schema";
import { eq } from "drizzle-orm";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}

// Get event ID from URL
const { id } = Astro.params;

// Redirect if no ID provided
if (!id) {
  return Astro.redirect("/dashboard");
}

// Get session and verify user
const [session] = await db
  .select()
  .from(sessions)
  .where(eq(sessions.id, sessionId))
  .limit(1);

if (!session || new Date(session.expiresAt) < new Date()) {
  return Astro.redirect("/auth/login");
}

// Get event by ID
const [event] = await db
  .select()
  .from(events)
  .where(eq(events.id, id as string))
  .limit(1);

// Verify event exists and belongs to current user
if (!event || event.creatorId !== session.userId) {
  return Astro.redirect("/dashboard");
}

// Format timestamps for form input (datetime-local expects YYYY-MM-DDTHH:mm format)
const formatDatetimeLocal = (date: string | null | undefined) => {
  if (!date) return "";
  try {
    return new Date(date).toISOString().slice(0, 16);
  } catch {
    return "";
  }
};

const startTimeValue = formatDatetimeLocal(event.startTime?.toString());
const endTimeValue = formatDatetimeLocal(event.endTime?.toString());
const budget = event.budgetCents ? (event.budgetCents / 100).toFixed(2) : "";
---

<Layout title={`Edit ${event.title}`} description="Edit event details">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16 gap-4">
          <a
            href={`/events/${event.id}`}
            class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-semibold text-sm sm:text-base"
          >
            ← Back
          </a>
          <h1
            class="text-xl sm:text-2xl font-bold text-indigo-600 dark:text-indigo-400 truncate"
          >
            Split
          </h1>
          <div class="flex gap-2">
            <button
              id="themeToggle"
              onclick="window.toggleTheme && window.toggleTheme()"
              class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors text-lg"
            >
              <span id="themeIcon">☀️</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main
      class="flex-1 max-w-4xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8"
    >
      <!-- Edit Form Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-6">
          Edit Event
        </h1>

        <form id="editEventForm" class="space-y-4">
          <!-- Event Name -->
          <!-- Event Title -->
          <div>
            <label
              for="eventTitle"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Event Title
            </label>
            <input
              type="text"
              id="eventTitle"
              name="title"
              value={event.title}
              required
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Event Type & Currency Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventType"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Event Type
              </label>
              <select
                id="eventType"
                name="type"
                value={event.type}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="general">General</option>
                <option value="concert">Concert</option>
                <option value="dinner">Formal Dinner</option>
                <option value="sports">Sports</option>
                <option value="movie">Movie</option>
                <option value="trip">Trip</option>
                <option value="wedding">Wedding</option>
              </select>
            </div>
            <div>
              <label
                for="eventCurrency"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Currency
              </label>
              <select
                id="eventCurrency"
                name="currency"
                value={event.currency}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="USD">USD - US Dollar</option>
                <option value="EUR">EUR - Euro</option>
                <option value="GBP">GBP - British Pound</option>
                <option value="CAD">CAD - Canadian Dollar</option>
                <option value="AUD">AUD - Australian Dollar</option>
                <option value="JPY">JPY - Japanese Yen</option>
                <option value="MXN">MXN - Mexican Peso</option>
                <option value="INR">INR - Indian Rupee</option>
              </select>
            </div>
          </div>

          <!-- DateTime Range -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventStartDateTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Start Date & Time
              </label>
              <input
                type="datetime-local"
                id="eventStartDateTime"
                name="startTime"
                value={startTimeValue}
                required
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label
                for="eventEndDateTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                End Date & Time (Optional)
              </label>
              <input
                type="datetime-local"
                id="eventEndDateTime"
                name="endTime"
                value={endTimeValue}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Timezone & Virtual -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventTimezone"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Timezone
              </label>
              <select
                id="eventTimezone"
                name="timezone"
                value={event.timezone}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="UTC">UTC</option>
                <option value="America/New_York">Eastern Time</option>
                <option value="America/Chicago">Central Time</option>
                <option value="America/Denver">Mountain Time</option>
                <option value="America/Los_Angeles">Pacific Time</option>
                <option value="Europe/London">London</option>
                <option value="Europe/Paris">Paris</option>
                <option value="Asia/Tokyo">Tokyo</option>
                <option value="Australia/Sydney">Sydney</option>
              </select>
            </div>
            <div class="flex items-center gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="eventIsVirtual"
                  name="isVirtual"
                  checked={event.isVirtual}
                  class="w-4 h-4 rounded border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-indigo-600 focus:ring-2 focus:ring-indigo-600"
                />
                <span class="text-sm font-medium text-slate-900 dark:text-white"
                  >Virtual</span
                >
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="eventIsPublic"
                  name="isPublic"
                  checked={event.isPublic}
                  class="w-4 h-4 rounded border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-indigo-600 focus:ring-2 focus:ring-indigo-600"
                />
                <span class="text-sm font-medium text-slate-900 dark:text-white"
                  >Public</span
                >
              </label>
            </div>
          </div>

          <!-- Budget -->
          <div>
            <label
              for="eventBudget"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Budget (Optional)
            </label>
            <div class="relative">
              <span
                class="absolute left-4 top-3 text-slate-600 dark:text-slate-400 font-medium"
                id="budgetSymbol"
              >
                $
              </span>
              <input
                type="number"
                id="eventBudget"
                name="budget"
                step="0.01"
                min="0"
                value={budget}
                placeholder="0.00"
                class="w-full pl-8 pr-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Description -->
          <div>
            <label
              for="eventDescription"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Description (Optional)
            </label>
            <textarea
              id="eventDescription"
              name="description"
              placeholder="Add details about this event..."
              rows="4"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base resize-none"
              >{event.description || ""}</textarea
            >
          </div>

          <!-- Error Message -->
          <div
            id="eventError"
            class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
          >
          </div>

          <!-- Action Buttons -->
          <div
            class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700"
          >
            <a
              href={`/events/${event.id}`}
              class="px-6 py-2 text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium"
            >
              Cancel
            </a>
            <button
              type="submit"
              class="px-6 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium"
            >
              Save Changes
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>

  <script define:vars={{ eventId: id }}>
    // Global theme toggle function accessible from HTML onclick
    window.toggleTheme = function () {
      console.log("🖱️ Theme toggle clicked");

      const html = document.documentElement;
      const isDark = html.classList.contains("dark");
      const icon = document.getElementById("themeIcon");
      const mainDiv = document.querySelector("div.min-h-screen");

      if (isDark) {
        // Switch to LIGHT mode
        console.log("→ Switching to light mode");
        html.classList.remove("dark");
        document.body.style.setProperty(
          "background-color",
          "rgb(255, 255, 255)",
          "important",
        );
        document.body.style.setProperty(
          "color",
          "rgb(15, 23, 42)",
          "important",
        );

        // Clear inline styles from main div
        if (mainDiv) {
          mainDiv.style.backgroundColor = "";
          mainDiv.style.color = "";
        }

        // Remove dark mode styles and apply light mode styles
        let darkStyles = document.getElementById("dynamicDarkStyles");
        if (darkStyles) darkStyles.remove();

        // Inject light mode styles
        if (!document.getElementById("dynamicLightStyles")) {
          const style = document.createElement("style");
          style.id = "dynamicLightStyles";
          style.textContent = `
            html:not(.dark) header {
              background-color: rgb(255, 255, 255) !important;
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) main {
              background-color: rgb(245, 246, 248) !important;
            }
            html:not(.dark) [class*="bg-white"],
            html:not(.dark) [class*="bg-slate-50"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-slate-900"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-slate-600"] {
              color: rgb(71, 85, 105) !important;
            }
            html:not(.dark) [class*="text-slate-400"] {
              color: rgb(148, 163, 184) !important;
            }
            html:not(.dark) [class*="border-slate-200"] {
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) [class*="bg-slate-800"],
            html:not(.dark) [class*="bg-slate-900"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-white"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-indigo-300"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-400"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-600"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-700"] {
              color: rgb(67, 56, 202) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem("theme", "light");
        console.log("✅ Switched to light mode");
        if (icon) icon.textContent = "☀️";
      } else {
        // Switch to DARK mode
        console.log("→ Switching to dark mode");
        html.classList.add("dark");
        document.body.style.setProperty(
          "background-color",
          "rgb(6, 6, 10)",
          "important",
        );
        document.body.style.setProperty(
          "color",
          "rgb(248, 250, 252)",
          "important",
        );

        // Set inline styles on main div for dark mode
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(6, 6, 10)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(248, 250, 252)", "important");
        }

        // Remove light mode styles and apply dark mode styles
        let lightStyles = document.getElementById("dynamicLightStyles");
        if (lightStyles) lightStyles.remove();

        // Inject dark mode styles
        if (!document.getElementById("dynamicDarkStyles")) {
          const style = document.createElement("style");
          style.id = "dynamicDarkStyles";
          style.textContent = `
            html.dark header {
              background-color: rgb(15, 23, 42) !important;
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark main {
              background-color: rgb(6, 6, 10) !important;
            }
            html.dark [class*="bg-white"],
            html.dark [class*="bg-slate-50"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="bg-slate-800"] {
              background-color: rgb(30, 41, 59) !important;
            }
            html.dark [class*="bg-slate-900"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="text-slate-900"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-slate-600"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-slate-400"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-white"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-indigo-300"] {
              color: rgb(165, 180, 252) !important;
            }
            html.dark [class*="text-indigo-400"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-600"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-700"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="border-slate-200"] {
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark [class*="border-slate-700"] {
              border-color: rgb(51, 65, 85) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem("theme", "dark");
        console.log("✅ Switched to dark mode");
        if (icon) icon.textContent = "🌙";
      }
    };

    // Setup theme toggle on page load
    function setupThemeToggle() {
      const btn = document.getElementById("themeToggle");
      const icon = document.getElementById("themeIcon");
      const html = document.documentElement;
      const body = document.body;
      const mainDiv = document.querySelector("div.min-h-screen");

      if (!btn) {
        console.error("❌ Theme toggle button not found");
        return;
      }

      console.log("✅ Theme toggle setup started");

      // Update icon to match current theme on initialization
      const isDark = html.classList.contains("dark");
      if (icon) icon.textContent = isDark ? "🌙" : "☀️";

      // Inject CSS styles for current theme (both light and dark)
      if (isDark && !document.getElementById("dynamicDarkStyles")) {
        // Inject dark mode CSS
        const darkStyle = document.createElement("style");
        darkStyle.id = "dynamicDarkStyles";
        darkStyle.textContent = `
          html.dark header {
            background-color: rgb(15, 23, 42) !important;
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark main {
            background-color: rgb(6, 6, 10) !important;
          }
          html.dark [class*="bg-white"],
          html.dark [class*="bg-slate-50"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="bg-slate-800"] {
            background-color: rgb(30, 41, 59) !important;
          }
          html.dark [class*="bg-slate-900"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="text-slate-900"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-slate-600"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-slate-400"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-white"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-indigo-300"] {
            color: rgb(165, 180, 252) !important;
          }
          html.dark [class*="text-indigo-400"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="text-indigo-600"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="text-indigo-700"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="border-slate-200"] {
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark [class*="border-slate-700"] {
            border-color: rgb(51, 65, 85) !important;
          }
        `;
        document.head.appendChild(darkStyle);
      } else if (!isDark && !document.getElementById("dynamicLightStyles")) {
        // Inject light mode CSS
        const lightStyle = document.createElement("style");
        lightStyle.id = "dynamicLightStyles";
        lightStyle.textContent = `
          html:not(.dark) header {
            background-color: rgb(255, 255, 255) !important;
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) main {
            background-color: rgb(245, 246, 248) !important;
          }
          html:not(.dark) [class*="bg-white"],
          html:not(.dark) [class*="bg-slate-50"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-slate-900"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-slate-600"] {
            color: rgb(71, 85, 105) !important;
          }
          html:not(.dark) [class*="text-slate-400"] {
            color: rgb(148, 163, 184) !important;
          }
          html:not(.dark) [class*="border-slate-200"] {
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) [class*="bg-slate-800"],
          html:not(.dark) [class*="bg-slate-900"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-white"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-indigo-300"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-400"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-600"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-700"] {
            color: rgb(67, 56, 202) !important;
          }
        `;
        document.head.appendChild(lightStyle);
      }

      // Apply inline styles with setProperty to match current theme
      if (isDark) {
        html.style.setProperty("color-scheme", "dark", "important");
        body.style.setProperty(
          "background-color",
          "rgb(6, 6, 10)",
          "important",
        );
        body.style.setProperty("color", "rgb(248, 250, 252)", "important");
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(6, 6, 10)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(248, 250, 252)", "important");
        }
      } else {
        html.style.setProperty("color-scheme", "light", "important");
        body.style.setProperty(
          "background-color",
          "rgb(255, 255, 255)",
          "important",
        );
        body.style.setProperty("color", "rgb(15, 23, 42)", "important");
        if (mainDiv) {
          mainDiv.style.setProperty(
            "background-color",
            "rgb(255, 255, 255)",
            "important",
          );
          mainDiv.style.setProperty("color", "rgb(15, 23, 42)", "important");
        }
      }

      console.log("✅ Theme toggle ready");
    }

    // Initialize theme on page load (wait for DOM to be fully ready)
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupThemeToggle);
    } else {
      setTimeout(setupThemeToggle, 0);
    }

    // Update currency symbol
    const eventCurrencySelect = document.getElementById("eventCurrency");
    const budgetSymbol = document.getElementById("budgetSymbol");
    const currencySymbols = {
      USD: "$",
      EUR: "€",
      GBP: "£",
      CAD: "$",
      AUD: "$",
      JPY: "¥",
      MXN: "$",
      INR: "₹",
    };

    if (eventCurrencySelect) {
      eventCurrencySelect.addEventListener("change", () => {
        const selectedCurrency = eventCurrencySelect.value;
        const symbol = currencySymbols[selectedCurrency] || selectedCurrency;
        if (budgetSymbol) {
          budgetSymbol.textContent = symbol;
        }
      });
    }

    // Form submission
    const editEventForm = document.getElementById("editEventForm");
    const eventError = document.getElementById("eventError");

    if (editEventForm) {
      editEventForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(editEventForm);
        const data = {
          eventId: eventId,
          name: formData.get("name"),
          location: formData.get("location") || undefined,
          startDate: formData.get("startDate") || undefined,
          endDate: formData.get("endDate") || undefined,
          startTime: formData.get("startTime") || undefined,
          endTime: formData.get("endTime") || undefined,
          currency: formData.get("currency"),
          budget: formData.get("budget") || undefined,
          description: formData.get("description") || undefined,
        };

        try {
          const response = await fetch("/api/events/update", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await response.json();

          if (!response.ok) {
            if (eventError) {
              eventError.textContent = result.error || "Failed to update event";
              eventError.classList.remove("hidden");
            }
          } else {
            window.location.href = `/events/${eventId}`;
          }
        } catch (error) {
          if (eventError) {
            eventError.textContent = "An error occurred. Please try again.";
            eventError.classList.remove("hidden");
          }
        }
      });
    }
  </script>
</Layout>
