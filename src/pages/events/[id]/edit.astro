---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import { db } from "../../../db";
import { events, sessions } from "../../../db/schema";
import { eq } from "drizzle-orm";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}

// Get event ID from URL
const { id } = Astro.params;

// Redirect if no ID provided
if (!id) {
  return Astro.redirect("/dashboard");
}

// Get session and verify user
const [session] = await db
  .select()
  .from(sessions)
  .where(eq(sessions.id, sessionId))
  .limit(1);

if (!session || new Date(session.expiresAt) < new Date()) {
  return Astro.redirect("/auth/login");
}

// Get userId from session
const userId = session.userId;

// Get event by ID
const [event] = await db
  .select()
  .from(events)
  .where(eq(events.id, id as string))
  .limit(1);

// Verify event exists and belongs to current user
if (!event || event.creatorId !== session.userId) {
  return Astro.redirect("/dashboard");
}

// Format timestamps for form input (datetime-local expects YYYY-MM-DDTHH:mm format)
const formatDatetimeLocal = (date: string | null | undefined) => {
  if (!date) return "";
  try {
    return new Date(date).toISOString().slice(0, 16);
  } catch {
    return "";
  }
};

const startTimeValue = formatDatetimeLocal(event.startTime?.toString());
const endTimeValue = formatDatetimeLocal(event.endTime?.toString());
const budget = event.budgetCents ? (event.budgetCents / 100).toFixed(2) : "";
---

<Layout title={`Edit ${event.title}`} description="Edit event details">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <Header title={event.title} currentPage="dashboard" />

    <!-- Page Title -->
    <div
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-3 sm:px-6 lg:px-8 py-4 sm:py-6"
    >
      <div class="max-w-7xl mx-auto">
        <h1
          class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-1"
        >
          Edit Event
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
          {event.title}
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main
      class="flex-1 max-w-7xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8"
    >
      <!-- Edit Form Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <form id="editEventForm" class="space-y-4">
          <!-- Event Name -->
          <!-- Event Title -->
          <div>
            <label
              for="eventTitle"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Event Title
            </label>
            <input
              type="text"
              id="eventTitle"
              name="title"
              value={event.title}
              required
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Event Type & Currency Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventType"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Event Type
              </label>
              <select
                id="eventType"
                name="type"
                value={event.type}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="general">General</option>
                <option value="concert">Concert</option>
                <option value="dinner">Formal Dinner</option>
                <option value="sports">Sports</option>
                <option value="movie">Movie</option>
                <option value="trip">Trip</option>
                <option value="wedding">Wedding</option>
              </select>
            </div>
            <div>
              <label
                for="eventCurrency"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Currency
              </label>
              <select
                id="eventCurrency"
                name="currency"
                value={event.currency}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="USD">USD - US Dollar</option>
                <option value="EUR">EUR - Euro</option>
                <option value="GBP">GBP - British Pound</option>
                <option value="CAD">CAD - Canadian Dollar</option>
                <option value="AUD">AUD - Australian Dollar</option>
                <option value="JPY">JPY - Japanese Yen</option>
                <option value="MXN">MXN - Mexican Peso</option>
                <option value="INR">INR - Indian Rupee</option>
              </select>
            </div>
          </div>

          <!-- DateTime Range -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventStartDateTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Start Date & Time
              </label>
              <input
                type="datetime-local"
                id="eventStartDateTime"
                name="startTime"
                value={startTimeValue}
                required
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label
                for="eventEndDateTime"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                End Date & Time (Optional)
              </label>
              <input
                type="datetime-local"
                id="eventEndDateTime"
                name="endTime"
                value={endTimeValue}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Timezone & Virtual -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventTimezone"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Timezone
              </label>
              <select
                id="eventTimezone"
                name="timezone"
                value={event.timezone}
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="UTC">UTC</option>
                <option value="America/New_York">Eastern Time</option>
                <option value="America/Chicago">Central Time</option>
                <option value="America/Denver">Mountain Time</option>
                <option value="America/Los_Angeles">Pacific Time</option>
                <option value="Europe/London">London</option>
                <option value="Europe/Paris">Paris</option>
                <option value="Asia/Tokyo">Tokyo</option>
                <option value="Australia/Sydney">Sydney</option>
              </select>
            </div>
            <div class="flex items-center gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="eventIsVirtual"
                  name="isVirtual"
                  checked={event.isVirtual}
                  class="w-4 h-4 rounded border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-indigo-600 focus:ring-2 focus:ring-indigo-600"
                />
                <span class="text-sm font-medium text-slate-900 dark:text-white"
                  >Virtual</span
                >
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="eventIsPublic"
                  name="isPublic"
                  checked={event.isPublic}
                  class="w-4 h-4 rounded border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-indigo-600 focus:ring-2 focus:ring-indigo-600"
                />
                <span class="text-sm font-medium text-slate-900 dark:text-white"
                  >Public</span
                >
              </label>
            </div>
          </div>

          <!-- Budget -->
          <div>
            <label
              for="eventBudget"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Budget (Optional)
            </label>
            <div class="relative">
              <span
                class="absolute left-4 top-3 text-slate-600 dark:text-slate-400 font-medium"
                id="budgetSymbol"
              >
                $
              </span>
              <input
                type="number"
                id="eventBudget"
                name="budget"
                step="0.01"
                min="0"
                value={budget}
                placeholder="0.00"
                class="w-full pl-8 pr-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Description -->
          <div>
            <label
              for="eventDescription"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Description (Optional)
            </label>
            <textarea
              id="eventDescription"
              name="description"
              placeholder="Add details about this event..."
              rows="4"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base resize-none"
              >{event.description || ""}</textarea
            >
          </div>

          <!-- Details/Metadata Section -->
          <div>
            <label
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Event Details (Location, Venue, Contact, etc.)
            </label>
            <div id="metadataContainer" class="space-y-3">
              <!-- Dynamic metadata fields will be added here -->
            </div>
            <button
              type="button"
              id="addMetadataFieldBtn"
              class="mt-3 px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium text-sm"
            >
              + Add Detail
            </button>
          </div>

          <!-- Add Expense Button -->
          <div class="pt-4 border-t border-slate-200 dark:border-slate-700">
            <button
              type="button"
              id="addExpenseBtn"
              class="inline-flex items-center px-4 py-2.5 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium text-sm"
            >
              💰 Add Expense
            </button>
          </div>

          <!-- Error Message -->
          <div
            id="eventError"
            class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
          >
          </div>

          <!-- Action Buttons -->
          <div
            class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700"
          >
            <a
              href={`/events/${event.id}`}
              class="px-6 py-2 text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium"
            >
              Cancel
            </a>
            <button
              type="submit"
              class="px-6 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium"
            >
              Save Changes
            </button>
          </div>
        </form>
      </div>
    </main>

    <!-- Add Event Expense Modal -->
    <div
      id="addEventExpenseModal"
      class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
    >
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-md border border-slate-200 dark:border-slate-700 my-8"
      >
        <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
          <h2
            class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white"
          >
            Add Event Expense
          </h2>
        </div>

        <form id="addEventExpenseForm" class="p-5 sm:p-6 space-y-4">
          <div>
            <label
              for="expenseDescription"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Description
            </label>
            <input
              type="text"
              id="expenseDescription"
              name="description"
              placeholder="e.g., Venue rental, Catering, Decorations"
              required
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-600 text-base"
            />
          </div>

          <div>
            <label
              for="expenseCategory"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Category
            </label>
            <select
              id="expenseCategory"
              name="category"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-600 text-base"
            >
              <option value="meal">Meal / Food</option>
              <option value="transport">Transport</option>
              <option value="accommodation">Accommodation</option>
              <option value="parking">Parking</option>
              <option value="entertainment">Entertainment</option>
              <option value="tickets">Tickets</option>
              <option value="misc" selected>Miscellaneous</option>
            </select>
          </div>

          <div>
            <label
              for="expenseAmount"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Amount ($)
            </label>
            <input
              type="number"
              id="expenseAmount"
              name="amount"
              step="0.01"
              min="0"
              placeholder="0.00"
              required
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-600 text-base"
            />
          </div>

          <div
            id="expenseError"
            class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
          >
          </div>

          <div
            class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700"
          >
            <button
              type="button"
              id="cancelExpenseBtn"
              class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-lg transition-colors font-medium text-sm"
            >
              Add Expense
            </button>
          </div>
        </form>
      </div>
    </div>

    <script define:vars={{ eventId: id, userId, event }}>
      // Add Expense Modal
      const addExpenseBtn = document.getElementById("addExpenseBtn");
      const addEventExpenseModal = document.getElementById(
        "addEventExpenseModal",
      );
      const cancelExpenseBtn = document.getElementById("cancelExpenseBtn");
      const addEventExpenseForm = document.getElementById(
        "addEventExpenseForm",
      );
      const expenseError = document.getElementById("expenseError");

      if (addExpenseBtn) {
        addExpenseBtn.addEventListener("click", () => {
          addEventExpenseModal.classList.remove("hidden");
        });
      }

      if (cancelExpenseBtn) {
        cancelExpenseBtn.addEventListener("click", () => {
          addEventExpenseModal.classList.add("hidden");
          addEventExpenseForm.reset();
          expenseError.classList.add("hidden");
        });
      }

      // Close modal when clicking outside
      if (addEventExpenseModal) {
        addEventExpenseModal.addEventListener("click", (e) => {
          if (e.target === addEventExpenseModal) {
            addEventExpenseModal.classList.add("hidden");
            addEventExpenseForm.reset();
            expenseError.classList.add("hidden");
          }
        });
      }

      // Add Expense Form Submission
      if (addEventExpenseForm) {
        addEventExpenseForm.addEventListener("submit", async (e) => {
          e.preventDefault();

          // First, get the event to get groupId
          try {
            const eventResponse = await fetch(`/api/events/${eventId}`);
            if (!eventResponse.ok) {
              expenseError.textContent =
                "Could not fetch event details. Please try again.";
              expenseError.classList.remove("hidden");
              return;
            }

            const eventData = await eventResponse.json();
            const groupId = eventData.event.groupId;

            if (!groupId) {
              expenseError.textContent =
                "This event doesn't have a group assigned yet. Please assign a group first.";
              expenseError.classList.remove("hidden");
              return;
            }

            // Get form data
            const formData = new FormData(addEventExpenseForm);
            const amount = parseFloat(formData.get("amount")) || 0;

            if (amount <= 0) {
              expenseError.textContent = "Amount must be greater than 0";
              expenseError.classList.remove("hidden");
              return;
            }

            // Create expense
            const expenseResponse = await fetch("/api/expenses/create", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                groupId: groupId,
                description: formData.get("description"),
                category: formData.get("category") || "misc",
                amount: Math.round(amount * 100),
                paidBy: userId,
              }),
            });

            if (!expenseResponse.ok) {
              const error = await expenseResponse.json();
              expenseError.textContent =
                error.error || "Failed to create expense";
              expenseError.classList.remove("hidden");
              return;
            }

            // Success
            showToast(`Expense of $${amount.toFixed(2)} added successfully!`);
            addEventExpenseModal.classList.add("hidden");
            addEventExpenseForm.reset();
            expenseError.classList.add("hidden");
          } catch (error) {
            console.error("Error:", error);
            expenseError.textContent = "An error occurred. Please try again.";
            expenseError.classList.remove("hidden");
          }
        });
      }

      // Global theme toggle function accessible from HTML onclick
      window.toggleTheme = function () {
        console.log("🖱️ Theme toggle clicked");

        const html = document.documentElement;
        const isDark = html.classList.contains("dark");
        const icon = document.getElementById("themeIcon");
        const mainDiv = document.querySelector("div.min-h-screen");

        if (isDark) {
          // Switch to LIGHT mode
          console.log("→ Switching to light mode");
          html.classList.remove("dark");
          document.body.style.setProperty(
            "background-color",
            "rgb(255, 255, 255)",
            "important",
          );
          document.body.style.setProperty(
            "color",
            "rgb(15, 23, 42)",
            "important",
          );

          // Clear inline styles from main div
          if (mainDiv) {
            mainDiv.style.backgroundColor = "";
            mainDiv.style.color = "";
          }

          // Remove dark mode styles and apply light mode styles
          let darkStyles = document.getElementById("dynamicDarkStyles");
          if (darkStyles) darkStyles.remove();

          // Inject light mode styles
          if (!document.getElementById("dynamicLightStyles")) {
            const style = document.createElement("style");
            style.id = "dynamicLightStyles";
            style.textContent = `
            html:not(.dark) header {
              background-color: rgb(255, 255, 255) !important;
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) main {
              background-color: rgb(245, 246, 248) !important;
            }
            html:not(.dark) [class*="bg-white"],
            html:not(.dark) [class*="bg-slate-50"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-slate-900"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-slate-600"] {
              color: rgb(71, 85, 105) !important;
            }
            html:not(.dark) [class*="text-slate-400"] {
              color: rgb(148, 163, 184) !important;
            }
            html:not(.dark) [class*="border-slate-200"] {
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) [class*="bg-slate-800"],
            html:not(.dark) [class*="bg-slate-900"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-white"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-indigo-300"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-400"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-600"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-700"] {
              color: rgb(67, 56, 202) !important;
            }
          `;
            document.head.appendChild(style);
          }

          localStorage.setItem("theme", "light");
          console.log("✅ Switched to light mode");
          if (icon) icon.textContent = "☀️";
        } else {
          // Switch to DARK mode
          console.log("→ Switching to dark mode");
          html.classList.add("dark");
          document.body.style.setProperty(
            "background-color",
            "rgb(6, 6, 10)",
            "important",
          );
          document.body.style.setProperty(
            "color",
            "rgb(248, 250, 252)",
            "important",
          );

          // Set inline styles on main div for dark mode
          if (mainDiv) {
            mainDiv.style.setProperty(
              "background-color",
              "rgb(6, 6, 10)",
              "important",
            );
            mainDiv.style.setProperty(
              "color",
              "rgb(248, 250, 252)",
              "important",
            );
          }

          // Remove light mode styles and apply dark mode styles
          let lightStyles = document.getElementById("dynamicLightStyles");
          if (lightStyles) lightStyles.remove();

          // Inject dark mode styles
          if (!document.getElementById("dynamicDarkStyles")) {
            const style = document.createElement("style");
            style.id = "dynamicDarkStyles";
            style.textContent = `
            html.dark header {
              background-color: rgb(15, 23, 42) !important;
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark main {
              background-color: rgb(6, 6, 10) !important;
            }
            html.dark [class*="bg-white"],
            html.dark [class*="bg-slate-50"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="bg-slate-800"] {
              background-color: rgb(30, 41, 59) !important;
            }
            html.dark [class*="bg-slate-900"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="text-slate-900"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-slate-600"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-slate-400"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-white"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-indigo-300"] {
              color: rgb(165, 180, 252) !important;
            }
            html.dark [class*="text-indigo-400"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-600"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-700"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="border-slate-200"] {
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark [class*="border-slate-700"] {
              border-color: rgb(51, 65, 85) !important;
            }
          `;
            document.head.appendChild(style);
          }

          localStorage.setItem("theme", "dark");
          console.log("✅ Switched to dark mode");
          if (icon) icon.textContent = "🌙";
        }
      };

      // Setup theme toggle on page load
      function setupThemeToggle() {
        const btn = document.getElementById("themeToggle");
        const icon = document.getElementById("themeIcon");
        const html = document.documentElement;
        const body = document.body;
        const mainDiv = document.querySelector("div.min-h-screen");

        if (!btn) {
          console.error("❌ Theme toggle button not found");
          return;
        }

        console.log("✅ Theme toggle setup started");

        // Update icon to match current theme on initialization
        const isDark = html.classList.contains("dark");
        if (icon) icon.textContent = isDark ? "🌙" : "☀️";

        // Inject CSS styles for current theme (both light and dark)
        if (isDark && !document.getElementById("dynamicDarkStyles")) {
          // Inject dark mode CSS
          const darkStyle = document.createElement("style");
          darkStyle.id = "dynamicDarkStyles";
          darkStyle.textContent = `
          html.dark header {
            background-color: rgb(15, 23, 42) !important;
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark main {
            background-color: rgb(6, 6, 10) !important;
          }
          html.dark [class*="bg-white"],
          html.dark [class*="bg-slate-50"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="bg-slate-800"] {
            background-color: rgb(30, 41, 59) !important;
          }
          html.dark [class*="bg-slate-900"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="text-slate-900"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-slate-600"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-slate-400"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-white"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-indigo-300"] {
            color: rgb(165, 180, 252) !important;
          }
          html.dark [class*="text-indigo-400"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="text-indigo-600"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="text-indigo-700"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="border-slate-200"] {
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark [class*="border-slate-700"] {
            border-color: rgb(51, 65, 85) !important;
          }
        `;
          document.head.appendChild(darkStyle);
        } else if (!isDark && !document.getElementById("dynamicLightStyles")) {
          // Inject light mode CSS
          const lightStyle = document.createElement("style");
          lightStyle.id = "dynamicLightStyles";
          lightStyle.textContent = `
          html:not(.dark) header {
            background-color: rgb(255, 255, 255) !important;
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) main {
            background-color: rgb(245, 246, 248) !important;
          }
          html:not(.dark) [class*="bg-white"],
          html:not(.dark) [class*="bg-slate-50"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-slate-900"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-slate-600"] {
            color: rgb(71, 85, 105) !important;
          }
          html:not(.dark) [class*="text-slate-400"] {
            color: rgb(148, 163, 184) !important;
          }
          html:not(.dark) [class*="border-slate-200"] {
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) [class*="bg-slate-800"],
          html:not(.dark) [class*="bg-slate-900"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-white"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-indigo-300"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-400"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-600"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-700"] {
            color: rgb(67, 56, 202) !important;
          }
        `;
          document.head.appendChild(lightStyle);
        }

        // Apply inline styles with setProperty to match current theme
        if (isDark) {
          html.style.setProperty("color-scheme", "dark", "important");
          body.style.setProperty(
            "background-color",
            "rgb(6, 6, 10)",
            "important",
          );
          body.style.setProperty("color", "rgb(248, 250, 252)", "important");
          if (mainDiv) {
            mainDiv.style.setProperty(
              "background-color",
              "rgb(6, 6, 10)",
              "important",
            );
            mainDiv.style.setProperty(
              "color",
              "rgb(248, 250, 252)",
              "important",
            );
          }
        } else {
          html.style.setProperty("color-scheme", "light", "important");
          body.style.setProperty(
            "background-color",
            "rgb(255, 255, 255)",
            "important",
          );
          body.style.setProperty("color", "rgb(15, 23, 42)", "important");
          if (mainDiv) {
            mainDiv.style.setProperty(
              "background-color",
              "rgb(255, 255, 255)",
              "important",
            );
            mainDiv.style.setProperty("color", "rgb(15, 23, 42)", "important");
          }
        }

        console.log("✅ Theme toggle ready");
      }

      // Initialize theme on page load (wait for DOM to be fully ready)
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupThemeToggle);
      } else {
        setTimeout(setupThemeToggle, 0);
      }

      // Update currency symbol
      const eventCurrencySelect = document.getElementById("eventCurrency");

      // Toast notification helper
      const toast = document.getElementById("toast");
      const toastMessage = document.getElementById("toast-message");

      function showToast(message) {
        if (!toast || !toastMessage) return;
        toastMessage.textContent = message;
        toast.classList.remove("opacity-0");
        setTimeout(() => {
          toast.classList.add("opacity-0");
        }, 3000);
      }
      const budgetSymbol = document.getElementById("budgetSymbol");
      const currencySymbols = {
        USD: "$",
        EUR: "€",
        GBP: "£",
        CAD: "$",
        AUD: "$",
        JPY: "¥",
        MXN: "$",
        INR: "₹",
      };

      if (eventCurrencySelect) {
        eventCurrencySelect.addEventListener("change", () => {
          const selectedCurrency = eventCurrencySelect.value;
          const symbol = currencySymbols[selectedCurrency] || selectedCurrency;
          if (budgetSymbol) {
            budgetSymbol.textContent = symbol;
          }
        });
      }

      // Form submission
      const editEventForm = document.getElementById("editEventForm");
      const eventError = document.getElementById("eventError");

      // Metadata field handlers
      function addMetadataField(key = "", value = "") {
        const container = document.getElementById("metadataContainer");
        const fieldId = "metadata-" + Date.now() + Math.random();
        const fieldHTML = `
          <div class="flex gap-2" id="${fieldId}">
            <input
              type="text"
              name="metadataKey"
              placeholder="Key (e.g., Venue Name)"
              value="${key}"
              class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
            />
            <input
              type="text"
              name="metadataValue"
              placeholder="Value (e.g., Grand Ballroom)"
              value="${value}"
              class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
            />
            <button
              type="button"
              onclick="document.getElementById('${fieldId}').remove()"
              class="px-3 py-2 bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-200 rounded-lg hover:bg-red-200 dark:hover:bg-red-800 transition-colors text-sm font-medium"
            >
              ✕
            </button>
          </div>
        `;
        container.insertAdjacentHTML("beforeend", fieldHTML);
      }

      const addMetadataFieldBtn = document.getElementById(
        "addMetadataFieldBtn",
      );
      if (addMetadataFieldBtn) {
        addMetadataFieldBtn.addEventListener("click", (e) => {
          e.preventDefault();
          addMetadataField();
        });
      }

      // Load existing metadata
      function loadMetadata() {
        if (event && event.metadata && typeof event.metadata === "object") {
          Object.entries(event.metadata).forEach(([key, value]) => {
            addMetadataField(key, String(value));
          });
        }
      }

      loadMetadata();

      if (editEventForm) {
        editEventForm.addEventListener("submit", async (e) => {
          e.preventDefault();

          const formData = new FormData(editEventForm);

          // Collect metadata
          const metadata = {};
          const metadataKeys = formData.getAll("metadataKey");
          const metadataValues = formData.getAll("metadataValue");

          for (let i = 0; i < metadataKeys.length; i++) {
            const key = metadataKeys[i]?.trim();
            const value = metadataValues[i]?.trim();
            if (key && value) {
              metadata[key] = value;
            }
          }

          const data = {
            eventId: eventId,
            title: formData.get("title"),
            type: formData.get("type"),
            startTime: formData.get("startTime") || undefined,
            endTime: formData.get("endTime") || undefined,
            timezone: formData.get("timezone"),
            isVirtual:
              document.getElementById("eventIsVirtual")?.checked || false,
            isPublic:
              document.getElementById("eventIsPublic")?.checked || false,
            currency: formData.get("currency"),
            budget: formData.get("budget") || undefined,
            description: formData.get("description") || undefined,
            metadata: Object.keys(metadata).length > 0 ? metadata : {},
          };

          try {
            const response = await fetch("/api/events/update", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(data),
            });

            const result = await response.json();

            if (!response.ok) {
              if (eventError) {
                eventError.textContent =
                  result.error || "Failed to update event";
                eventError.classList.remove("hidden");
              }
            } else {
              showToast("Event updated successfully!");
              setTimeout(() => {
                window.location.href = `/events/${eventId}`;
              }, 1500);
            }
          } catch (error) {
            if (eventError) {
              eventError.textContent = "An error occurred. Please try again.";
              eventError.classList.remove("hidden");
            }
          }
        });
      }
    </script>
    <!-- Toast Notification -->
    <div
      id="toast"
      class="fixed bottom-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none z-50 max-w-xs"
    >
      <span id="toast-message"></span>
    </div>
  </div></Layout
>
