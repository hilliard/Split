---
import { getSession } from '../../utils/session';
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { sessions } from '../../db/schema';
import { eq } from 'drizzle-orm';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

const session = await getSession(sessionId);
if (!session) {
  Astro.cookies.delete('sessionId', { path: '/' });
  return Astro.redirect('/auth/login');
}


---

<Layout
  title="Create Event"
  description="Create a new event for expense tracking"
  currentPage="dashboard"
>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Page Title -->
    <div
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-3 sm:px-6 lg:px-8 py-4 sm:py-6"
    >
      <div class="max-w-4xl mx-auto">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-1">
          Create New Event
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
          Set up a new event to track expenses with your friends
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <!-- Create Form Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <form id="createEventForm" class="space-y-4">
          <!-- Event Title -->
          <div>
            <label
              for="eventTitle"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Event Title <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="eventTitle"
              name="title"
              required
              placeholder="e.g., Team Dinner, Weekend Trip"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Event Type & Currency Row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventType"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Event Type
              </label>
              <select
                id="eventType"
                name="type"
                value="general"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="general">General</option>
                <option value="concert">Concert</option>
                <option value="dinner">Formal Dinner</option>
                <option value="sports">Sports</option>
                <option value="movie">Movie</option>
                <option value="trip">Trip</option>
                <option value="wedding">Wedding</option>
              </select>
            </div>
            <div>
              <label
                for="eventCurrency"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Currency
              </label>
              <select
                id="eventCurrency"
                name="currency"
                value="USD"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="USD">USD - US Dollar</option>
                <option value="EUR">EUR - Euro</option>
                <option value="GBP">GBP - British Pound</option>
                <option value="CAD">CAD - Canadian Dollar</option>
                <option value="AUD">AUD - Australian Dollar</option>
                <option value="JPY">JPY - Japanese Yen</option>
                <option value="MXN">MXN - Mexican Peso</option>
                <option value="INR">INR - Indian Rupee</option>
              </select>
            </div>
          </div>

          <!-- DateTime Range -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Start Date & Time <span class="text-red-500">*</span>
              </label>
              <div class="flex gap-2">
                <input
                  type="date"
                  id="eventStartDate"
                  name="startDate"
                  required
                  class="w-1/2 px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
                <input
                  type="time"
                  id="eventStartTime"
                  name="startTime"
                  required
                  class="w-1/2 px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
              </div>
            </div>
            <div>
              <label
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                End Date & Time (Optional)
              </label>
              <div class="flex gap-2">
                <input
                  type="date"
                  id="eventEndDate"
                  name="endDate"
                  class="w-1/2 px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
                <input
                  type="time"
                  id="eventEndTime"
                  name="endTime"
                  class="w-1/2 px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
              </div>
            </div>
          </div>

          <!-- Timezone & Virtual -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="eventTimezone"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Timezone
              </label>
              <select
                id="eventTimezone"
                name="timezone"
                value="UTC"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="UTC">UTC</option>
                <option value="America/New_York">Eastern Time</option>
                <option value="America/Chicago">Central Time</option>
                <option value="America/Denver">Mountain Time</option>
                <option value="America/Los_Angeles">Pacific Time</option>
                <option value="Europe/London">London</option>
                <option value="Europe/Paris">Paris</option>
                <option value="Asia/Tokyo">Tokyo</option>
                <option value="Australia/Sydney">Sydney</option>
              </select>
            </div>
            <div class="flex items-center gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="eventIsVirtual"
                  name="isVirtual"
                  class="w-4 h-4 rounded border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-indigo-600 focus:ring-2 focus:ring-indigo-600"
                />
                <span class="text-sm font-medium text-slate-900 dark:text-white">Virtual Event</span
                >
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="eventIsPublic"
                  name="isPublic"
                  checked
                  class="w-4 h-4 rounded border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-indigo-600 focus:ring-2 focus:ring-indigo-600"
                />
                <span class="text-sm font-medium text-slate-900 dark:text-white">Public</span>
              </label>
            </div>
          </div>

          <!-- Budget -->
          <div>
            <label
              for="eventBudget"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Total Budget (Optional)
            </label>
            <div class="flex items-center gap-2">
              <span id="budgetSymbol" class="text-lg font-semibold text-slate-900 dark:text-white"
                >$</span
              >
              <input
                type="number"
                id="eventBudget"
                name="budget"
                step="0.01"
                min="0"
                placeholder="0.00"
                class="flex-1 px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
          </div>

          <!-- Description -->
          <div>
            <label
              for="eventDescription"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Description (Optional)
            </label>
            <textarea
              id="eventDescription"
              name="description"
              rows="4"
              placeholder="Add any notes about this event..."
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            ></textarea>
          </div>

          <!-- Group Selection / Creation (Top-Level) -->
          <div class="pt-4 border-t border-slate-200 dark:border-slate-700">
            <div>
              <label
                for="expenseGroupSelect"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Associate Event with Group (Optional)
              </label>
              <div class="flex gap-2 flex-col sm:flex-row">
                <select
                  id="expenseGroupSelect"
                  name="groupId"
                  class="flex-1 px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                >
                  <option value="">-- No Group (Personal Event) --</option>
                </select>
                <button
                  type="button"
                  id="createNewGroupBtn"
                  class="px-4 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium whitespace-nowrap"
                >
                  + New Group
                </button>
              </div>
            </div>

            <!-- Create New Group Form (Hidden) -->
            <div
              id="createNewGroupForm"
              class="hidden mt-3 p-3 bg-white dark:bg-slate-600 rounded-lg border border-indigo-300 dark:border-slate-500 space-y-3"
            >
              <label
                for="newGroupName"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                New Group Name
              </label>
              <input
                type="text"
                id="newGroupName"
                name="newGroupName"
                placeholder="e.g., Houston Trip Friends"
                class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
              <div class="flex gap-2">
                <button
                  type="button"
                  id="createGroupConfirmBtn"
                  class="flex-1 px-3 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded transition-colors font-medium text-sm"
                >
                  Create Group
                </button>
                <button
                  type="button"
                  id="createGroupCancelBtn"
                  class="flex-1 px-3 py-2 bg-slate-300 dark:bg-slate-500 text-slate-900 dark:text-white hover:bg-slate-400 dark:hover:bg-slate-600 rounded transition-colors font-medium text-sm"
                >
                  Cancel
                </button>
              </div>
              <div id="groupCreationError" class="text-sm text-red-600 dark:text-red-400 hidden">
              </div>
            </div>
          </div>

          <!-- Add Initial Expense Toggle -->
          <div
            class="p-4 bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900 dark:to-emerald-900 border-2 border-green-400 dark:border-emerald-600 rounded-lg"
          >
            <label class="flex items-center gap-4 cursor-pointer">
              <!-- Toggle Switch -->
              <div
                class="relative inline-block w-14 h-8 bg-gray-300 dark:bg-gray-600 rounded-full transition-colors"
                id="toggleInitialExpenseSwitch"
              >
                <div
                  class="absolute top-1 left-1 w-6 h-6 bg-white dark:bg-slate-200 rounded-full shadow-md transition-transform translate-x-0"
                  id="toggleInitialExpenseThumb"
                >
                </div>
              </div>

              <input
                type="checkbox"
                id="addInitialExpense"
                name="addInitialExpense"
                class="hidden"
              />

              <div>
                <p
                  class="text-sm font-bold text-green-900 dark:text-green-100"
                  id="toggleInitialExpenseLabel"
                >
                  ○ Add Initial Expense
                </p>
                <p class="text-xs text-green-700 dark:text-green-300">
                  Quickly log your first expense for this event
                </p>
              </div>
            </label>
          </div>

          <!-- Expense Fields (Hidden by default) -->
          <div
            id="initialExpenseFieldsContainer"
            class="hidden space-y-4 p-4 bg-green-50 dark:bg-slate-700 rounded-lg border border-green-200 dark:border-slate-600"
          >

            <!-- Expense Fields -->
            <div>
              <label
                for="initialExpenseDescription"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Expense Description
              </label>
              <input
                type="text"
                id="initialExpenseDescription"
                name="initialExpenseDescription"
                placeholder="e.g., Flight, Restaurant, Transportation, etc."
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              />
            </div>

            <div>
              <label
                for="initialExpenseAmount"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Amount <span class="text-red-500">*</span>
              </label>
              <input
                type="number"
                id="initialExpenseAmount"
                name="initialExpenseAmount"
                step="0.01"
                min="0"
                placeholder="0.00"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              />
            </div>
          </div>

          <!-- Error Message -->
          <div
            id="eventError"
            class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
          >
          </div>

          <!-- Action Buttons -->
          <div class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700">
            <a
              href="/dashboard"
              class="px-6 py-2 text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium"
            >
              Cancel
            </a>
            <button
              type="submit"
              class="px-6 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium"
            >
              Create Event
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>

  <script>
    // Declare window extension for TypeScript
    declare global {
      interface Window {
        toggleTheme?: () => void;
      }
    }

    // Global theme toggle function accessible from HTML onclick
    window.toggleTheme = function () {
      console.log('🖱️ Theme toggle clicked');

      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      const icon = document.getElementById('themeIcon');
      const mainDiv = document.querySelector('div.min-h-screen') as HTMLElement | null;

      if (isDark) {
        // Switch to LIGHT mode
        console.log('→ Switching to light mode');
        html.classList.remove('dark');
        document.body.style.setProperty('background-color', 'rgb(255, 255, 255)', 'important');
        document.body.style.setProperty('color', 'rgb(15, 23, 42)', 'important');

        // Clear inline styles from main div
        if (mainDiv) {
          mainDiv.style.backgroundColor = '';
          mainDiv.style.color = '';
        }

        // Remove dark mode styles and apply light mode styles
        let darkStyles = document.getElementById('dynamicDarkStyles');
        if (darkStyles) darkStyles.remove();

        // Inject light mode styles
        if (!document.getElementById('dynamicLightStyles')) {
          const style = document.createElement('style');
          style.id = 'dynamicLightStyles';
          style.textContent = `
            html:not(.dark) header {
              background-color: rgb(255, 255, 255) !important;
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) main {
              background-color: rgb(245, 246, 248) !important;
            }
            html:not(.dark) [class*="bg-white"],
            html:not(.dark) [class*="bg-slate-50"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-slate-900"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-slate-600"] {
              color: rgb(71, 85, 105) !important;
            }
            html:not(.dark) [class*="text-slate-400"] {
              color: rgb(148, 163, 184) !important;
            }
            html:not(.dark) [class*="border-slate-200"] {
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) [class*="bg-slate-800"],
            html:not(.dark) [class*="bg-slate-900"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-white"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-indigo-300"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-400"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-600"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-700"] {
              color: rgb(67, 56, 202) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem('theme', 'light');
        console.log('✅ Switched to light mode');
        if (icon) icon.textContent = '☀️';
      } else {
        // Switch to DARK mode
        console.log('→ Switching to dark mode');
        html.classList.add('dark');
        document.body.style.setProperty('background-color', 'rgb(6, 6, 10)', 'important');
        document.body.style.setProperty('color', 'rgb(248, 250, 252)', 'important');

        // Set inline styles on main div for dark mode
        if (mainDiv) {
          mainDiv.style.setProperty('background-color', 'rgb(6, 6, 10)', 'important');
          mainDiv.style.setProperty('color', 'rgb(248, 250, 252)', 'important');
        }

        // Remove light mode styles and apply dark mode styles
        let lightStyles = document.getElementById('dynamicLightStyles');
        if (lightStyles) lightStyles.remove();

        // Inject dark mode styles
        if (!document.getElementById('dynamicDarkStyles')) {
          const style = document.createElement('style');
          style.id = 'dynamicDarkStyles';
          style.textContent = `
            html.dark header {
              background-color: rgb(15, 23, 42) !important;
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark main {
              background-color: rgb(6, 6, 10) !important;
            }
            html.dark [class*="bg-white"],
            html.dark [class*="bg-slate-50"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="bg-slate-800"] {
              background-color: rgb(30, 41, 59) !important;
            }
            html.dark [class*="bg-slate-900"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="text-slate-900"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-slate-600"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-slate-400"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-white"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-indigo-300"] {
              color: rgb(165, 180, 252) !important;
            }
            html.dark [class*="text-indigo-400"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-600"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-700"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="border-slate-200"] {
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark [class*="border-slate-700"] {
              border-color: rgb(51, 65, 85) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem('theme', 'dark');
        console.log('✅ Switched to dark mode');
        if (icon) icon.textContent = '🌙';
      }
    };

    // Setup theme toggle on page load
    function setupThemeToggle() {
      const btn = document.getElementById('themeToggle');
      const icon = document.getElementById('themeIcon');
      const html = document.documentElement;
      const body = document.body;
      const mainDiv = document.querySelector('div.min-h-screen') as HTMLElement | null;

      if (!btn) {
        console.error('❌ Theme toggle button not found');
        return;
      }

      console.log('✅ Theme toggle setup started');

      // Update icon to match current theme on initialization
      const isDark = html.classList.contains('dark');
      if (icon) icon.textContent = isDark ? '🌙' : '☀️';

      // Inject CSS styles for current theme (both light and dark)
      if (isDark && !document.getElementById('dynamicDarkStyles')) {
        // Inject dark mode CSS
        const darkStyle = document.createElement('style');
        darkStyle.id = 'dynamicDarkStyles';
        darkStyle.textContent = `
          html.dark header {
            background-color: rgb(15, 23, 42) !important;
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark main {
            background-color: rgb(6, 6, 10) !important;
          }
          html.dark [class*="bg-white"],
          html.dark [class*="bg-slate-50"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="bg-slate-800"] {
            background-color: rgb(30, 41, 59) !important;
          }
          html.dark [class*="bg-slate-900"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="text-slate-900"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-slate-600"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-slate-400"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-white"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="border-slate-200"] {
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark [class*="border-slate-700"] {
            border-color: rgb(51, 65, 85) !important;
          }
        `;
        document.head.appendChild(darkStyle);
      } else if (!isDark && !document.getElementById('dynamicLightStyles')) {
        // Inject light mode CSS
        const lightStyle = document.createElement('style');
        lightStyle.id = 'dynamicLightStyles';
        lightStyle.textContent = `
          html:not(.dark) header {
            background-color: rgb(255, 255, 255) !important;
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) main {
            background-color: rgb(245, 246, 248) !important;
          }
          html:not(.dark) [class*="bg-white"],
          html:not(.dark) [class*="bg-slate-50"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-slate-900"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-slate-600"] {
            color: rgb(71, 85, 105) !important;
          }
          html:not(.dark) [class*="text-slate-400"] {
            color: rgb(148, 163, 184) !important;
          }
          html:not(.dark) [class*="border-slate-200"] {
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) [class*="bg-slate-800"],
          html:not(.dark) [class*="bg-slate-900"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-white"] {
            color: rgb(15, 23, 42) !important;
          }
        `;
        document.head.appendChild(lightStyle);
      }

      // Apply inline styles with setProperty to match current theme
      if (isDark) {
        html.style.setProperty('color-scheme', 'dark', 'important');
        body.style.setProperty('background-color', 'rgb(6, 6, 10)', 'important');
        body.style.setProperty('color', 'rgb(248, 250, 252)', 'important');
        if (mainDiv) {
          mainDiv.style.setProperty('background-color', 'rgb(6, 6, 10)', 'important');
          mainDiv.style.setProperty('color', 'rgb(248, 250, 252)', 'important');
        }
      } else {
        html.style.setProperty('color-scheme', 'light', 'important');
        body.style.setProperty('background-color', 'rgb(255, 255, 255)', 'important');
        body.style.setProperty('color', 'rgb(15, 23, 42)', 'important');
        if (mainDiv) {
          mainDiv.style.setProperty('background-color', 'rgb(255, 255, 255)', 'important');
          mainDiv.style.setProperty('color', 'rgb(15, 23, 42)', 'important');
        }
      }

      console.log('✅ Theme toggle ready');
    }

    // Initialize theme on page load (wait for DOM to be fully ready)
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupThemeToggle);
    } else {
      setTimeout(setupThemeToggle, 0);
    }

    // Update currency symbol
    const eventCurrencySelect = document.getElementById(
      'eventCurrency'
    ) as HTMLSelectElement | null;
    const budgetSymbol = document.getElementById('budgetSymbol') as HTMLElement | null;
    const currencySymbols: { [key: string]: string } = {
      USD: '$',
      EUR: '€',
      GBP: '£',
      CAD: '$',
      AUD: '$',
      JPY: '¥',
      MXN: '$',
      INR: '₹',
    };

    if (eventCurrencySelect) {
      eventCurrencySelect.addEventListener('change', () => {
        const selectedCurrency = (eventCurrencySelect as HTMLSelectElement).value;
        const symbol = currencySymbols[selectedCurrency] || selectedCurrency;
        if (budgetSymbol) {
          budgetSymbol.textContent = symbol;
        }
      });
    }

    // Form submission
    const createEventForm = document.getElementById('createEventForm') as HTMLFormElement | null;
    const eventError = document.getElementById('eventError') as HTMLElement | null;

    // Expense Toggle Handler
    const addInitialExpenseCheckbox = document.getElementById(
      'addInitialExpense'
    ) as HTMLInputElement | null;
    const toggleInitialExpenseSwitch = document.getElementById(
      'toggleInitialExpenseSwitch'
    ) as HTMLElement | null;
    const toggleInitialExpenseThumb = document.getElementById(
      'toggleInitialExpenseThumb'
    ) as HTMLElement | null;
    const toggleInitialExpenseLabel = document.getElementById(
      'toggleInitialExpenseLabel'
    ) as HTMLElement | null;
    const initialExpenseFieldsContainer = document.getElementById(
      'initialExpenseFieldsContainer'
    ) as HTMLElement | null;

    function updateExpenseToggleState() {
      const isChecked = (addInitialExpenseCheckbox as HTMLInputElement)?.checked ?? false;

      if (isChecked) {
        // Checked state
        toggleInitialExpenseSwitch?.classList.remove('bg-gray-300', 'dark:bg-gray-600');
        toggleInitialExpenseSwitch?.classList.add('bg-green-500', 'dark:bg-green-600');
        toggleInitialExpenseThumb?.classList.remove('translate-x-0');
        toggleInitialExpenseThumb?.classList.add('translate-x-6');
        if (toggleInitialExpenseLabel)
          toggleInitialExpenseLabel.textContent = '✓ Add Initial Expense';
        toggleInitialExpenseLabel?.classList.remove('text-gray-700');
        toggleInitialExpenseLabel?.classList.add('text-green-900', 'dark:text-green-100');
        initialExpenseFieldsContainer?.classList.remove('hidden');
      } else {
        // Unchecked state
        toggleInitialExpenseSwitch?.classList.remove('bg-green-500', 'dark:bg-green-600');
        toggleInitialExpenseSwitch?.classList.add('bg-gray-300', 'dark:bg-gray-600');
        toggleInitialExpenseThumb?.classList.remove('translate-x-6');
        toggleInitialExpenseThumb?.classList.add('translate-x-0');
        if (toggleInitialExpenseLabel)
          toggleInitialExpenseLabel.textContent = '○ Add Initial Expense';
        toggleInitialExpenseLabel?.classList.remove('text-green-900', 'dark:text-green-100');
        toggleInitialExpenseLabel?.classList.add('text-gray-700', 'dark:text-gray-300');
        initialExpenseFieldsContainer?.classList.add('hidden');
      }
    }

    // Initialize expense toggle
    if (addInitialExpenseCheckbox) {
      updateExpenseToggleState();
      addInitialExpenseCheckbox.addEventListener('change', async () => {
        updateExpenseToggleState();
      });
    }

    // Always fetch groups on page load
    loadUserGroups();

    // Load user's groups
    async function loadUserGroups() {
      try {
        const response = await fetch('/api/groups/my-groups');
        const data = await response.json();

        const groupSelect = document.getElementById(
          'expenseGroupSelect'
        ) as HTMLSelectElement | null;
        if (groupSelect && data.groups && data.groups.length > 0) {
          // Clear existing options except the default
          groupSelect.innerHTML = '<option value="">-- No Group (Personal Event) --</option>';

          data.groups.forEach((group: any) => {
            const option = document.createElement('option');
            option.value = group.id;
            option.textContent = group.name;
            groupSelect.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading groups:', error);
      }
    }

    // Group creation handlers
    const createNewGroupBtn = document.getElementById('createNewGroupBtn') as HTMLElement | null;
    const createNewGroupForm = document.getElementById('createNewGroupForm') as HTMLElement | null;
    const createGroupConfirmBtn = document.getElementById(
      'createGroupConfirmBtn'
    ) as HTMLElement | null;
    const createGroupCancelBtn = document.getElementById(
      'createGroupCancelBtn'
    ) as HTMLElement | null;
    const newGroupNameInput = document.getElementById('newGroupName') as HTMLInputElement | null;
    const groupCreationError = document.getElementById('groupCreationError') as HTMLElement | null;

    if (createNewGroupBtn) {
      createNewGroupBtn.addEventListener('click', (e) => {
        e.preventDefault();
        createNewGroupForm?.classList.remove('hidden');
        newGroupNameInput?.focus();
      });
    }

    if (createGroupCancelBtn) {
      createGroupCancelBtn.addEventListener('click', (e) => {
        e.preventDefault();
        createNewGroupForm?.classList.add('hidden');
        if (newGroupNameInput) newGroupNameInput.value = '';
        if (groupCreationError) {
          groupCreationError.textContent = '';
          groupCreationError.classList.add('hidden');
        }
      });
    }

    if (createGroupConfirmBtn) {
      createGroupConfirmBtn.addEventListener('click', async (e) => {
        e.preventDefault();

        const groupName = (newGroupNameInput?.value ?? '').trim();
        if (!groupName) {
          if (groupCreationError) {
            groupCreationError.textContent = 'Group name is required';
            groupCreationError.classList.remove('hidden');
          }
          return;
        }

        try {
          const response = await fetch('/api/groups/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: groupName }),
          });

          const result = await response.json();

          if (!response.ok) {
            if (groupCreationError) {
              groupCreationError.textContent = result.error || 'Failed to create group';
              groupCreationError.classList.remove('hidden');
            }
            return;
          }

          // Add the new group to the dropdown
          const groupSelect = document.getElementById('expenseGroupSelect');
          if (groupSelect) {
            const option = document.createElement('option');
            option.value = result.group.id;
            option.textContent = result.group.name;
            option.selected = true;
            groupSelect.appendChild(option);
          }

          // Hide form and reset
          if (createNewGroupForm) {
            createNewGroupForm.classList.add('hidden');
          }
          if (newGroupNameInput) {
            newGroupNameInput.value = '';
          }
          if (groupCreationError) {
            groupCreationError.textContent = '';
            groupCreationError.classList.add('hidden');
          }
        } catch (error) {
          console.error('Error creating group:', error);
          if (groupCreationError) {
            groupCreationError.textContent = 'An error occurred';
            groupCreationError.classList.remove('hidden');
          }
        }
      });
    }

    if (toggleInitialExpenseSwitch) {
      toggleInitialExpenseSwitch.addEventListener('click', () => {
        if (addInitialExpenseCheckbox) {
          addInitialExpenseCheckbox.checked = !addInitialExpenseCheckbox.checked;
          updateExpenseToggleState();

          // If checked, fetch groups
          if (addInitialExpenseCheckbox.checked) {
            loadUserGroups();
          }
        }
      });
    }

    if (createEventForm) {
      console.log('✅ Form handler attached to:', createEventForm.id);
      createEventForm.addEventListener('submit', async (e) => {
        console.log('🎯 FORM SUBMIT FIRED');

        // Add visible indicator
        const indicator = document.createElement('div');
        indicator.style.position = 'fixed';
        indicator.style.top = '20px';
        indicator.style.right = '20px';
        indicator.style.padding = '20px';
        indicator.style.backgroundColor = '#22c55e';
        indicator.style.color = 'white';
        indicator.style.borderRadius = '8px';
        indicator.style.zIndex = '9999';
        indicator.textContent = '✅ Form submitted! Check console...';
        document.body.appendChild(indicator);

        e.preventDefault();

        const formData = new FormData(createEventForm as HTMLFormElement);

        // Combine date and time
        const startDate = formData.get('startDate') as string;
        const startTime = formData.get('startTime') as string;
        const endDate = formData.get('endDate') as string;
        const endTime = formData.get('endTime') as string;
        
        const startTimeInput = (startDate && startTime) ? `${startDate}T${startTime}` : '';
        const endTimeInput = (endDate && endTime) ? `${endDate}T${endTime}` : '';
        const shouldAddExpense = (addInitialExpenseCheckbox as HTMLInputElement)?.checked ?? false;
        const expenseDescription = (
          (formData.get('initialExpenseDescription') as string) ?? ''
        ).trim();
        const expenseAmount =
          parseFloat((formData.get('initialExpenseAmount') as string) ?? '0') || 0;
        const eventGroupId = (formData.get('groupId') as string) ?? '';

        // DEBUG: Log form submission state
        console.log('🚀 Form Submission Started:', {
          shouldAddExpense,
          expenseDescription,
          expenseAmountRaw: formData.get('initialExpenseAmount'),
          expenseAmount,
          eventGroupId,
          checkboxElement: addInitialExpenseCheckbox,
          checkboxChecked: addInitialExpenseCheckbox?.checked,
        });

        const data = {
          title: formData.get('title'),
          type: formData.get('type'),
          description: formData.get('description') || undefined,
          startTime: startTimeInput ? new Date(startTimeInput).toISOString() : undefined,
          endTime: endTimeInput ? new Date(endTimeInput).toISOString() : undefined,
          timezone: formData.get('timezone'),
          isVirtual: formData.get('isVirtual') === 'on',
          isPublic: formData.get('isPublic') === 'on',
          currency: formData.get('currency'),
          budget: formData.get('budget') || undefined,
          groupId: formData.get('groupId') || undefined,
        };

        try {
          // Validate expense fields if expense is enabled
          if (shouldAddExpense) {
            console.log('🔍 Expense validation triggered');
            const eventGroupId = formData.get('groupId') as string;
            
            if (!eventGroupId) {
              if (eventError) {
                eventError.textContent = 'Please select or create a group if you want to add an initial expense';
                eventError.classList.remove('hidden');
              }
              return;
            }

            if (!expenseDescription || !expenseDescription.trim()) {
              if (eventError) {
                eventError.textContent = 'Please provide an expense description';
                eventError.classList.remove('hidden');
              }
              return;
            }

            if (expenseAmount <= 0) {
              if (eventError) {
                eventError.textContent = 'Expense amount must be greater than 0';
                eventError.classList.remove('hidden');
              }
              return;
            }
            console.log('✅ Expense validation passed');
          } else {
            console.warn('⚠️ shouldAddExpense is false - skipping expense');
          }

          const response = await fetch('/api/events', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          const result = await response.json();

          if (!response.ok) {
            if (eventError) {
              eventError.textContent = result.error || 'Failed to create event';
              eventError.classList.remove('hidden');
            }
          } else {
            // Event created successfully
            const eventId = result.event.id;
            console.log('✅ Event created:', eventId);
            console.log(
              '🔄 Checking expense creation conditions: shouldAddExpense=' +
                shouldAddExpense +
                ', expenseAmount=' +
                expenseAmount
            );

            // Create expense if enabled
            if (shouldAddExpense && expenseAmount > 0) {
              console.log('🟢 INSIDE expense creation block');
              try {
                console.log('📝 Creating expense:', {
                  groupId: eventGroupId,
                  amount: expenseAmount,
                  description: expenseDescription,
                });

                // Get current user ID
                console.log('🔄 Fetching user from /api/auth/me...');
                const meResponse = await fetch('/api/auth/me');
                console.log('📡 Fetch response status:', meResponse.status);
                const meData = await meResponse.json();
                console.log('📦 /api/auth/me returned:', meData);
                const userId = meData.id; // Fixed: use meData.id directly, not meData.human?.id
                console.log('🆔 Extracted userId:', userId);

                if (!userId) {
                  console.warn('❌ Could not create expense - user ID not available', meData);
                  // Still redirect even if expense creation fails
                  // window.location.href = `/events/${eventId}`;
                  console.warn('❌ USER ID NOT AVAILABLE - NOT REDIRECTING');
                  return;
                }

                console.log('✅ Got user ID:', userId);

                const expenseData = {
                  eventId: eventId, // expenses are linked to events
                  amount: expenseAmount,
                  description: expenseDescription,
                  paidBy: userId,
                };

                console.log('📤 Expense details:', {
                  description: expenseDescription,
                  amount: expenseAmount,
                  groupId: eventGroupId,
                  paidBy: userId,
                  descriptionTrimmed: (expenseDescription ?? '').trim(),
                  amountIsNumber: typeof expenseAmount === 'number',
                  amountIsPositive: expenseAmount > 0,
                });
                console.log('📤 Sending expense data:', JSON.stringify(expenseData));

                const expenseResponse = await fetch('/api/expenses/create', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(expenseData),
                });

                const expenseResult = await expenseResponse.json();
                console.log('📥 Expense response:', expenseResponse.status, expenseResult);

                if (!expenseResponse.ok) {
                  console.warn('❌ Expense creation failed:', expenseResult.error || expenseResult);
                } else {
                  console.log('✅ Expense created successfully:', expenseResult.expense?.id);
                }
              } catch (error) {
                console.error('❌ Error creating expense:', error);
                // Still redirect even if expense creation fails
              }
            } else {
              console.warn(
                '🔴 SKIPPED expense creation: shouldAddExpense=' +
                  shouldAddExpense +
                  ', expenseAmount=' +
                  expenseAmount
              );
            }

            // Redirect to the newly created event
            console.log('✅✅✅ SUBMISSION COMPLETE - Redirecting to event ✅✅✅');
            setTimeout(() => {
              window.location.href = `/events/${eventId}`;
            }, 1000);
          }
        } catch (error) {
          if (eventError) {
            eventError.textContent = 'An error occurred. Please try again.';
            eventError.classList.remove('hidden');
          }
        }
      });
    }
  </script>
</Layout>
