---
import { getSession } from '../../utils/session';
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { events, sessions, expenses, humans } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { getTipStats, getTipDemographics, calculateSettlements } from '../../utils/expenses';
import { centsToDollars } from '../../utils/currency';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

const session = await getSession(sessionId);
if (!session) {
  Astro.cookies.delete('sessionId', { path: '/' });
  return Astro.redirect('/auth/login');
}

// Get session and verify user


// Get event ID from query parameters
const eventId = Astro.url.searchParams.get('eventId');

if (!eventId) {
  return Astro.redirect('/dashboard');
}

// Get event and verify ownership
const [event] = await db.select().from(events).where(eq(events.id, eventId)).limit(1);

if (!event || event.creatorId !== session.userId) {
  return Astro.redirect('/dashboard');
}

// Get all expenses for this event (via the group)
const eventExpenses = event.groupId
  ? await db.select().from(expenses).where(eq(expenses.groupId, event.groupId))
  : [];

// Get all humans (users)
const allUsers = await db.select().from(humans);

// Calculate analytics
const tipStats = await getTipStats(eventId);
const tipDemographics = await getTipDemographics(eventId);
const settlements = await calculateSettlements(eventId);

// Calculate totals (keep in cents)
const totalAmount = eventExpenses.reduce((sum, e) => sum + e.amount, 0);
const totalTips = eventExpenses.reduce((sum, e) => sum + (e.tipAmount ? e.tipAmount : 0), 0);
const grandTotal = totalAmount + totalTips;
---

<Layout title={`Analytics - ${event.title}`} description="Expense analytics and settlements">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">
              Analytics & Settlements
            </h1>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              {event.title}
            </p>
          </div>
          <a
            href={`/expenses?eventId=${event.id}`}
            class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
          >
            ← Back to Expenses
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-6xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <!-- Overall Summary -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 sm:p-6"
        >
          <p class="text-xs font-medium text-slate-600 dark:text-slate-400 uppercase mb-1">
            Total Expenses
          </p>
          <p class="text-2xl font-bold text-slate-900 dark:text-white">
            {event.currency}
            {centsToDollars(totalAmount)}
          </p>
        </div>

        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 sm:p-6"
        >
          <p class="text-xs font-medium text-slate-600 dark:text-slate-400 uppercase mb-1">
            Total Tips
          </p>
          <p class="text-2xl font-bold text-green-600 dark:text-green-400">
            {event.currency}
            {centsToDollars(totalTips)}
          </p>
        </div>

        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 sm:p-6"
        >
          <p class="text-xs font-medium text-slate-600 dark:text-slate-400 uppercase mb-1">
            Grand Total
          </p>
          <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">
            {event.currency}
            {centsToDollars(grandTotal)}
          </p>
        </div>

        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 sm:p-6"
        >
          <p class="text-xs font-medium text-slate-600 dark:text-slate-400 uppercase mb-1">
            Avg Tip %
          </p>
          <p class="text-2xl font-bold text-orange-600 dark:text-orange-400">
            {tipStats.averageTipPercentage.toFixed(1)}%
          </p>
        </div>

        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 sm:p-6"
        >
          <p class="text-xs font-medium text-slate-600 dark:text-slate-400 uppercase mb-1">
            Expenses Count
          </p>
          <p class="text-2xl font-bold text-slate-900 dark:text-white">
            {eventExpenses.length}
          </p>
        </div>
      </div>

      <!-- Tip Statistics -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6"
      >
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">💰 Tip Statistics</h2>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
          <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
            <p class="text-xs text-slate-600 dark:text-slate-400 mb-1">Average Tip</p>
            <p class="text-xl font-bold text-slate-900 dark:text-white">
              {event.currency}
              {tipStats.averageTip.toFixed(2)}
            </p>
          </div>

          <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
            <p class="text-xs text-slate-600 dark:text-slate-400 mb-1">Median Tip</p>
            <p class="text-xl font-bold text-slate-900 dark:text-white">
              {event.currency}
              {tipStats.medianTip.toFixed(2)}
            </p>
          </div>

          <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
            <p class="text-xs text-slate-600 dark:text-slate-400 mb-1">Min Tip</p>
            <p class="text-xl font-bold text-slate-900 dark:text-white">
              {event.currency}
              {tipStats.minTip.toFixed(2)}
            </p>
          </div>

          <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
            <p class="text-xs text-slate-600 dark:text-slate-400 mb-1">Max Tip</p>
            <p class="text-xl font-bold text-slate-900 dark:text-white">
              {event.currency}
              {tipStats.maxTip.toFixed(2)}
            </p>
          </div>

          <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
            <p class="text-xs text-slate-600 dark:text-slate-400 mb-1">Avg % of Subtotal</p>
            <p class="text-xl font-bold text-orange-600 dark:text-orange-400">
              {tipStats.averageTipPercentage.toFixed(1)}%
            </p>
          </div>
        </div>
      </div>

      <!-- Tipping Demographics -->
      {
        tipDemographics.length > 0 && (
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
              👥 Tipping Demographics
            </h2>

            <div class="overflow-x-auto">
              <table class="w-full">
                <thead class="bg-slate-50 dark:bg-slate-700 border-b border-slate-200 dark:border-slate-600">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Person
                    </th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Total Tipped
                    </th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Times
                    </th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Avg Per Tip
                    </th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                  {tipDemographics.map((person) => (
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                      <td class="px-6 py-4 text-slate-900 dark:text-white font-medium">
                        {person.name}
                      </td>
                      <td class="px-6 py-4 text-right font-bold text-slate-900 dark:text-white">
                        {event.currency} {person.totalTipped.toFixed(2)}
                      </td>
                      <td class="px-6 py-4 text-right text-slate-600 dark:text-slate-400">
                        {person.timesLeftTip}
                      </td>
                      <td class="px-6 py-4 text-right text-green-600 dark:text-green-400 font-medium">
                        {event.currency} {person.averageTip.toFixed(2)}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )
      }

      <!-- Settlements -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
          🔄 Settlement Payments Required
        </h2>

        {
          settlements.length === 0 ? (
            <div class="p-6 text-center bg-green-50 dark:bg-green-900/20 rounded-lg border border-green-200 dark:border-green-800">
              <p class="text-lg font-semibold text-green-700 dark:text-green-300">
                ✅ All debts are settled!
              </p>
              <p class="text-sm text-green-600 dark:text-green-400 mt-1">
                Everyone has paid their fair share.
              </p>
            </div>
          ) : (
            <div class="space-y-3">
              {settlements.map((settlement) => (
                <div class="p-4 bg-slate-50 dark:bg-slate-700 rounded-lg border border-slate-200 dark:border-slate-600 flex items-center justify-between">
                  <div>
                    <p class="font-medium text-slate-900 dark:text-white">
                      <span class="font-bold">{settlement.fromName}</span>
                      <span class="text-slate-600 dark:text-slate-400 mx-2">owes</span>
                      <span class="font-bold">{settlement.toName}</span>
                    </p>
                    <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">
                      Amount:{' '}
                      <span class="font-semibold text-slate-900 dark:text-white">
                        {event.currency} {settlement.amount.toFixed(2)}
                      </span>
                    </p>
                  </div>
                  <button
                    type="button"
                    class="px-4 py-2 bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 rounded-lg hover:bg-indigo-200 dark:hover:bg-indigo-800 transition-colors font-medium text-sm"
                    onclick={`markPaid('${settlement.from}', '${settlement.to}', ${settlement.amount})`}
                  >
                    Mark Paid
                  </button>
                </div>
              ))}
            </div>
          )
        }
      </div>

      <!-- Back Button -->
      <div class="mt-6 flex gap-3">
        <a
          href={`/expenses?eventId=${event.id}`}
          class="px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
        >
          ← Back to Expenses
        </a>
        <a
          href={`/events/${event.id}`}
          class="px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
        >
          ← Back to Event
        </a>
      </div>
    </main>
  </div>
</Layout>

<script>
  function markPaid(from, to, amount) {
    alert('Payment tracking coming soon!');
    // TODO: Implement payment confirmation
  }
</script>
