---
import { getSession } from '../../utils/session';
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { events, expenseGroups, groupMembers, humans } from '../../db/schema';
import { eq, and, or } from 'drizzle-orm';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

const session = await getSession(sessionId);
if (!session) {
  Astro.cookies.delete('sessionId', { path: '/' });
  return Astro.redirect('/auth/login');
}

// Fetch user's groups
const createdGroups = await db.select().from(expenseGroups).where(eq(expenseGroups.createdBy, session.userId));
const memberGroupLinks = await db.select({ group: expenseGroups }).from(groupMembers).innerJoin(expenseGroups, eq(groupMembers.groupId, expenseGroups.id)).where(eq(groupMembers.userId, session.userId));
const memberGroupsList = memberGroupLinks.map(link => link.group);

// Combine and deduplicate groups
const allGroupsMap = new Map();
[...createdGroups, ...memberGroupsList].forEach(g => {
  allGroupsMap.set(g.id, g);
});
const allGroups = Array.from(allGroupsMap.values());

// Fetch user's events
const createdEvents = await db.select().from(events).where(eq(events.creatorId, session.userId));
const allEvents = [...createdEvents]; // TODO: Add events where user is in the group

// Fetch group members for dynamic "Paid By" dropdown
const groupMembersList = await db
  .select({
    groupId: groupMembers.groupId,
    userId: humans.id,
    firstName: humans.firstName,
    lastName: humans.lastName
  })
  .from(groupMembers)
  .innerJoin(humans, eq(groupMembers.userId, humans.id));

const membersByGroup: Record<string, {id: string, name: string}[]> = {};
for (const member of groupMembersList) {
  if (!membersByGroup[member.groupId]) membersByGroup[member.groupId] = [];
  membersByGroup[member.groupId].push({
    id: member.userId,
    name: `${member.firstName || ''} ${member.lastName || ''}`.trim() || 'Unknown User'
  });
}

// Add group creator to the members list if not already there
allGroups.forEach(g => {
  if (!membersByGroup[g.id]) membersByGroup[g.id] = [];
  const hasCreator = membersByGroup[g.id].find(m => m.id === g.createdBy);
  if (!hasCreator) {
    // We would need the creator's name, but for now we can just rely on the groupMembers table
    // because creators should be in groupMembers.
  }
});

const eventGroupMap: Record<string, string> = {};
for (const e of allEvents) {
  if (e.groupId) {
    eventGroupMap[e.id] = e.groupId;
  }
}

// Fetch all humans as fallback
const rawUsers = await db.select().from(humans);
const allUsers = rawUsers.map((user) => ({
  ...user,
  name: `${user.firstName || ''} ${user.lastName || ''}`.trim() || 'Unknown User',
}));

// Default selected query parameters
const preselectGroupId = Astro.url.searchParams.get('groupId') || '';
const preselectEventId = Astro.url.searchParams.get('eventId') || '';
---

<Layout
  title="Add Expense"
  description="Log a new expense"
  currentPage="expenses"
>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Page Title -->
    <div class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-3 sm:px-6 lg:px-8 py-4 sm:py-6">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-1">
          Add Expense
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
          Record an expense and assign it to a group or event
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main class="flex-1 max-w-2xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8">
        
        <form id="globalAddExpenseForm" class="space-y-6">
          <div id="expenseError" class="hidden p-4 bg-red-50 text-red-600 dark:bg-red-900 dark:text-red-200 rounded-lg text-sm"></div>

          <!-- Target Selection: Group or Event -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="expenseTarget" class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Add to <span class="text-red-500">*</span>
              </label>
              <select
                id="expenseTargetType"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="group" selected={preselectGroupId || !preselectEventId}>Group</option>
                <option value="event" selected={preselectEventId ? true : false}>Event</option>
              </select>
            </div>
            
            <div id="groupSelectContainer" class={preselectEventId ? 'hidden' : 'block'}>
              <label for="groupId" class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Select Group <span class="text-red-500">*</span>
              </label>
              <select
                id="groupId"
                name="groupId"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="">-- Select a Group --</option>
                {allGroups.map((g) => (
                  <option value={g.id} selected={g.id === preselectGroupId}>{g.name}</option>
                ))}
              </select>
            </div>

            <div id="eventSelectContainer" class={preselectEventId ? 'block' : 'hidden'}>
              <label for="eventId" class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Select Event <span class="text-red-500">*</span>
              </label>
              <select
                id="eventId"
                name="eventId"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="">-- Select an Event --</option>
                {allEvents.map((e) => (
                  <option value={e.id} selected={e.id === preselectEventId}>{e.title}</option>
                ))}
              </select>
            </div>
          </div>

          <!-- Description & Category -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="description" class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Description <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="description"
                name="description"
                required
                placeholder="What was this expense for?"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              />
            </div>
            <div>
              <label for="category" class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Category
              </label>
              <select
                id="category"
                name="category"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                <option value="meal">Meal / Food</option>
                <option value="transport">Transport</option>
                <option value="flight">Flight</option>
                <option value="roundtrip_flight">🔄 Round-Trip Flight</option>
                <option value="accommodation">Accommodation</option>
                <option value="parking">Parking</option>
                <option value="entertainment">Entertainment</option>
                <option value="tickets">Tickets</option>
                <option value="misc" selected>Miscellaneous</option>
              </select>
            </div>
          </div>

          <!-- Amount & Payer -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="amount" class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Amount <span class="text-red-500">*</span>
              </label>
              <div class="relative">
                <span class="absolute left-4 top-3 text-slate-600 dark:text-slate-400 font-medium">$</span>
                <input
                  type="number"
                  id="amount"
                  name="amount"
                  step="0.01"
                  min="0.01"
                  required
                  placeholder="0.00"
                  class="w-full pl-8 pr-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
                />
              </div>
            </div>

            <div>
              <label for="paidBy" class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Paid By <span class="text-red-500">*</span>
              </label>
              <select
                id="paidBy"
                name="paidBy"
                required
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
              >
                {allUsers.map((user) => (
                  <option value={user.id} selected={user.id === session.userId}>
                    {user.id === session.userId ? 'You' : user.name}
                  </option>
                ))}
              </select>
            </div>
          </div>

          <!-- Metadata / Templates Section -->
          <div class="pt-2">
            <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
              Expense Details (Flight #, Address, etc.)
            </label>
            
            <div class="mb-4 flex gap-2 items-end">
              <div class="flex-1">
                <label for="templateSelect" class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">
                  Quick Templates
                </label>
                <select id="templateSelect" class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm">
                  <option value="">-- Select a template --</option>
                  <option value="flight">✈️ One-Way Flight</option>
                  <option value="roundtrip_flight">🔄 Round-Trip Flight</option>
                  <option value="hotel">🏨 Hotel</option>
                    <option value="car_rental">🚗 Car Rental</option>
                  <option value="dinner">🍽️ Restaurant/Dinner</option>
                  <option value="tourist">🎫 Tourist Activity</option>
                </select>
              </div>
              <button type="button" id="applyTemplateBtn" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium text-sm whitespace-nowrap">
                Apply Template
              </button>
            </div>

            <div id="metadataContainer" class="space-y-3">
              <!-- Dynamic metadata fields go here -->
            </div>
            
            <button
              type="button"
              id="addMetadataFieldBtn"
              class="mt-3 px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium text-sm"
            >
              + Add Detail
            </button>
          </div>

          <!-- Actions -->
          <div class="flex gap-4 pt-4 border-t border-slate-200 dark:border-slate-700">
            <button
              type="submit"
              class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium w-full sm:w-auto"
            >
              Save Expense
            </button>
            <button
              type="button"
              onclick="window.history.back()"
              class="px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium w-full sm:w-auto text-center"
            >
              Cancel
            </button>
          </div>
        </form>
      </div>
    </main>

    <!-- Toast Notification -->
    <div
      id="toast"
      class="fixed bottom-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none z-50 max-w-xs"
    >
      <span id="toast-message"></span>
    </div>

    <script define:vars={{ 
      currentUserId: session.userId,
      membersByGroup,
      eventGroupMap,
      allUsers
    }}>
      // Toggle Group vs Event selection
      const targetTypeSelect = document.getElementById('expenseTargetType');
      const groupContainer = document.getElementById('groupSelectContainer');
      const eventContainer = document.getElementById('eventSelectContainer');
      const groupIdSelect = document.getElementById('groupId');
      const eventIdSelect = document.getElementById('eventId');
      const paidBySelect = document.getElementById('paidBy');

      // Metadata Template Logic
      let metadataCount = 0;

      function addMetadataField(key = "", value = "") {
        const container = document.getElementById("metadataContainer");
        if (!container) return;

        const fieldId = `metadata_field_${metadataCount++}`;
        const fieldHTML = `
          <div id="${fieldId}" class="flex gap-2 items-center">
            <input
              type="text"
              name="metadataKey"
              placeholder="Key (e.g., Flight Number)"
              value="${key}"
              class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
            />
            <input
              type="text"
              name="metadataValue"
              placeholder="Value (e.g., DL123)"
              value="${value}"
              class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-sm"
            />
            <button
              type="button"
              onclick="document.getElementById('${fieldId}').remove()"
              class="px-3 py-2 bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-200 rounded-lg hover:bg-red-200 dark:hover:bg-red-800 transition-colors text-sm font-medium"
            >
              ✕
            </button>
          </div>
        `;
        container.insertAdjacentHTML("beforeend", fieldHTML);
      }

      const activityTemplates = {
        flight: {
          "Airline Company": "",
          "Flight Number": "",
          "Confirmation Number": "",
          "Take Off Time": "",
          "Arrival Time": "",
          "Seat Number": ""
        },
        roundtrip_flight: {
          "Airline Company": "",
          "Confirmation Number": "",
          "Outbound Flight #": "",
          "Outbound Take Off": "",
          "Outbound Arrival": "",
          "Outbound Seat": "",
          "Return Flight #": "",
          "Return Take Off": "",
          "Return Arrival": "",
          "Return Seat": ""
        },
        hotel: {
          "Hotel Name": "",
          "Address": "",
          "Check-in Date": "",
          "Check-out Date": "",
          "Confirmation Code": ""
        },
        car_rental: {
          "Rental Company": "",
          "Reservation #": "",
          "Vehicle Type": "",
          "Pick Up Location": "",
          "Pick Up Time": "",
          "Drop Off Location": "",
          "Drop Off Time": ""
        },
        dinner: {
          "Restaurant Name": "",
          "Reservation Time": "",
          "Party Size": "",
          "Reservation Name": ""
        },
        tourist: {
          "Location/Attraction": "",
          "Address": "",
          "Suggested Time": ""
        }
      };

      const applyTemplateBtn = document.getElementById("applyTemplateBtn");
      if (applyTemplateBtn) {
        applyTemplateBtn.addEventListener("click", () => {
          const templateSelect = document.getElementById("templateSelect");
          const selectedTemplate = templateSelect.value;
          
          if (selectedTemplate && activityTemplates[selectedTemplate]) {
            const template = activityTemplates[selectedTemplate];
            Object.keys(template).forEach(key => {
              addMetadataField(key, "");
            });
            templateSelect.value = "";
          }
        });
      }

      const addMetadataFieldBtn = document.getElementById("addMetadataFieldBtn");
      if (addMetadataFieldBtn) {
        addMetadataFieldBtn.addEventListener("click", (e) => {
          e.preventDefault();
          addMetadataField();
        });
      }

      function updatePaidByDropdown() {
        if (!paidBySelect) return;
        
        const isGroup = targetTypeSelect.value === 'group';
        let targetGroupId = null;
        
        if (isGroup && groupIdSelect.value) {
          targetGroupId = groupIdSelect.value;
        } else if (!isGroup && eventIdSelect.value) {
          targetGroupId = eventGroupMap[eventIdSelect.value];
        }

        paidBySelect.innerHTML = '';
        
        let usersToDisplay = allUsers; // fallback
        
        if (targetGroupId && membersByGroup[targetGroupId] && membersByGroup[targetGroupId].length > 0) {
          usersToDisplay = membersByGroup[targetGroupId];
        }

        usersToDisplay.forEach(user => {
          const option = document.createElement('option');
          option.value = user.id;
          option.textContent = user.id === currentUserId ? 'You' : user.name;
          if (user.id === currentUserId) {
            option.selected = true;
          }
          paidBySelect.appendChild(option);
        });
      }

      if (targetTypeSelect && groupContainer && eventContainer) {
        targetTypeSelect.addEventListener('change', (e) => {
          if (e.target.value === 'group') {
            groupContainer.classList.remove('hidden');
            eventContainer.classList.add('hidden');
            eventIdSelect.value = '';
          } else {
            groupContainer.classList.add('hidden');
            eventContainer.classList.remove('hidden');
            groupIdSelect.value = '';
          }
          updatePaidByDropdown();
        });
      }

      if (groupIdSelect) groupIdSelect.addEventListener('change', updatePaidByDropdown);
      if (eventIdSelect) eventIdSelect.addEventListener('change', updatePaidByDropdown);
      
      // Initialize on load
      updatePaidByDropdown();

      // Toast Notification
      function showToast(message) {
        const toast = document.getElementById('toast');
        const toastMessage = document.getElementById('toast-message');
        if (toast && toastMessage) {
          toastMessage.textContent = message;
          toast.classList.remove('opacity-0');
          toast.classList.add('opacity-100');
          setTimeout(() => {
            toast.classList.remove('opacity-100');
            toast.classList.add('opacity-0');
          }, 3000);
        }
      }

      // Form Submission
      const form = document.getElementById('globalAddExpenseForm');
      const errorDiv = document.getElementById('expenseError');

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (errorDiv) errorDiv.classList.add('hidden');
          
          const formData = new FormData(form);
          
          const isGroup = targetTypeSelect.value === 'group';
          const groupId = formData.get('groupId');
          const eventId = formData.get('eventId');
          
          if (isGroup && !groupId) {
            errorDiv.textContent = 'Please select a group';
            errorDiv.classList.remove('hidden');
            return;
          }
          if (!isGroup && !eventId) {
            errorDiv.textContent = 'Please select an event';
            errorDiv.classList.remove('hidden');
            return;
          }

          // Gather metadata
          const metadata = {};
          const metadataKeys = formData.getAll("metadataKey");
          const metadataValues = formData.getAll("metadataValue");

          for (let i = 0; i < metadataKeys.length; i++) {
            const key = metadataKeys[i]?.trim();
            const value = metadataValues[i]?.trim();
            if (key && value) {
              metadata[key] = value;
            }
          }

          const data = {
            groupId: isGroup ? groupId : undefined,
            eventId: !isGroup ? eventId : undefined,
            amount: parseFloat(formData.get('amount')),
            description: formData.get('description'),
            paidBy: formData.get('paidBy') || currentUserId,
            tipAmount: 0,
            category: formData.get('category') || 'misc',
            metadata: Object.keys(metadata).length > 0 ? metadata : undefined
          };

          try {
            const res = await fetch('/api/expenses/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });
            
            const resData = await res.json();
            
            if (!res.ok) {
              errorDiv.textContent = resData.error || 'Failed to add expense';
              errorDiv.classList.remove('hidden');
            } else {
              showToast('Expense added successfully!');
              setTimeout(() => {
                window.history.back();
              }, 1500);
            }
          } catch (err) {
            errorDiv.textContent = 'Network error occurred. Please try again.';
            errorDiv.classList.remove('hidden');
          }
        });
      }
    </script>
  </div>
</Layout>
