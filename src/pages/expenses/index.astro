---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { events, sessions, expenses, humans, expenseGroups, groupMembers } from '../../db/schema';
import { eq, and } from 'drizzle-orm';
import { v4 as uuidv4 } from 'uuid';
import { centsToDollars } from '../../utils/currency';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

// Get session and verify user
const [session] = await db.select().from(sessions).where(eq(sessions.id, sessionId)).limit(1);

if (!session || new Date(session.expiresAt) < new Date()) {
  return Astro.redirect('/auth/login');
}

// Get event ID from query parameters
const eventId = Astro.url.searchParams.get('eventId');

if (!eventId) {
  return Astro.redirect('/dashboard');
}

// Get event
let [event] = await db.select().from(events).where(eq(events.id, eventId)).limit(1);

if (!event) {
  return Astro.redirect('/dashboard');
}

// Verify authorization: user is event creator OR member of the group
const isCreator = event.creatorId === session.userId;
let isMember = false;

if (event.groupId) {
  const [member] = await db
    .select()
    .from(groupMembers)
    .where(and(eq(groupMembers.groupId, event.groupId), eq(groupMembers.userId, session.userId)))
    .limit(1);
  isMember = !!member;
}

if (!isCreator && !isMember) {
  return Astro.redirect('/dashboard');
}

// If event doesn't have a group, create one
if (!event.groupId) {
  const groupId = uuidv4();
  try {
    const [newGroup] = await db
      .insert(expenseGroups)
      .values({
        id: groupId,
        createdBy: session.userId,
        name: `${event.title} Expenses`,
      })
      .returning();

    // Update event with new group
    const [updatedEvent] = await db
      .update(events)
      .set({ groupId: groupId })
      .where(eq(events.id, eventId))
      .returning();

    event = updatedEvent;
  } catch (e) {
    console.error('Error creating expense group:', e);
    return Astro.redirect('/dashboard');
  }
}

// Get all expenses for this event (via the group)
const eventExpenses = event.groupId
  ? await db.select().from(expenses).where(eq(expenses.groupId, event.groupId))
  : [];

// Get all humans (users) for the dropdown
const rawUsers = await db.select().from(humans);

// Format users with computed name
const allUsers = rawUsers.map((user) => ({
  ...user,
  name: `${user.firstName || ''} ${user.lastName || ''}`.trim() || 'Unknown User',
}));

// Format expenses for display
const formattedExpenses = eventExpenses.map((exp) => ({
  ...exp,
  amountDisplay: `${event.currency} ${(parseFloat(exp.amount as any) / 100).toFixed(2)}`,
  tipDisplay: exp.tipAmount
    ? `${event.currency} ${parseFloat(exp.tipAmount as any).toFixed(2)}`
    : '-',
  totalDisplay: `${event.currency} ${(parseFloat(exp.amount as any) / 100 + (exp.tipAmount ? parseFloat(exp.tipAmount as any) : 0)).toFixed(2)}`,
}));

// Calculate totals (keep in cents)
const totalAmountCents = eventExpenses.reduce((sum, e) => sum + e.amount, 0);
const totalTipsCents = eventExpenses.reduce((sum, e) => sum + (e.tipAmount ? e.tipAmount : 0), 0);
const grandTotalCents = totalAmountCents + totalTipsCents;
---

<Layout title={`Expenses - ${event.title}`} description="Manage event expenses and tips">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Header -->
    <header
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-50"
    >
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Expenses & Tips</h1>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              {event.title}
            </p>
          </div>
          <a
            href={`/events/${event.id}`}
            class="px-4 py-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
          >
            ← Back to Event
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-6xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <!-- Add Expense Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6"
      >
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Add New Expense</h2>

        <form id="addExpenseForm" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Base Amount -->
            <div>
              <label
                for="amount"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Amount ({event.currency}) <span class="text-red-500">*</span>
              </label>
              <input
                type="number"
                id="amount"
                name="amount"
                step="0.01"
                min="0"
                placeholder="34.95"
                required
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
              <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Base cost before tip</p>
            </div>

            <!-- Tip Amount -->
            <div>
              <label
                for="tipAmount"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Tip ({event.currency})
              </label>
              <div class="flex gap-2">
                <input
                  type="number"
                  id="tipAmount"
                  name="tipAmount"
                  step="0.01"
                  min="0"
                  placeholder="0.00"
                  class="flex-1 px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                />
                <button
                  type="button"
                  id="tipSuggestionBtn"
                  class="px-3 py-2 bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 rounded-lg hover:bg-indigo-200 dark:hover:bg-indigo-800 transition-colors font-medium text-sm whitespace-nowrap"
                  title="Suggest 20% tip based on amount"
                >
                  💡 20%
                </button>
              </div>
              <p id="tipSuggestion" class="text-xs text-slate-500 dark:text-slate-400 mt-1"></p>
            </div>

            <!-- Paid By -->
            <div>
              <label
                for="paidBy"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Paid By <span class="text-red-500">*</span>
              </label>
              <select
                id="paidBy"
                name="paidBy"
                required
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
              >
                <option value="">Select who paid</option>
                {allUsers.map((user) => <option value={user.id}>{user.name}</option>)}
              </select>
            </div>

            <!-- Description -->
            <div class="sm:col-span-2">
              <label
                for="description"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Description
              </label>
              <input
                type="text"
                id="description"
                name="description"
                placeholder="Breakfast at Denny's"
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
            </div>
          </div>

          <!-- Total Summary -->
          <div
            id="expenseSummary"
            class="p-4 bg-indigo-50 dark:bg-indigo-900/20 rounded-lg border border-indigo-200 dark:border-indigo-800"
          >
            <div class="grid grid-cols-3 gap-4 text-center">
              <div>
                <p class="text-xs text-slate-600 dark:text-slate-400 mb-1">Subtotal</p>
                <p id="summarySubtotal" class="font-bold text-lg text-slate-900 dark:text-white">
                  {event.currency} 0.00
                </p>
              </div>
              <div>
                <p class="text-xs text-slate-600 dark:text-slate-400 mb-1">Tip</p>
                <p id="summaryTip" class="font-bold text-lg text-green-600 dark:text-green-400">
                  {event.currency} 0.00
                </p>
              </div>
              <div>
                <p class="text-xs text-slate-600 dark:text-slate-400 mb-1">Total</p>
                <p id="summaryTotal" class="font-bold text-lg text-indigo-600 dark:text-indigo-400">
                  {event.currency} 0.00
                </p>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            class="w-full px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium"
          >
            ✅ Add Expense
          </button>
        </form>
      </div>

      <!-- Summary Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 sm:p-6"
        >
          <p class="text-sm font-medium text-slate-600 dark:text-slate-400 mb-2">Total Expenses</p>
          <p class="text-2xl font-bold text-slate-900 dark:text-white">
            {event.currency}
            {centsToDollars(totalAmountCents)}
          </p>
        </div>

        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 sm:p-6"
        >
          <p class="text-sm font-medium text-slate-600 dark:text-slate-400 mb-2">Total Tips</p>
          <p class="text-2xl font-bold text-green-600 dark:text-green-400">
            {event.currency}
            {centsToDollars(totalTipsCents)}
          </p>
        </div>

        <div
          class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 sm:p-6"
        >
          <p class="text-sm font-medium text-slate-600 dark:text-slate-400 mb-2">Grand Total</p>
          <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">
            {event.currency}
            {centsToDollars(grandTotalCents)}
          </p>
        </div>
      </div>

      <!-- Expenses List -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden"
      >
        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
          <h2 class="text-lg font-bold text-slate-900 dark:text-white">
            Expenses ({eventExpenses.length})
          </h2>
        </div>

        {
          eventExpenses.length === 0 ? (
            <div class="px-6 py-12 text-center">
              <p class="text-slate-600 dark:text-slate-400 mb-2">No expenses yet</p>
              <p class="text-sm text-slate-500 dark:text-slate-500">
                Add your first expense using the form above
              </p>
            </div>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead class="bg-slate-50 dark:bg-slate-700 border-b border-slate-200 dark:border-slate-600">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Description
                    </th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Amount
                    </th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Tip
                    </th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Total
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Paid By
                    </th>
                    <th class="px-6 py-3 text-center text-xs font-medium text-slate-600 dark:text-slate-400 uppercase">
                      Actions
                    </th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                  {formattedExpenses.map((exp) => {
                    const payer = allUsers.find((u) => u.id === exp.paidBy);
                    return (
                      <tr class="hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                        <td class="px-6 py-4 text-slate-900 dark:text-white font-medium">
                          {exp.description || '—'}
                        </td>
                        <td class="px-6 py-4 text-right text-slate-900 dark:text-white font-medium">
                          {exp.amountDisplay}
                        </td>
                        <td class="px-6 py-4 text-right">
                          <span
                            class={
                              exp.tipAmount
                                ? 'text-green-600 dark:text-green-400 font-medium'
                                : 'text-slate-500 dark:text-slate-400'
                            }
                          >
                            {exp.tipDisplay}
                          </span>
                        </td>
                        <td class="px-6 py-4 text-right font-bold text-indigo-600 dark:text-indigo-400">
                          {exp.totalDisplay}
                        </td>
                        <td class="px-6 py-4 text-slate-600 dark:text-slate-400">{payer?.name}</td>
                        <td class="px-6 py-4 text-center">
                          <button
                            type="button"
                            class="inline-flex items-center px-3 py-1 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded transition-colors"
                            onclick={`editExpense('${exp.id}')`}
                          >
                            ✏️ Edit
                          </button>
                          <button
                            type="button"
                            class="inline-flex items-center px-3 py-1 text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded transition-colors"
                            onclick={`deleteExpense('${exp.id}')`}
                          >
                            🗑️
                          </button>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )
        }
      </div>

      <!-- Analytics Link -->
      <div class="mt-6 flex gap-3">
        <a
          href={`/events/${event.id}`}
          class="px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white rounded-lg hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors font-medium"
        >
          ← Back to Event
        </a>
        <a
          href={`/expenses/analytics?eventId=${event.id}`}
          class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-medium"
        >
          📊 View Analytics & Settlements
        </a>
      </div>
    </main>
  </div>
</Layout>

<script define:vars={{ eventId, groupId: event.groupId, currency: event.currency }}>
  // Calculate tip suggestions
  document.getElementById('amount').addEventListener('input', function (e) {
    const amount = parseFloat(e.target.value) || 0;
    updateExpenseSummary();
    updateTipSuggestion(amount);
  });

  document.getElementById('tipAmount').addEventListener('input', function (e) {
    updateExpenseSummary();
  });

  // Tip suggestion button
  document.getElementById('tipSuggestionBtn').addEventListener('click', function (e) {
    e.preventDefault();
    const amount = parseFloat(document.getElementById('amount').value) || 0;
    const tip20 = parseFloat((amount * 0.2).toFixed(2));
    document.getElementById('tipAmount').value = tip20;
    updateExpenseSummary();
  });

  function updateTipSuggestion(amount) {
    if (amount <= 0) {
      document.getElementById('tipSuggestion').textContent = '';
      return;
    }
    const tip20 = parseFloat((amount * 0.2).toFixed(2));
    document.getElementById('tipSuggestion').textContent =
      `Suggested 20% tip: ${currency} ${tip20.toFixed(2)}`;
  }

  function updateExpenseSummary() {
    const amount = parseFloat(document.getElementById('amount').value) || 0;
    const tip = parseFloat(document.getElementById('tipAmount').value) || 0;
    const total = amount + tip;

    document.getElementById('summarySubtotal').textContent = `${currency} ${amount.toFixed(2)}`;
    document.getElementById('summaryTip').textContent = `${currency} ${tip.toFixed(2)}`;
    document.getElementById('summaryTotal').textContent = `${currency} ${total.toFixed(2)}`;
  }

  // Add expense form submission
  document.getElementById('addExpenseForm').addEventListener('submit', async function (e) {
    e.preventDefault();

    const formData = {
      groupId: groupId,
      amount: parseFloat(document.getElementById('amount').value),
      tipAmount: parseFloat(document.getElementById('tipAmount').value) || 0,
      paidBy: document.getElementById('paidBy').value,
      description: document.getElementById('description').value,
      splitAmong: [], // Will be handled by backend
    };

    try {
      const response = await fetch('/api/expenses/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData),
      });

      console.log('✅ Response received:', {
        status: response.status,
        statusText: response.statusText,
      });

      // Try to parse as JSON, but handle non-JSON responses
      let result;
      try {
        result = await response.json();
      } catch (jsonError) {
        console.error('❌ Failed to parse response as JSON:', jsonError);
        const text = await response.text();
        console.error('Response text:', text);
        alert(`Error: Server returned invalid response (${response.status})`);
        return;
      }

      if (result.success) {
        document.getElementById('addExpenseForm').reset();
        updateExpenseSummary();
        showToast('Expense added successfully!');
        setTimeout(() => {
          location.reload();
        }, 1500);
      } else {
        console.error('❌ API returned error:', result.error);
        alert('Error: ' + (result.error || 'Failed to add expense'));
      }
    } catch (error) {
      console.error('❌ Fetch error:', error);
      alert('Error adding expense: ' + (error instanceof Error ? error.message : String(error)));
    }
  });

  // Toast notification helper
  const toast = document.getElementById('toast');
  const toastMessage = document.getElementById('toast-message');

  function showToast(message) {
    if (!toast || !toastMessage) return;
    toastMessage.textContent = message;
    toast.classList.remove('opacity-0');
    setTimeout(() => {
      toast.classList.add('opacity-0');
    }, 3000);
  }

  function editExpense(expenseId) {
    showToast('Edit functionality coming soon!');
    // TODO: Implement edit modal
  }

  async function deleteExpense(expenseId) {
    if (!confirm('Are you sure you want to delete this expense?')) {
      return;
    }

    try {
      const response = await fetch(`/api/expenses/delete?expenseId=${expenseId}`, {
        method: 'DELETE',
      });

      const result = await response.json();

      if (result.success) {
        showToast('Expense deleted successfully!');
        setTimeout(() => {
          location.reload();
        }, 1500);
      } else {
        alert('Error: ' + (result.error || 'Failed to delete expense'));
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Error deleting expense: ' + error.message);
    }
  }
</script>
