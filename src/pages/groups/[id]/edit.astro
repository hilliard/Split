---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import { db } from "../../../db";
import { sessions, expenseGroups, groupMembers } from "../../../db/schema";
import { eq, and } from "drizzle-orm";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
if (!sessionId) {
  return Astro.redirect("/auth/login");
}

// Verify session
const [session] = await db
  .select()
  .from(sessions)
  .where(eq(sessions.id, sessionId))
  .limit(1);

if (!session || new Date(session.expiresAt) < new Date()) {
  return Astro.redirect("/auth/login");
}

// Get group ID from URL
const { id: groupId } = Astro.params;
if (!groupId) {
  return Astro.redirect("/dashboard");
}

// Get the group
const [group] = await db
  .select()
  .from(expenseGroups)
  .where(eq(expenseGroups.id, groupId))
  .limit(1);

if (!group) {
  return Astro.redirect("/dashboard");
}

// Check if user is a member of the group
const [member] = await db
  .select()
  .from(groupMembers)
  .where(
    and(
      eq(groupMembers.groupId, groupId),
      eq(groupMembers.userId, session.userId),
    ),
  );

if (!member) {
  return Astro.redirect("/dashboard");
}
---

<Layout title="Edit Group" description="Edit your group settings">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <Header title={group.name} currentPage="dashboard" />

    <!-- Page Title -->
    <div
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-3 sm:px-6 lg:px-8 py-4 sm:py-6"
    >
      <div class="max-w-7xl mx-auto">
        <h1
          class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-1"
        >
          Edit Group
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
          {group.name}
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main
      class="flex-1 max-w-2xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8"
    >
      <!-- Edit Group Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6"
      >
        <form id="editGroupForm" class="space-y-4">
          <!-- Group Name -->
          <div>
            <label
              for="groupName"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Group Name
            </label>
            <input
              type="text"
              id="groupName"
              name="name"
              required
              value={group.name}
              placeholder="e.g., Hockey Game with friends"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Info Message -->
          <div
            class="p-3 bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-lg text-sm text-blue-800 dark:text-blue-200"
          >
            ℹ️ Other group members will be notified of changes to the group
            name.
          </div>

          <!-- Error Message -->
          <div
            id="groupError"
            class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
          >
          </div>

          <!-- Success Message -->
          <div
            id="groupSuccess"
            class="p-3 bg-green-50 dark:bg-green-900 border border-green-200 dark:border-green-700 rounded-lg text-sm text-green-800 dark:text-green-200 hidden"
          >
            ✓ Group updated successfully!
          </div>

          <!-- Action Buttons -->
          <div
            class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700"
          >
            <a
              href="/dashboard"
              class="px-4 py-2 text-slate-700 dark:text-slate-300 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
            >
              Cancel
            </a>
            <button
              type="submit"
              class="px-4 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium text-sm min-h-touch flex items-center justify-center"
            >
              Save Changes
            </button>
          </div>
        </form>
      </div>

      <!-- Danger Zone -->
      <div
        class="bg-red-50 dark:bg-red-900 rounded-lg shadow-sm border border-red-200 dark:border-red-700 p-5 sm:p-6"
      >
        <h2
          class="text-lg sm:text-xl font-bold text-red-900 dark:text-red-100 mb-2"
        >
          ⚠️ Danger Zone
        </h2>
        <p class="text-sm text-red-800 dark:text-red-200 mb-4">
          Deleting this group is permanent and cannot be undone. All members,
          events, and expense data will be deleted.
        </p>
        <button
          id="deleteGroupBtn"
          type="button"
          class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium text-sm"
        >
          Delete Group
        </button>
      </div>
    </main>

    <!-- Toast Notification -->
    <div
      id="toast"
      class="fixed bottom-4 right-4 bg-green-500 text-white px-4 py-3 rounded-lg shadow-lg hidden z-[100] max-w-xs"
    >
      <div class="flex items-center gap-2">
        <span class="text-lg">✓</span>
        <span id="toastMessage">Group updated successfully!</span>
      </div>
    </div>

    <script is:inline>
      console.log("Edit Group script loaded");

      // Show toast notification
      function showToast(
        message = "Group updated successfully!",
        duration = 3000,
      ) {
        const toast = document.getElementById("toast");
        const toastMessage = document.getElementById("toastMessage");
        if (toast && toastMessage) {
          toastMessage.textContent = message;
          toast.classList.remove("hidden");
          setTimeout(() => {
            toast.classList.add("hidden");
          }, duration);
        }
      }

      // Handle form submission
      document
        .getElementById("editGroupForm")
        .addEventListener("submit", async (e) => {
          e.preventDefault();

          const formData = new FormData(e.target);
          const name = formData.get("name");

          const errorDiv = document.getElementById("groupError");
          const successDiv = document.getElementById("groupSuccess");

          // Reset messages
          errorDiv.classList.add("hidden");
          successDiv.classList.add("hidden");

          if (!name || name.trim().length === 0) {
            errorDiv.textContent = "Group name is required";
            errorDiv.classList.remove("hidden");
            return;
          }

          try {
            const groupId = window.location.pathname.split("/")[2];

            const response = await fetch(`/api/groups/${groupId}/update`, {
              method: "PUT",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({
                name: name.trim(),
              }),
            });

            if (response.ok) {
              const data = await response.json();
              successDiv.textContent = `✓ Group "${data.group.name}" updated successfully!`;
              successDiv.classList.remove("hidden");
              showToast(`Group "${data.group.name}" updated successfully!`);

              // Redirect back to dashboard after a short delay
              setTimeout(() => {
                window.location.href = "/dashboard";
              }, 2000);
            } else {
              const error = await response.json();
              errorDiv.textContent = error.error || "Failed to update group";
              errorDiv.classList.remove("hidden");
            }
          } catch (error) {
            console.error("Error updating group:", error);
            errorDiv.textContent =
              "An error occurred while updating the group. Please try again.";
            errorDiv.classList.remove("hidden");
          }
        });

      // Setup theme toggle
      function setupThemeToggle() {
        const html = document.documentElement;
        const savedTheme = localStorage.getItem("theme") || "light";

        if (savedTheme === "dark") {
          html.classList.add("dark");
          const icon = document.getElementById("themeIcon");
          if (icon) icon.textContent = "🌙";
        }
      }

      setupThemeToggle();

      // Handle delete group
      document
        .getElementById("deleteGroupBtn")
        .addEventListener("click", async () => {
          if (
            !confirm(
              "Are you sure you want to delete this group? This action cannot be undone.",
            )
          ) {
            return;
          }

          if (
            !confirm(
              "This will delete ALL members, events, and expenses. Are you absolutely sure?",
            )
          ) {
            return;
          }

          try {
            const deleteBtn = document.getElementById("deleteGroupBtn");
            deleteBtn.disabled = true;
            deleteBtn.textContent = "Deleting...";

            const groupId = window.location.pathname.split("/")[2];

            const response = await fetch(`/api/groups/${groupId}/delete`, {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
            });

            if (response.ok) {
              const data = await response.json();
              showToast("Group deleted successfully! Redirecting...");

              // Redirect to dashboard after a short delay
              setTimeout(() => {
                window.location.href = "/dashboard";
              }, 2000);
            } else {
              const error = await response.json();
              alert(error.error || "Failed to delete group");
              deleteBtn.disabled = false;
              deleteBtn.textContent = "Delete Group";
            }
          } catch (error) {
            console.error("Error deleting group:", error);
            alert("Error deleting group");
            const deleteBtn = document.getElementById("deleteGroupBtn");
            deleteBtn.disabled = false;
            deleteBtn.textContent = "Delete Group";
          }
        });
    </script>
  </div></Layout
>
