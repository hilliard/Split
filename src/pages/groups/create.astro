---
import { getSession } from '../../utils/session';
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { sessions, expenseGroups, groupMembers } from '../../db/schema';
import { eq } from 'drizzle-orm';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

const session = await getSession(sessionId);
if (!session) {
  Astro.cookies.delete('sessionId', { path: '/' });
  return Astro.redirect('/auth/login');
}

// Fetch user's current groups
const userGroups = await db
  .select({
    id: expenseGroups.id,
    name: expenseGroups.name,
  })
  .from(groupMembers)
  .innerJoin(expenseGroups, eq(groupMembers.groupId, expenseGroups.id))
  .where(eq(groupMembers.userId, session.userId));

---

<Layout title="Create Group" description="Create a group to split expenses" currentPage="dashboard">
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Page Title -->
    <div
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-3 sm:px-6 lg:px-8 py-4 sm:py-6"
    >
      <div class="max-w-4xl mx-auto">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-1">
          Create New Group
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
          Create a group to organize expenses with friends
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main class="flex-1 max-w-2xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <!-- Create Group Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6"
      >
        <form id="createGroupForm" class="space-y-4">
          <!-- Group Name -->
          <div>
            <label
              for="groupName"
              class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
            >
              Group Name
            </label>
            <input
              type="text"
              id="groupName"
              name="name"
              required
              placeholder="e.g., Hockey Game with friends"
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
          </div>

          <!-- Error Message -->
          <div
            id="groupError"
            class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
          >
          </div>

          <!-- Action Buttons -->
          <div class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700">
            <a
              href="/dashboard"
              class="px-6 py-2 text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium"
            >
              Cancel
            </a>
            <button
              type="submit"
              class="px-6 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium"
            >
              Create Group
            </button>
          </div>
        </form>
      </div>

      <!-- After group is created, add members here -->
      <div
        id="addMembersSection"
        class="hidden bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8"
      >
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Add Members</h2>
        <p id="groupNameDisplay" class="text-slate-600 dark:text-slate-400 mb-4">
          Group: <span id="groupNameSpan" class="font-semibold"></span>
        </p>

        <div class="mb-4">
          <label
            for="searchUsers"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Search for users to add
          </label>
          <div class="relative">
            <input
              type="text"
              id="searchUsers"
              placeholder="Search by name or phone..."
              class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
            />
            <div
              id="searchResults"
              class="absolute top-full left-0 right-0 mt-2 bg-white dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg shadow-lg max-h-48 overflow-y-auto hidden z-10"
            >
            </div>
          </div>
        </div>

        <!-- Members List -->
        <div>
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-3">Group Members</h3>
          <div id="membersList" class="space-y-2 mb-4"></div>
        </div>

        <!-- Buttons -->
        <div class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700">
          <a
            href="/dashboard"
            class="px-6 py-2 text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium"
          >
            Done
          </a>
        </div>
      </div>

      <!-- Current Groups Section -->
      <div class="mt-8">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Your Current Groups</h2>
        {userGroups.length === 0 ? (
          <div class="bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 p-6 text-center text-slate-500 dark:text-slate-400">
            You are not in any groups yet.
          </div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {userGroups.map((group) => (
              <a 
                href={`/groups/${group.id}`}
                class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-4 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors flex items-center justify-between group-card"
              >
                <div class="font-medium text-slate-900 dark:text-white truncate pr-4">{group.name}</div>
                <div class="text-indigo-600 dark:text-indigo-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </main>
  </div>

  <script is:inline>
    let currentGroupId = null;
    let currentGroupName = '';
    let groupMembers = [];

    // Global theme toggle function accessible from HTML onclick
    window.toggleTheme = function () {
      console.log('🖱️ Theme toggle clicked');

      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      const icon = document.getElementById('themeIcon');
      const mainDiv = document.querySelector('div.min-h-screen');

      if (isDark) {
        // Switch to LIGHT mode
        console.log('→ Switching to light mode');
        html.classList.remove('dark');
        document.body.style.setProperty('background-color', 'rgb(255, 255, 255)', 'important');
        document.body.style.setProperty('color', 'rgb(15, 23, 42)', 'important');

        // Clear inline styles from main div
        if (mainDiv) {
          mainDiv.style.backgroundColor = '';
          mainDiv.style.color = '';
        }

        // Remove dark mode styles and apply light mode styles
        let darkStyles = document.getElementById('dynamicDarkStyles');
        if (darkStyles) darkStyles.remove();

        // Inject light mode styles
        if (!document.getElementById('dynamicLightStyles')) {
          const style = document.createElement('style');
          style.id = 'dynamicLightStyles';
          style.textContent = `
            html:not(.dark) header {
              background-color: rgb(255, 255, 255) !important;
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) main {
              background-color: rgb(245, 246, 248) !important;
            }
            html:not(.dark) [class*="bg-white"],
            html:not(.dark) [class*="bg-slate-50"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-slate-900"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-slate-600"] {
              color: rgb(71, 85, 105) !important;
            }
            html:not(.dark) [class*="text-slate-400"] {
              color: rgb(148, 163, 184) !important;
            }
            html:not(.dark) [class*="border-slate-200"] {
              border-color: rgb(226, 232, 240) !important;
            }
            html:not(.dark) [class*="bg-slate-800"],
            html:not(.dark) [class*="bg-slate-900"] {
              background-color: rgb(255, 255, 255) !important;
            }
            html:not(.dark) [class*="text-white"] {
              color: rgb(15, 23, 42) !important;
            }
            html:not(.dark) [class*="text-indigo-300"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-400"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-600"] {
              color: rgb(79, 70, 229) !important;
            }
            html:not(.dark) [class*="text-indigo-700"] {
              color: rgb(67, 56, 202) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem('theme', 'light');
        console.log('✅ Switched to light mode');
        if (icon) icon.textContent = '☀️';
      } else {
        // Switch to DARK mode
        console.log('→ Switching to dark mode');
        html.classList.add('dark');
        document.body.style.setProperty('background-color', 'rgb(6, 6, 10)', 'important');
        document.body.style.setProperty('color', 'rgb(248, 250, 252)', 'important');

        // Set inline styles on main div for dark mode
        if (mainDiv) {
          mainDiv.style.setProperty('background-color', 'rgb(6, 6, 10)', 'important');
          mainDiv.style.setProperty('color', 'rgb(248, 250, 252)', 'important');
        }

        // Remove light mode styles and apply dark mode styles
        let lightStyles = document.getElementById('dynamicLightStyles');
        if (lightStyles) lightStyles.remove();

        // Inject dark mode styles
        if (!document.getElementById('dynamicDarkStyles')) {
          const style = document.createElement('style');
          style.id = 'dynamicDarkStyles';
          style.textContent = `
            html.dark header {
              background-color: rgb(15, 23, 42) !important;
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark main {
              background-color: rgb(6, 6, 10) !important;
            }
            html.dark [class*="bg-white"],
            html.dark [class*="bg-slate-50"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="bg-slate-800"] {
              background-color: rgb(30, 41, 59) !important;
            }
            html.dark [class*="bg-slate-900"] {
              background-color: rgb(15, 23, 42) !important;
            }
            html.dark [class*="text-slate-900"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-slate-600"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-slate-400"] {
              color: rgb(203, 213, 225) !important;
            }
            html.dark [class*="text-white"] {
              color: rgb(248, 250, 252) !important;
            }
            html.dark [class*="text-indigo-300"] {
              color: rgb(165, 180, 252) !important;
            }
            html.dark [class*="text-indigo-400"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-600"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="text-indigo-700"] {
              color: rgb(129, 140, 248) !important;
            }
            html.dark [class*="border-slate-200"] {
              border-color: rgb(51, 65, 85) !important;
            }
            html.dark [class*="border-slate-700"] {
              border-color: rgb(51, 65, 85) !important;
            }
          `;
          document.head.appendChild(style);
        }

        localStorage.setItem('theme', 'dark');
        console.log('✅ Switched to dark mode');
        if (icon) icon.textContent = '🌙';
      }
    };

    // Setup theme toggle on page load
    function setupThemeToggle() {
      const btn = document.getElementById('themeToggle');
      const icon = document.getElementById('themeIcon');
      const html = document.documentElement;
      const body = document.body;
      const mainDiv = document.querySelector('div.min-h-screen');

      if (!btn) {
        console.error('❌ Theme toggle button not found');
        return;
      }

      console.log('✅ Theme toggle setup started');

      // Update icon to match current theme on initialization
      const isDark = html.classList.contains('dark');
      if (icon) icon.textContent = isDark ? '🌙' : '☀️';

      // Inject CSS styles for current theme (both light and dark)
      if (isDark && !document.getElementById('dynamicDarkStyles')) {
        // Inject dark mode CSS
        const darkStyle = document.createElement('style');
        darkStyle.id = 'dynamicDarkStyles';
        darkStyle.textContent = `
          html.dark header {
            background-color: rgb(15, 23, 42) !important;
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark main {
            background-color: rgb(6, 6, 10) !important;
          }
          html.dark [class*="bg-white"],
          html.dark [class*="bg-slate-50"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="bg-slate-800"] {
            background-color: rgb(30, 41, 59) !important;
          }
          html.dark [class*="bg-slate-900"] {
            background-color: rgb(15, 23, 42) !important;
          }
          html.dark [class*="text-slate-900"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-slate-600"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-slate-400"] {
            color: rgb(203, 213, 225) !important;
          }
          html.dark [class*="text-white"] {
            color: rgb(248, 250, 252) !important;
          }
          html.dark [class*="text-indigo-300"] {
            color: rgb(165, 180, 252) !important;
          }
          html.dark [class*="text-indigo-400"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="text-indigo-600"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="text-indigo-700"] {
            color: rgb(129, 140, 248) !important;
          }
          html.dark [class*="border-slate-200"] {
            border-color: rgb(51, 65, 85) !important;
          }
          html.dark [class*="border-slate-700"] {
            border-color: rgb(51, 65, 85) !important;
          }
        `;
        document.head.appendChild(darkStyle);
      } else if (!isDark && !document.getElementById('dynamicLightStyles')) {
        // Inject light mode CSS
        const lightStyle = document.createElement('style');
        lightStyle.id = 'dynamicLightStyles';
        lightStyle.textContent = `
          html:not(.dark) header {
            background-color: rgb(255, 255, 255) !important;
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) main {
            background-color: rgb(245, 246, 248) !important;
          }
          html:not(.dark) [class*="bg-white"],
          html:not(.dark) [class*="bg-slate-50"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-slate-900"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-slate-600"] {
            color: rgb(71, 85, 105) !important;
          }
          html:not(.dark) [class*="text-slate-400"] {
            color: rgb(148, 163, 184) !important;
          }
          html:not(.dark) [class*="border-slate-200"] {
            border-color: rgb(226, 232, 240) !important;
          }
          html:not(.dark) [class*="bg-slate-800"],
          html:not(.dark) [class*="bg-slate-900"] {
            background-color: rgb(255, 255, 255) !important;
          }
          html:not(.dark) [class*="text-white"] {
            color: rgb(15, 23, 42) !important;
          }
          html:not(.dark) [class*="text-indigo-300"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-400"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-600"] {
            color: rgb(79, 70, 229) !important;
          }
          html:not(.dark) [class*="text-indigo-700"] {
            color: rgb(67, 56, 202) !important;
          }
        `;
        document.head.appendChild(lightStyle);
      }

      // Apply inline styles with setProperty to match current theme
      if (isDark) {
        html.style.setProperty('color-scheme', 'dark', 'important');
        body.style.setProperty('background-color', 'rgb(6, 6, 10)', 'important');
        body.style.setProperty('color', 'rgb(248, 250, 252)', 'important');
        if (mainDiv) {
          mainDiv.style.setProperty('background-color', 'rgb(6, 6, 10)', 'important');
          mainDiv.style.setProperty('color', 'rgb(248, 250, 252)', 'important');
        }
      } else {
        html.style.setProperty('color-scheme', 'light', 'important');
        body.style.setProperty('background-color', 'rgb(255, 255, 255)', 'important');
        body.style.setProperty('color', 'rgb(15, 23, 42)', 'important');
        if (mainDiv) {
          mainDiv.style.setProperty('background-color', 'rgb(255, 255, 255)', 'important');
          mainDiv.style.setProperty('color', 'rgb(15, 23, 42)', 'important');
        }
      }

      console.log('✅ Theme toggle ready');
    }

    // Initialize theme on page load (wait for DOM to be fully ready)
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupThemeToggle);
    } else {
      setTimeout(setupThemeToggle, 0);
    }

    // Create group form
    const createGroupForm = document.getElementById('createGroupForm');
    const groupError = document.getElementById('groupError');
    const addMembersSection = document.getElementById('addMembersSection');
    const groupNameDisplay = document.getElementById('groupNameDisplay');
    const groupNameSpan = document.getElementById('groupNameSpan');
    const membersList = document.getElementById('membersList');

    if (createGroupForm) {
      createGroupForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const groupName = document.getElementById('groupName').value;
        const submitBtn = createGroupForm.querySelector('button[type="submit"]');

        if (groupError) {
          groupError.textContent = '';
          groupError.classList.add('hidden');
        }

        if (submitBtn) submitBtn.disabled = true;

        try {
          const response = await fetch('/api/groups/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: groupName }),
          });

          const data = await response.json();

          if (!response.ok) {
            if (groupError) {
              groupError.textContent = data.error || 'Failed to create group';
              groupError.classList.remove('hidden');
            }
          } else {
            currentGroupId = data.group.id;
            currentGroupName = data.group.name;
            groupMembers = [{ userId: data.group.createdBy, name: 'You (Owner)' }];

            // Show add members section
            createGroupForm.style.display = 'none';
            if (addMembersSection) {
              addMembersSection.classList.remove('hidden');
              groupNameSpan.textContent = currentGroupName;
              renderMembers();
            }
          }
        } catch (error) {
          if (groupError) {
            groupError.textContent = 'An error occurred. Please try again.';
            groupError.classList.remove('hidden');
          }
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    }

    // Search for users
    const searchUsers = document.getElementById('searchUsers');
    const searchResults = document.getElementById('searchResults');

    if (searchUsers) {
      let searchTimeout;
      searchUsers.addEventListener('input', (e) => {
        clearTimeout(searchTimeout);
        const query = e.target.value.trim();

        if (query.length < 2) {
          searchResults.classList.add('hidden');
          return;
        }

        searchTimeout = setTimeout(async () => {
          try {
            const response = await fetch(`/api/users/search?q=${encodeURIComponent(query)}`);
            const data = await response.json();

            if (data.users && data.users.length > 0) {
              searchResults.innerHTML = data.users
                .map(
                  (user) =>
                    `<button
                  type="button"
                  class="w-full text-left px-4 py-2 hover:bg-indigo-50 dark:hover:bg-slate-600 transition-colors user-item"
                  data-user-id="${user.id}"
                  data-user-name="${user.firstName} ${user.lastName}"
                >
                  <p class="font-medium text-slate-900 dark:text-white">${user.firstName} ${user.lastName}</p>
                  ${user.phone ? `<p class="text-xs text-slate-500">${user.phone}</p>` : ''}
                </button>`
                )
                .join('');
              searchResults.classList.remove('hidden');

              // Add click handlers
              document.querySelectorAll('.user-item').forEach((item) => {
                item.addEventListener('click', (e) => {
                  e.preventDefault();
                  const userId = item.dataset.userId;
                  const userName = item.dataset.userName;
                  addMemberToGroup(userId, userName);
                  searchResults.classList.add('hidden');
                  searchUsers.value = '';
                });
              });
            } else {
              searchResults.innerHTML =
                '<div class="px-4 py-2 text-slate-500">No users found</div>';
              searchResults.classList.remove('hidden');
            }
          } catch (error) {
            console.error('Search error:', error);
          }
        }, 300);
      });
    }

    function renderMembers() {
      if (membersList) {
        membersList.innerHTML = groupMembers
          .map(
            (member) =>
              `<div class="flex items-center justify-between p-3 bg-slate-50 dark:bg-slate-700 rounded-lg">
            <span class="text-slate-900 dark:text-white">${member.name}</span>
            ${
              member.userId !== (currentGroupId ? 'owner' : '')
                ? `<button
              type="button"
              class="text-xs px-3 py-1 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900 rounded transition-colors remove-member-btn"
              data-user-id="${member.userId}"
            >
              Remove
            </button>`
                : ''
            }
          </div>`
          )
          .join('');
      }
    }

    async function addMemberToGroup(userId, userName) {
      try {
        const response = await fetch('/api/groups/add-member', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            groupId: currentGroupId,
            userId: userId,
          }),
        });

        if (response.ok) {
          groupMembers.push({ userId: userId, name: userName });
          renderMembers();
        } else {
          const data = await response.json();
          alert(data.error || 'Failed to add member');
        }
      } catch (error) {
        alert('Error adding member: ' + error.message);
      }
    }
  </script>
</Layout>
