---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Welcome to Split"
  description="Split expenses easily with friends"
>
  <nav
    class="bg-white dark:bg-slate-900 shadow-sm border-b border-slate-200 dark:border-slate-800"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <h1 class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">
          Split
        </h1>
        <div class="flex gap-4">
          <a
            href="/auth/login"
            class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
          >
            Login
          </a>
          <a
            href="/auth/register"
            class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors"
          >
            Sign Up
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main
    class="min-h-screen bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-950"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="text-center mb-12">
        <h2 class="text-5xl font-bold text-slate-900 dark:text-white mb-4">
          Split Expenses, Not Friendships
        </h2>
        <p class="text-xl text-slate-600 dark:text-slate-300 mb-8">
          Track shared expenses easily and see who owes what at a glance
        </p>
        <div class="flex gap-4 justify-center">
          <a
            href="/auth/register"
            class="px-8 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-semibold"
          >
            Get Started
          </a>
          <a
            href="#features"
            class="px-8 py-3 border-2 border-indigo-600 text-indigo-600 dark:text-indigo-400 dark:border-indigo-400 rounded-lg hover:bg-indigo-50 dark:hover:bg-slate-800 transition-colors font-semibold"
          >
            Learn More
          </a>
        </div>
      </div>

      <section
        id="features"
        class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-20"
      >
        <div
          class="p-6 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700"
        >
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
            Create Events
          </h3>
          <p class="text-slate-600 dark:text-slate-400">
            Organize expenses by events like trips, dinners, or parties
          </p>
        </div>

        <div
          class="p-6 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700"
        >
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
            Track Expenses
          </h3>
          <p class="text-slate-600 dark:text-slate-400">
            Log who paid and split costs automatically among group members
          </p>
        </div>

        <div
          class="p-6 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700"
        >
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
            Settle Up
          </h3>
          <p class="text-slate-600 dark:text-slate-400">
            See instantly who owes whom and settle balances easily
          </p>
        </div>
      </section>
    </div>
  </main>
</Layout>
