---
import Layout from "../layouts/Layout.astro";
import { db } from "../db";
import { events, sessions, customers, expenses, groupMembers } from "../db/schema";
import { eq, desc } from "drizzle-orm";
import { sumCents, centsToDollars } from "../utils/currency";

// Check if user is authenticated
const sessionId = Astro.cookies.get("sessionId")?.value;
let isAuthenticated = false;
let userEvents: any[] = [];
let userName = "";

if (sessionId) {
  try {
    // Get session
    const [session] = await db
      .select()
      .from(sessions)
      .where(eq(sessions.id, sessionId))
      .limit(1);

    if (session && new Date(session.expiresAt) > new Date()) {
      isAuthenticated = true;
      
      // Get user's events (limit to last 3 for summary)
      const recentEvents = await db
        .select()
        .from(events)
        .where(eq(events.creatorId, session.userId))
        .orderBy(desc(events.createdAt))
        .limit(3);
      
      // For each event, fetch expenses and participant count
      const eventsWithData = await Promise.all(
        recentEvents.map(async (event) => {
          // Get total expenses for this event - all calculations in cents
          const eventExpenses = await db
            .select()
            .from(expenses)
            .where(eq(expenses.eventId, event.id));
          
          console.log(`\n=== ${event.title} (${event.id}) ===`);
          console.log(`Found ${eventExpenses.length} expenses from DB`);
          
          // Calculate total in cents: amount (already in cents) + tip (now also in cents)
          const expenseAmounts = eventExpenses.map((exp) => {
            const amountCents = exp.amount || 0; // Already in cents from DB
            const tipCents = exp.tipAmount || 0; // Now also in cents from DB (was stored as dollars before)
            const totalExpCents = amountCents + tipCents;
            return totalExpCents;
          });
          
          const totalExpensesCents = sumCents(...expenseAmounts);
          
          // Get participant count from group if event has a group
          let participantCount = 1; // At least the creator
          if (event.groupId) {
            const members = await db
              .select()
              .from(groupMembers)
              .where(eq(groupMembers.groupId, event.groupId));
            participantCount = Math.max(1, members.length);
          }
          
          return {
            ...event,
            totalExpensesCents,
            participantCount,
          };
        })
      );
      
      userEvents = eventsWithData;
      
      // Get username from customers table
      const [customer] = await db
        .select()
        .from(customers)
        .where(eq(customers.humanId, session.userId))
        .limit(1);
      
      userName = customer?.username || "User";
    }
  } catch (error) {
    console.error("Error checking auth:", error);
  }
}
---

<Layout
  title={isAuthenticated ? "Dashboard - Split" : "Welcome to Split"}
  description={isAuthenticated ? "Your Split dashboard" : "Split expenses easily with friends"}
  currentPage={isAuthenticated ? "dashboard" : undefined}
>
  {
    isAuthenticated ? (
      // AUTHENTICATED HOME PAGE - Dashboard View
      <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
        <!-- Main Content -->
        <main class="flex-1 max-w-7xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
          <!-- Welcome Section -->
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-8">
            <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3">
              Welcome back, {userName}! 👋
            </h2>
            <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 mb-6">
              View your recent events below or go to your dashboard to create new ones.
            </p>
          </div>

          <!-- Recent Events Section -->
          <div>
            <div class="flex justify-between items-center mb-4">
              <h3 class="text-2xl font-bold text-slate-900 dark:text-white">
                Your Recent Events
              </h3>
              <a
                href="/dashboard"
                class="text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-semibold"
              >
                View All →
              </a>
            </div>

            {userEvents.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
                {userEvents.map((event) => (
                  <a
                    href={`/events/${event.id}`}
                    class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-5 sm:p-6 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors cursor-pointer group"
                  >
                    <div class="flex justify-between items-start mb-3">
                      <h4 class="text-lg font-semibold text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                        {event.title}
                      </h4>
                      <span class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-slate-700 px-2.5 py-1 rounded">
                        {event.currency}
                      </span>
                    </div>

                    {event.description && (
                      <p class="text-sm text-slate-600 dark:text-slate-400 mb-3 line-clamp-2">
                        {event.description}
                      </p>
                    )}

                    <div class="text-sm text-slate-600 dark:text-slate-400 space-y-2 mb-4">
                      {event.startTime && (
                        <p>
                          📅 {new Date(event.startTime).toLocaleDateString("en-US", {
                            month: "short",
                            day: "numeric",
                            year: "numeric",
                          })}
                        </p>
                      )}
                    </div>

                    {/* Trip Stats */}
                    <div class="grid grid-cols-2 gap-3 pt-4 border-t border-slate-200 dark:border-slate-700">
                      <div class="flex flex-col">
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium">
                          Total Expenses
                        </p>
                        <p class="text-lg font-bold text-slate-900 dark:text-white">
                          {event.currency} {(event.totalExpensesCents / 100).toFixed(2)}
                        </p>
                      </div>
                      <div class="flex flex-col">
                        <p class="text-xs text-slate-500 dark:text-slate-400 font-medium">
                          Participants
                        </p>
                        <p class="text-lg font-bold text-slate-900 dark:text-white">
                          {event.participantCount} {event.participantCount === 1 ? "person" : "people"}
                        </p>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-12 text-center">
                <p class="text-slate-600 dark:text-slate-400 mb-4">
                  You haven't created any events yet.
                </p>
                <a
                  href="/dashboard"
                  class="inline-block px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-semibold"
                >
                  Create Your First Event
                </a>
              </div>
            )}
          </div>
        </main>
      </div>
    ) : (
      // UNAUTHENTICATED HOME PAGE - Marketing Landing
      <div>


        <main class="min-h-screen bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-950 flex-1">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-24">
            <div class="text-center mb-8 sm:mb-12">
              <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4 leading-tight">
                Split Expenses, Not Friendships
              </h2>
              <p class="text-base sm:text-lg lg:text-xl text-slate-600 dark:text-slate-300 mb-6 sm:mb-8">
                Track shared expenses easily and see who owes what at a glance
              </p>
              <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
                <a
                  href="/auth/register"
                  class="px-6 sm:px-8 py-3 sm:py-4 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-semibold text-base sm:text-lg w-full sm:w-auto"
                >
                  Get Started
                </a>
                <a
                  href="#features"
                  class="px-6 sm:px-8 py-3 sm:py-4 border-2 border-indigo-600 text-indigo-600 dark:text-indigo-400 dark:border-indigo-400 rounded-lg hover:bg-indigo-50 dark:hover:bg-slate-800 transition-colors font-semibold text-base sm:text-lg w-full sm:w-auto"
                >
                  Learn More
                </a>
              </div>
            </div>

            <section id="features" class="grid grid-cols-1 md:grid-cols-3 gap-5 sm:gap-8 mt-12 sm:mt-20">
              <div class="p-5 sm:p-6 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700">
                <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4">
                  Create Events
                </h3>
                <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
                  Organize expenses by events like trips, dinners, or parties
                </p>
              </div>

              <div class="p-5 sm:p-6 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700">
                <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4">
                  Track Expenses
                </h3>
                <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
                  Log who paid and split costs automatically among group members
                </p>
              </div>

              <div class="p-5 sm:p-6 bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700">
                <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-3 sm:mb-4">
                  Settle Up
                </h3>
                <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
                  See instantly who owes whom and settle balances easily
                </p>
              </div>
            </section>
          </div>
        </main>
      </div>
    )
  }
</Layout>
