---
import { getSession } from '../../utils/session';
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { activities } from '../../db/schema';
import { isNull } from 'drizzle-orm';

// Check if user is authenticated
const sessionId = Astro.cookies.get('sessionId')?.value;
if (!sessionId) {
  return Astro.redirect('/auth/login');
}

const session = await getSession(sessionId);
if (!session) {
  Astro.cookies.delete('sessionId', { path: '/' });
  return Astro.redirect('/auth/login');
}

// Get all standalone activities (not linked to any event)
const standaloneActivities = await db.select().from(activities).where(isNull(activities.eventId));

// Get userId from session
const userId = session.userId;
---

<Layout
  title="Standalone Activities"
  description="Manage your standalone activities"
  currentPage="activities"
>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-900 flex flex-col">
    <!-- Page Title -->
    <div
      class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 px-3 sm:px-6 lg:px-8 py-4 sm:py-6"
    >
      <div class="max-w-4xl mx-auto">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white mb-1">
          Standalone Activities
        </h1>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">
          Activities not linked to any event
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-3 sm:px-6 lg:px-8 py-6 sm:py-8">
      <!-- Add Activity Card -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 p-6 sm:p-8 mb-6"
      >
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Create Activity</h2>

        <form id="addActivityForm" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                for="activityTitle"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Activity Title <span class="text-red-600">*</span>
              </label>
              <input
                type="text"
                id="activityTitle"
                name="title"
                required
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                placeholder="e.g., Morning hike"
              />
            </div>

            <div>
              <label
                for="locationName"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Location
              </label>
              <input
                type="text"
                id="locationName"
                name="locationName"
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                placeholder="e.g., Mountain Trail"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                Start Time
              </label>
              <div class="flex gap-2">
                <input
                  type="date"
                  id="startTimeDate"
                  name="startDate"
                  class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                />
                <input
                  type="time"
                  id="startTimeTime"
                  name="startTime"
                  class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
                End Time
              </label>
              <div class="flex gap-2">
                <input
                  type="date"
                  id="endTimeDate"
                  name="endDate"
                  class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                />
                <input
                  type="time"
                  id="endTimeTime"
                  name="endTime"
                  class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                />
              </div>
            </div>
          </div>

          <!-- Add Expense Toggle -->
          <div
            class="p-4 bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900 dark:to-emerald-900 border-2 border-green-400 dark:border-emerald-600 rounded-lg"
          >
            <label class="flex items-center gap-4 cursor-pointer">
              <!-- Toggle Switch -->
              <div
                class="relative inline-block w-14 h-8 bg-gray-300 dark:bg-gray-600 rounded-full transition-colors"
                id="toggleExpenseSwitch"
              >
                <div
                  class="absolute top-1 left-1 w-6 h-6 bg-white dark:bg-slate-200 rounded-full shadow-md transition-transform translate-x-0"
                  id="toggleExpenseThumb"
                >
                </div>
              </div>

              <input
                type="checkbox"
                id="addExpenseWithActivity"
                name="addExpenseWithActivity"
                class="hidden"
              />

              <div>
                <p
                  class="text-sm font-bold text-green-900 dark:text-green-100"
                  id="toggleExpenseLabel"
                >
                  ○ Add Expense
                </p>
                <p class="text-xs text-green-700 dark:text-green-300">
                  Create an expense for this activity
                </p>
              </div>
            </label>
          </div>

          <!-- Expense Fields (Hidden by default) -->
          <div
            id="expenseFieldsContainer"
            class="hidden space-y-4 p-4 bg-green-50 dark:bg-slate-700 rounded-lg border border-green-200 dark:border-slate-600"
          >
            <div>
              <label
                for="expenseGroup"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Group <span class="text-red-600">*</span>
              </label>
              <select
                id="expenseGroup"
                name="expenseGroup"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              >
                <option value="">Select a group...</option>
              </select>
            </div>

            <div>
              <label
                for="expenseDescription"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Expense Description
              </label>
              <input
                type="text"
                id="expenseDescription"
                name="expenseDescription"
                placeholder="Will auto-fill with activity title"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              />
            </div>

            <div>
              <label
                for="expenseCategory"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Category
              </label>
              <select
                id="expenseCategory"
                name="expenseCategory"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              >
                <option value="meal">Meal / Food</option>
                <option value="transport">Transport</option>
                <option value="flight">Flight</option>
                <option value="roundtrip_flight">🔄 Round-Trip Flight</option>
                <option value="accommodation">Accommodation</option>
                <option value="parking">Parking</option>
                <option value="entertainment">Entertainment</option>
                <option value="tickets">Tickets</option>
                <option value="misc" selected>Miscellaneous</option>
              </select>
            </div>

            <div>
              <label
                for="expenseAmount"
                class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
              >
                Amount ($)
              </label>
              <input
                type="number"
                id="expenseAmount"
                name="expenseAmount"
                step="0.01"
                min="0"
                placeholder="0.00"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-600 text-base"
              />
            </div>
          </div>

          <div id="activityError" class="hidden text-red-600 dark:text-red-400 text-sm"></div>

          <button
            type="submit"
            class="w-full px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors font-medium"
          >
            Create Activity
          </button>
        </form>
      </div>

      <!-- Activities List -->
      <div
        class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden"
      >
        <div class="p-6 sm:p-8">
          <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
            Activities ({standaloneActivities.length})
          </h2>

          {
            standaloneActivities.length === 0 ? (
              <p class="text-slate-600 dark:text-slate-400 text-center py-8">
                No standalone activities yet. Create one above to get started!
              </p>
            ) : (
              <div class="space-y-3">
                {standaloneActivities.map((activity: typeof activities.$inferSelect) => (
                  <div
                    class="activity-item border border-slate-200 dark:border-slate-700 rounded-lg p-4 flex justify-between items-start hover:shadow-md transition-shadow"
                    data-activity-id={activity.id}
                  >
                    <div class="flex-1">
                      <a
                        href={`/activities/${activity.id}`}
                        class="font-medium text-indigo-600 dark:text-indigo-400 hover:underline"
                      >
                        {activity.title}
                      </a>
                      {activity.locationName && (
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">
                          📍 {activity.locationName}
                        </p>
                      )}
                      {activity.startTime && (
                        <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">
                          🕐{' '}
                          {new Date(activity.startTime).toLocaleString('en-US', {
                            month: 'short',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit',
                          })}
                          {activity.endTime &&
                            ` - ${new Date(activity.endTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}`}
                        </p>
                      )}
                    </div>

                    <div class="flex gap-2 ml-4">
                      <button
                        class="edit-btn px-3 py-2 text-sm bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded-lg hover:bg-blue-200 dark:hover:bg-blue-800 transition-colors"
                        data-activity-id={activity.id}
                      >
                        ✏️ Edit
                      </button>
                      <button
                        class="delete-btn px-3 py-2 text-sm bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-300 rounded-lg hover:bg-red-200 dark:hover:bg-red-800 transition-colors"
                        data-activity-id={activity.id}
                      >
                        Delete
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </main>
  </div>

  <!-- Edit Activity Modal -->
  <div
    id="editActivityModal"
    class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
  >
    <div
      class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-md border border-slate-200 dark:border-slate-700 my-8"
    >
      <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
        <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white">Edit Activity</h2>
      </div>

      <form id="editActivityForm" class="p-5 sm:p-6 space-y-4">
        <input type="hidden" id="editActivityId" name="activityId" />

        <div>
          <label
            for="editActivityTitle"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Activity Title
          </label>
          <input
            type="text"
            id="editActivityTitle"
            name="title"
            required
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
          />
        </div>

        <div>
          <label
            for="editActivityLocation"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Location
          </label>
          <input
            type="text"
            id="editActivityLocation"
            name="locationName"
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 text-base"
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
              Start Time
            </label>
            <div class="flex gap-2">
              <input
                type="date"
                id="editStartDate"
                name="startDate"
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
              <input
                type="time"
                id="editStartTime"
                name="startTime"
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">
              End Time
            </label>
            <div class="flex gap-2">
              <input
                type="date"
                id="editEndDate"
                name="endDate"
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
              <input
                type="time"
                id="editEndTime"
                name="endTime"
                class="w-full px-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
            </div>
          </div>
        </div>

        <div
          id="editActivityError"
          class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
        >
        </div>

        <div class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700">
          <button
            type="button"
            id="cancelEditBtn"
            class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
          >
            Cancel
          </button>
          <button
            type="submit"
            class="px-4 py-2 bg-indigo-600 text-white hover:bg-indigo-700 rounded-lg transition-colors font-medium text-sm"
          >
            Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Add Expense Modal -->
  <div
    id="addExpenseModal"
    class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 overflow-y-auto"
  >
    <div
      class="bg-white dark:bg-slate-800 rounded-lg shadow-lg w-full max-w-md border border-slate-200 dark:border-slate-700 my-8"
    >
      <div class="p-5 sm:p-6 border-b border-slate-200 dark:border-slate-700">
        <h2 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white">Add Expense</h2>
      </div>

      <form id="addExpenseForm" class="p-5 sm:p-6 space-y-4">
        <input type="hidden" id="expenseActivityId" name="activityId" />

        <div>
          <label
            for="expenseGroupId"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Group <span class="text-red-600">*</span>
          </label>
          <select
            id="expenseGroupId"
            name="groupId"
            required
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-600 text-base"
          >
            <option value="">Select a group...</option>
          </select>
        </div>

        <div>
          <label
            for="expenseDescription"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Description
          </label>
          <input
            type="text"
            id="expenseDescription"
            name="description"
            placeholder="Expense details"
            required
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-600 text-base"
          />
        </div>

        <div>
          <label
            for="expenseModalCategory"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Category
          </label>
          <select
            id="expenseModalCategory"
            name="category"
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-600 text-base"
          >
            <option value="meal">Meal / Food</option>
            <option value="transport">Transport</option>
            <option value="flight">Flight</option>
            <option value="roundtrip_flight">🔄 Round-Trip Flight</option>
            <option value="accommodation">Accommodation</option>
            <option value="parking">Parking</option>
            <option value="entertainment">Entertainment</option>
            <option value="tickets">Tickets</option>
            <option value="misc" selected>Miscellaneous</option>
          </select>
        </div>

        <div>
          <label
            for="expenseAmount"
            class="block text-sm font-medium text-slate-900 dark:text-white mb-2"
          >
            Amount ($)
          </label>
          <input
            type="number"
            id="expenseAmount"
            name="amount"
            step="0.01"
            min="0"
            placeholder="0.00"
            required
            class="w-full px-4 py-3 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-600 text-base"
          />
        </div>

        <div
          id="expenseError"
          class="p-3 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-800 dark:text-red-200 hidden"
        >
        </div>

        <div class="flex gap-3 justify-end pt-4 border-t border-slate-200 dark:border-slate-700">
          <button
            type="button"
            id="cancelExpenseBtn"
            class="px-4 py-2 text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 rounded-lg transition-colors font-medium text-sm"
          >
            Cancel
          </button>
          <button
            type="submit"
            class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-lg transition-colors font-medium text-sm"
          >
            Add Expense
          </button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ userId }}>
    const addActivityForm = document.getElementById('addActivityForm');
    const activityError = document.getElementById('activityError');
    const editActivityModal = document.getElementById('editActivityModal');
    const editActivityForm = document.getElementById('editActivityForm');
    const cancelEditBtn = document.getElementById('cancelEditBtn');
    const editActivityError = document.getElementById('editActivityError');
    const addExpenseModal = document.getElementById('addExpenseModal');
    // Toast notification helper
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toast-message');

    function showToast(message) {
      if (!toast || !toastMessage) return;
      toastMessage.textContent = message;
      toast.classList.remove('opacity-0');
      setTimeout(() => {
        toast.classList.add('opacity-0');
      }, 3000);
    }

    const addExpenseForm = document.getElementById('addExpenseForm');
    const cancelExpenseBtn = document.getElementById('cancelExpenseBtn');
    const expenseError = document.getElementById('expenseError');
    const expenseGroupSelect = document.getElementById('expenseGroupId');

    // Expense toggle for Create Activity form
    const expenseCheckbox = document.getElementById('addExpenseWithActivity');
    const toggleSwitch = document.getElementById('toggleExpenseSwitch');
    const toggleThumb = document.getElementById('toggleExpenseThumb');
    const toggleLabel = document.getElementById('toggleExpenseLabel');
    const expenseFieldsContainer = document.getElementById('expenseFieldsContainer');
    const expenseGroupSelect2 = document.getElementById('expenseGroup');

    // Update toggle state
    function updateExpenseToggleState() {
      if (expenseCheckbox.checked) {
        toggleSwitch.classList.replace('bg-gray-300', 'bg-green-500');
        toggleThumb.classList.add('translate-x-6');
        toggleLabel.textContent = '✓ Add Expense';
        expenseFieldsContainer.classList.remove('hidden');
      } else {
        toggleSwitch.classList.replace('bg-green-500', 'bg-gray-300');
        toggleThumb.classList.remove('translate-x-6');
        toggleLabel.textContent = '○ Add Expense';
        expenseFieldsContainer.classList.add('hidden');
      }
    }

    expenseCheckbox.addEventListener('change', updateExpenseToggleState);
    toggleSwitch.addEventListener('click', () => {
      expenseCheckbox.checked = !expenseCheckbox.checked;
      updateExpenseToggleState();
    });

    // Load groups on page load
    async function loadGroups() {
      try {
        const response = await fetch('/api/groups/list');
        if (response.ok) {
          const data = await response.json();
          expenseGroupSelect.innerHTML = '<option value="">Select a group...</option>';
          expenseGroupSelect2.innerHTML = '<option value="">Select a group...</option>';
          if (data.groups && data.groups.length > 0) {
            data.groups.forEach((group) => {
              const option1 = document.createElement('option');
              option1.value = group.id;
              option1.textContent = group.name;
              expenseGroupSelect.appendChild(option1);

              const option2 = document.createElement('option');
              option2.value = group.id;
              option2.textContent = group.name;
              expenseGroupSelect2.appendChild(option2);
            });
          }
        }
      } catch (error) {
        console.error('Error loading groups:', error);
      }
    }

    // Close modals
    function closeEditModal() {
      editActivityModal.classList.add('hidden');
      editActivityForm.reset();
      editActivityError.classList.add('hidden');
    }

    function closeExpenseModal() {
      addExpenseModal.classList.add('hidden');
      addExpenseForm.reset();
      expenseError.classList.add('hidden');
    }

    cancelEditBtn.addEventListener('click', closeEditModal);
    cancelExpenseBtn.addEventListener('click', closeExpenseModal);

    // Close modals when clicking outside
    editActivityModal.addEventListener('click', (e) => {
      if (false && e.target === editActivityModal) closeEditModal();
    });

    addExpenseModal.addEventListener('click', (e) => {
      if (false && e.target === addExpenseModal) closeExpenseModal();
    });

    // Add activity
    addActivityForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(addActivityForm);
      const data = {
        eventId: null, // Standalone activity
        title: formData.get('title'),
        locationName: formData.get('locationName') || null,
        startTime: formData.get('startTime') || null,
        endTime: formData.get('endTime') || null,
        sequenceOrder: 0,
      };

      try {
        activityError.classList.add('hidden');

        const response = await fetch('/api/activities/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          activityError.textContent =
            error.error?.message || error.error || 'Failed to create activity';
          activityError.classList.remove('hidden');
          return;
        }

        const newActivity = await response.json();
        const newActivityId = newActivity.activity.id;
        const activityTitle = formData.get('title');

        // If expense should be added
        if (expenseCheckbox.checked) {
          const groupId = formData.get('expenseGroup');
          const expenseAmount = parseFloat(formData.get('expenseAmount')) || 0;

          if (!groupId) {
            activityError.textContent = 'Please select a group for the expense';
            activityError.classList.remove('hidden');
            return;
          }

          if (expenseAmount <= 0) {
            activityError.textContent = 'Expense amount must be greater than 0';
            activityError.classList.remove('hidden');
            return;
          }

          try {
            const expenseResponse = await fetch('/api/expenses/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                groupId,
                activityId: newActivityId,
                amount: Math.round(expenseAmount * 100),
                description: formData.get('expenseDescription') || activityTitle,
                category: formData.get('expenseCategory') || 'misc',
                paidBy: userId,
              }),
            });

            if (expenseResponse.ok) {
              if (typeof window.showToast === 'function') {
                window.showToast(`Activity '${activityTitle}' created! ✓ Expense of $${expenseAmount.toFixed(2)} added.`);
              } else {
                alert(`Activity '${activityTitle}' created! ✓ Expense of $${expenseAmount.toFixed(2)} added.`);
              }
            } else {
              if (typeof window.showToast === 'function') {
                window.showToast(`Activity '${activityTitle}' created! Note: Expense creation had an issue.`);
              } else {
                alert(`Activity '${activityTitle}' created! Note: Expense creation had an issue.`);
              }
            }
          } catch (error) {
            console.error('Error creating expense:', error);
            if (typeof window.showToast === 'function') {
              window.showToast(`Activity '${activityTitle}' created! Note: Expense creation had an issue.`);
            } else {
              alert(`Activity '${activityTitle}' created! Note: Expense creation had an issue.`);
            }
          }
        } else {
          if (typeof window.showToast === 'function') {
            window.showToast(`Activity '${activityTitle}' created successfully!`);
          }
        }

        // Reload page to show new activity
        setTimeout(() => {
          window.location.reload();
        }, 1000);
      } catch (error) {
        activityError.textContent = error instanceof Error ? error.message : 'An error occurred';
        activityError.classList.remove('hidden');
      }
    });

    // Edit activity
    document.querySelectorAll('.edit-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const activityId = btn.dataset.activityId;

        try {
          // Fetch activity details
          const response = await fetch(`/api/activities/${activityId}`);
          if (!response.ok) {
            alert('Failed to load activity details');
            return;
          }

          const activityData = await response.json();
          const activity = activityData.activity;

          // Populate form
          document.getElementById('editActivityId').value = activity.id;
          document.getElementById('editActivityTitle').value = activity.title;
          document.getElementById('editActivityLocation').value = activity.locationName || '';

          if (activity.startTime) {
            const startDate = new Date(activity.startTime);
            const offset = startDate.getTimezoneOffset() * 60000;
            const localDate = new Date(startDate.getTime() - offset);
            const isoString = localDate.toISOString();
            document.getElementById('editStartDate').value = isoString.split('T')[0];
            document.getElementById('editStartTime').value = isoString.split('T')[1].slice(0, 5);
          }

          if (activity.endTime) {
            const endDate = new Date(activity.endTime);
            const offset = endDate.getTimezoneOffset() * 60000;
            const localDate = new Date(endDate.getTime() - offset);
            const isoString = localDate.toISOString();
            document.getElementById('editEndDate').value = isoString.split('T')[0];
            document.getElementById('editEndTime').value = isoString.split('T')[1].slice(0, 5);
          }

          editActivityModal.classList.remove('hidden');
        } catch (error) {
          console.error('Error loading activity:', error);
          alert('Failed to load activity');
        }
      });
    });

    // Save edited activity
    editActivityForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const activityId = document.getElementById('editActivityId').value;
      const formData = new FormData(editActivityForm);

      const startDate = formData.get('startDate');
      const startTime = formData.get('startTime');
      const endDate = formData.get('endDate');
      const endTime = formData.get('endTime');

      const startInput = (startDate && startTime) ? new Date(`${startDate}T${startTime}`).toISOString() : null;
      const endInput = (endDate && endTime) ? new Date(`${endDate}T${endTime}`).toISOString() : null;

      const data = {
        activityId,
        title: formData.get('title'),
        locationName: formData.get('locationName') || null,
        startTime: startInput,
        endTime: endInput,
      };

      try {
        editActivityError.classList.add('hidden');

        const response = await fetch('/api/activities/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          editActivityError.textContent = error.error || 'Failed to update activity';
          editActivityError.classList.remove('hidden');
          return;
        }

        // Reload page
        window.location.reload();
      } catch (error) {
        editActivityError.textContent = 'An error occurred';
        editActivityError.classList.remove('hidden');
      }
    });

    // Delete activity
    document.querySelectorAll('.delete-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const activityId = btn.dataset.activityId;

        const isConfirmed = await window.customConfirm('Are you sure you want to delete this activity? This cannot be undone.', 'Delete Activity');
        if (!isConfirmed) {
          return;
        }

        try {
          const response = await fetch('/api/activities/delete-standalone', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ activityId }),
          });

          if (!response.ok) {
            const error = await response.json();
            alert(error.error || error.error?.message || 'Failed to delete activity');
            return;
          }

          // Reload page
          window.location.reload();
        } catch (error) {
          alert(error instanceof Error ? error.message : 'An error occurred');
        }
      });
    });

    // Submit expense form
    addExpenseForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(addExpenseForm);
      const groupId = formData.get('groupId');
      const amount = parseFloat(formData.get('amount')) || 0;

      if (!groupId) {
        expenseError.textContent = 'Please select a group';
        expenseError.classList.remove('hidden');
        return;
      }

      if (amount <= 0) {
        expenseError.textContent = 'Amount must be greater than 0';
        expenseError.classList.remove('hidden');
        return;
      }

      try {
        expenseError.classList.add('hidden');

        const response = await fetch('/api/expenses/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            groupId,
            activityId: formData.get('activityId') || undefined,
            description: formData.get('description'),
            category: formData.get('category') || 'misc',
            amount: Math.round(amount * 100),
            paidBy: userId,
          }),
        });

        if (!response.ok) {
          const error = await response.json();
          expenseError.textContent = error.error || 'Failed to create expense';
          expenseError.classList.remove('hidden');
          return;
        }

        showToast(`Expense of $${amount.toFixed(2)} added successfully!`);
        closeExpenseModal();
        setTimeout(() => {
          window.location.reload();
        }, 1500);
      } catch (error) {
        expenseError.textContent = 'An error occurred';
        expenseError.classList.remove('hidden');
      }
    });

    // Load groups when page loads
    window.addEventListener('load', loadGroups);
  </script>

  <!-- Toast Notification -->
  <div
    id="toast"
    class="fixed bottom-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none z-50 max-w-xs"
  >
    <span id="toast-message"></span>
  </div>
</Layout>
